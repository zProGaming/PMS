@page
@model Vantage.PMS.Pages.Inventory.Categories.CreateModel
@{
    ViewData["Title"] = "Create Inventory Category";
}

<h1 class="h3 mb-3">Create Inventory Category</h1>
<form method="post" class="row g-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="col-md-6">
        <label asp-for="Category.Name" class="form-label"></label>
        <input asp-for="Category.Name" class="form-control" />
        <span asp-validation-for="Category.Name" class="text-danger"></span>
    </div>
    <div class="col-12">
        <label asp-for="Category.Description" class="form-label"></label>
        <textarea asp-for="Category.Description" class="form-control"></textarea>
    </div>
    <div class="col-12">
        <div class="form-check"><input asp-for="Category.IsActive" class="form-check-input" /><label asp-for="Category.IsActive" class="form-check-label"></label></div>
    </div>
    <div class="col-12">
        <button class="btn btn-primary">Create</button>
        <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
