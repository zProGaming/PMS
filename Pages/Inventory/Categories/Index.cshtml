@page
@model Vantage.PMS.Pages.Inventory.Categories.IndexModel
@{
    ViewData["Title"] = "Inventory Categories";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">Inventory Categories</h1>
    <a asp-page="Create" class="btn btn-primary">New Category</a>
</div>

<table class="table table-striped table-hover">
    <thead><tr><th>Name</th><th>Description</th><th>Active</th><th></th></tr></thead>
    <tbody>
        @foreach (var item in Model.Categories)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Description</td>
                <td>@(item.IsActive ? "Yes" : "No")</td>
                <td class="text-end">
                    <a asp-page="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                    <a asp-page="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
