@page
@model Vantage.PMS.Pages.Inventory.StockMovements.IndexModel
@using Vantage.PMS.Models.Inventory
@{
    ViewData["Title"] = "Stock Movements";
}

<h1 class="h3 mb-3">Stock Movements</h1>

<form method="get" class="row g-3 mb-4">
    <div class="col-md-3"><label asp-for="InventoryItemId" class="form-label">Item</label><select asp-for="InventoryItemId" asp-items="Model.InventoryItemOptions" class="form-select"><option value="">All items</option></select></div>
    <div class="col-md-2"><label asp-for="MovementType" class="form-label">Type</label><select asp-for="MovementType" asp-items="Html.GetEnumSelectList<StockMovementType>()" class="form-select"><option value="">All types</option></select></div>
    <div class="col-md-2"><label asp-for="FromDate" class="form-label">From</label><input asp-for="FromDate" type="date" class="form-control" /></div>
    <div class="col-md-2"><label asp-for="ToDate" class="form-label">To</label><input asp-for="ToDate" type="date" class="form-control" /></div>
    <div class="col-md-2"><label asp-for="DepartmentId" class="form-label">Department</label><select asp-for="DepartmentId" asp-items="Model.DepartmentOptions" class="form-select"><option value="">All</option></select></div>
    <div class="col-md-1 align-self-end"><button class="btn btn-primary w-100">Filter</button></div>
</form>

<table class="table table-striped table-hover align-middle">
    <thead><tr><th>Date</th><th>Item</th><th>Type</th><th class="text-end">Quantity</th><th class="text-end">Unit Cost</th><th>Reference</th><th>Department</th><th>Remarks</th></tr></thead>
    <tbody>
        @foreach (var movement in Model.Movements)
        {
            <tr>
                <td>@movement.MovementDate.ToString("g")</td>
                <td>@movement.InventoryItem?.ItemCode - @movement.InventoryItem?.ItemName</td>
                <td>@movement.MovementType</td>
                <td class="text-end">@movement.Quantity.ToString("N2")</td>
                <td class="text-end">@movement.UnitCost.ToString("C")</td>
                <td>@movement.ReferenceType #@movement.ReferenceId</td>
                <td>@movement.Department?.Name</td>
                <td>@movement.Remarks</td>
            </tr>
        }
    </tbody>
</table>
