@page "{id:int}"
@model Vantage.PMS.Pages.Inventory.StockAdjustments.DetailsModel
@{
    ViewData["Title"] = "Stock Adjustment";
    var totalVariance = Model.StockAdjustment.Items.Sum(item => item.VarianceAmount);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">Stock Adjustment @Model.StockAdjustment.AdjustmentNumber</h1>
    <a asp-page="Index" class="btn btn-outline-secondary">Back</a>
</div>

@if (TempData["ErrorMessage"] is string error)
{
    <div class="alert alert-danger">@error</div>
}

<div class="row g-3 mb-4">
    <div class="col-md-3"><div class="border rounded p-3"><div class="text-muted">Date</div><strong>@Model.StockAdjustment.AdjustmentDate.ToString("d")</strong></div></div>
    <div class="col-md-3"><div class="border rounded p-3"><div class="text-muted">Status</div><span class="badge text-bg-secondary">@Model.StockAdjustment.Status</span></div></div>
    <div class="col-md-3"><div class="border rounded p-3"><div class="text-muted">Prepared By</div><strong>@Model.StockAdjustment.PreparedBy</strong></div></div>
    <div class="col-md-3"><div class="border rounded p-3"><div class="text-muted">Variance Amount</div><strong>@totalVariance.ToString("C")</strong></div></div>
</div>

<div class="mb-3 d-flex flex-wrap gap-2">
    @if (Model.StockAdjustment.Status == Vantage.PMS.Models.Inventory.StockAdjustmentStatus.Draft)
    {
        <a asp-page="./Details" asp-page-handler="ForApprovalNative" asp-route-id="@Model.StockAdjustment.Id" class="btn btn-primary" data-vpms-native-dialog data-vpms-native-dialog-title="Submit Stock Adjustment">Submit for Approval</a>
    }
    @if (Model.StockAdjustment.Status == Vantage.PMS.Models.Inventory.StockAdjustmentStatus.ForApproval)
    {
        <a asp-page="./Details" asp-page-handler="ApproveNative" asp-route-id="@Model.StockAdjustment.Id" class="btn btn-success" data-vpms-native-dialog data-vpms-native-dialog-title="Approve Stock Adjustment">Approve</a>
    }
    @if (Model.StockAdjustment.Status == Vantage.PMS.Models.Inventory.StockAdjustmentStatus.Approved)
    {
        <a asp-page="./Details" asp-page-handler="PostAdjustmentNative" asp-route-id="@Model.StockAdjustment.Id" class="btn btn-success" data-vpms-native-dialog data-vpms-native-dialog-title="Post Stock Adjustment">Post Adjustment</a>
    }
    @if (Model.StockAdjustment.Status is not Vantage.PMS.Models.Inventory.StockAdjustmentStatus.Posted and not Vantage.PMS.Models.Inventory.StockAdjustmentStatus.Cancelled)
    {
        <a asp-page="./Details" asp-page-handler="CancelNative" asp-route-id="@Model.StockAdjustment.Id" class="btn btn-outline-secondary" data-vpms-native-dialog data-vpms-native-dialog-title="Cancel Stock Adjustment">Cancel</a>
    }
</div>

<h2 class="h5">Items</h2>
<table class="table table-striped align-middle">
    <thead><tr><th>Item</th><th class="text-end">System Qty</th><th class="text-end">Actual Qty</th><th class="text-end">Variance</th><th class="text-end">Unit Cost</th><th class="text-end">Variance Amount</th><th>Notes</th><th></th></tr></thead>
    <tbody>
        @foreach (var item in Model.StockAdjustment.Items)
        {
            <tr>
                <td>@item.InventoryItem?.ItemCode - @item.InventoryItem?.ItemName</td>
                <td class="text-end">@item.SystemQuantity.ToString("N2")</td>
                <td class="text-end">@item.ActualQuantity.ToString("N2")</td>
                <td class="text-end">@item.VarianceQuantity.ToString("N2")</td>
                <td class="text-end">@item.UnitCost.ToString("C")</td>
                <td class="text-end">@item.VarianceAmount.ToString("C")</td>
                <td>@item.Notes</td>
                <td class="text-end">
                    @if (Model.CanEditItems)
                    {
                        <form method="post" asp-page-handler="DeleteItem" asp-route-itemId="@item.Id">
                            <button class="btn btn-sm btn-outline-danger">Remove</button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@if (Model.CanEditItems)
{
    <h2 class="h5 mt-4">Add Item</h2>
    <form method="post" asp-page-handler="AddItem" class="row g-3">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="col-md-5"><label asp-for="NewItem.InventoryItemId" class="form-label">Item</label><select asp-for="NewItem.InventoryItemId" asp-items="Model.InventoryItemOptions" class="form-select"></select></div>
        <div class="col-md-2"><label asp-for="NewItem.ActualQuantity" class="form-label"></label><input asp-for="NewItem.ActualQuantity" class="form-control" /></div>
        <div class="col-md-5"><label asp-for="NewItem.Notes" class="form-label"></label><input asp-for="NewItem.Notes" class="form-control" /></div>
        <div class="col-12"><button class="btn btn-primary">Add Item</button></div>
    </form>
}

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
