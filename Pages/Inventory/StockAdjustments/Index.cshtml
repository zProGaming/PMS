@page
@model Vantage.PMS.Pages.Inventory.StockAdjustments.IndexModel
@{
    ViewData["Title"] = "Stock Adjustments";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">Stock Adjustments</h1>
    <a asp-page="Create"
       class="btn btn-primary"
       data-vpms-native-dialog
       data-vpms-native-handler="Native"
       data-vpms-native-dialog-title="New Stock Adjustment">New Adjustment</a>
</div>

<div class="vpms-table-wrapper">
    <table class="table table-striped table-hover align-middle mb-0">
        <thead><tr><th>Adjustment #</th><th>Date</th><th>Status</th><th>Prepared By</th><th>Approved By</th><th class="text-end">Variance Amount</th><th></th></tr></thead>
        <tbody>
            @if (!Model.StockAdjustments.Any())
            {
                <tr class="vpms-empty-row">
                    <td colspan="7">
                        <section class="vpms-empty-state vpms-empty-state-table">
                            <strong>No stock adjustments found.</strong>
                            <span>Record an adjustment only after inventory variance review and approval.</span>
                        </section>
                    </td>
                </tr>
            }
            else
            {
                @foreach (var adjustment in Model.StockAdjustments)
                {
                    <tr>
                        <td>@adjustment.AdjustmentNumber</td>
                        <td>@adjustment.AdjustmentDate.ToString("d")</td>
                        <td><span class="badge text-bg-secondary">@adjustment.Status</span></td>
                        <td>@adjustment.PreparedBy</td>
                        <td>@adjustment.ApprovedBy</td>
                        <td class="text-end">@adjustment.Items.Sum(item => item.VarianceAmount).ToString("C")</td>
                        <td class="text-end"><a asp-page="Details" asp-route-id="@adjustment.Id" class="btn btn-sm btn-outline-primary" data-vpms-dialog data-vpms-dialog-title="Stock Adjustment Control">Open</a></td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
