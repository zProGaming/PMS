@page
@model Vantage.PMS.Pages.Inventory.Items.IndexModel
@{
    ViewData["Title"] = "Inventory Items";
}

<div class="page-header">
    <div>
        <div class="page-kicker">Inventory Control</div>
        <h1 class="page-title">Inventory Items</h1>
        <p class="page-subtitle">Stock master records, par levels, reorder points, and cost controls for hotel operations.</p>
    </div>
    <a asp-page="Create" class="btn btn-primary" data-vpms-dialog data-vpms-dialog-title="New Inventory Item">New Item</a>
</div>

<div class="vpms-table-wrapper">
    <table class="table table-striped table-hover align-middle mb-0">
        <thead>
            <tr>
                <th>Item Code</th>
                <th>Item Name</th>
                <th>Category</th>
                <th>UOM</th>
                <th class="text-end">Current Stock</th>
                <th class="text-end">Reorder</th>
                <th class="text-end">Par</th>
                <th class="text-end">Standard Cost</th>
                <th>Active</th>
                <th>Stock</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Items.Any())
            {
                <tr class="vpms-empty-row">
                    <td colspan="11">
                        <section class="vpms-empty-state vpms-empty-state-table">
                            <strong>No inventory items configured.</strong>
                            <span>No inventory items match the current view.</span>
                        </section>
                    </td>
                </tr>
            }
            else
            {
                @foreach (var item in Model.Items)
                {
                    var lowStock = item.CurrentStock <= item.ReorderLevel;
                    <tr>
                        <td>@item.ItemCode</td>
                        <td>@item.ItemName</td>
                        <td>@item.InventoryCategory?.Name</td>
                        <td>@item.UnitOfMeasure</td>
                        <td class="text-end">@item.CurrentStock.ToString("N2")</td>
                        <td class="text-end">@item.ReorderLevel.ToString("N2")</td>
                        <td class="text-end">@item.ParStockLevel.ToString("N2")</td>
                        <td class="text-end">@item.StandardCost.ToString("C")</td>
                        <td>@(item.IsActive ? "Yes" : "No")</td>
                        <td>
                            @if (item.CurrentStock <= 0)
                            {
                                <span class="badge text-bg-danger">Out</span>
                            }
                            else if (lowStock)
                            {
                                <span class="badge text-bg-warning">Low</span>
                            }
                            else
                            {
                                <span class="badge text-bg-success">OK</span>
                            }
                        </td>
                        <td class="text-end">
                            <div class="vpms-row-actions">
                                <a asp-page="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" data-vpms-dialog data-vpms-dialog-title="Inventory Item Control">Details</a>
                                <a asp-page="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" data-vpms-dialog data-vpms-dialog-title="Edit Inventory Item">Edit</a>
                                <a asp-page="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
