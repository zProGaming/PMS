@page
@model Vantage.PMS.Pages.GuestPortal.ExpressCheckoutModel
@{
    ViewData["Title"] = "Express Checkout";
}

<h1 class="h3 mb-3">Express Checkout Request</h1>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-success">@Model.StatusMessage</div>
}

@if (Model.Access is null)
{
    <div class="alert alert-warning">Guest portal access is invalid or expired.</div>
}
else if (!Model.Setting.AllowExpressCheckoutRequest)
{
    <div class="alert alert-info">Express checkout requests are currently unavailable.</div>
}
else if (!Model.CanRequestExpressCheckout)
{
    <div class="alert alert-info">Express checkout can be requested only for checked-in stays.</div>
}
else
{
    <form method="post" class="row g-3">
        <input type="hidden" asp-for="Token" />
        <div class="col-12">
            <label asp-for="GuestNotes" class="form-label">Notes for front desk</label>
            <textarea asp-for="GuestNotes" class="form-control" rows="4"></textarea>
        </div>
        <div class="col-12">
            <button type="submit" class="btn btn-primary">Request Express Checkout</button>
            <a asp-page="Home" asp-route-token="@Model.Token" class="btn btn-outline-secondary">Back</a>
        </div>
    </form>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
