@page
@model Vantage.PMS.Pages.GuestPortal.MyStayModel
@{
    ViewData["Title"] = "My Stay";
}

<h1 class="h3 mb-3">My Stay</h1>

@if (Model.Access is null)
{
    <div class="alert alert-warning">Guest portal access is invalid or expired.</div>
}
else
{
    <div class="card">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Guest</dt>
                <dd class="col-sm-9">@Model.GuestName</dd>
                <dt class="col-sm-3">Reference</dt>
                <dd class="col-sm-9">@Model.Reference</dd>
                <dt class="col-sm-3">Dates</dt>
                <dd class="col-sm-9">@Model.StayDates</dd>
                <dt class="col-sm-3">Room Type</dt>
                <dd class="col-sm-9">@Model.RoomType</dd>
                <dt class="col-sm-3">Room</dt>
                <dd class="col-sm-9">@Model.RoomNumber</dd>
                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">@Model.Status</dd>
                <dt class="col-sm-3">Special Requests</dt>
                <dd class="col-sm-9">@Model.SpecialRequests</dd>
            </dl>
        </div>
    </div>
    <a asp-page="Home" asp-route-token="@Model.Token" class="btn btn-outline-secondary mt-3">Back</a>
}
