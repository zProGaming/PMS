@page
@model Vantage.PMS.Pages.FrontOffice.RoomRack.IndexModel
@using Vantage.PMS.Models.FrontOffice

@{
    ViewData["Title"] = "Room Calendar";
    var rangeEnd = Model.EffectiveEndDateExclusive.AddDays(-1);
    var calendarStyle = $"--vpms-calendar-days:{Model.DateColumns.Count};";
    var dateRangeLabel = $"{Model.EffectiveStartDate:MMM d} - {rangeEnd:MMM d, yyyy}";
    var startDateValue = Model.EffectiveStartDate.ToString("yyyy-MM-dd");
    var monthBands = Model.DateColumns
        .Select((day, index) => new { day.Date, Index = index })
        .GroupBy(item => new { item.Date.Year, item.Date.Month })
        .Select(group => new
        {
            Label = new DateTime(group.Key.Year, group.Key.Month, 1).ToString("MMM yyyy"),
            Start = group.Min(item => item.Index) + 2,
            Span = group.Count()
        })
        .ToList();
}

<section class="vpms-ops-hero vpms-room-calendar-hero">
    <div>
        <div class="page-kicker">Front Office / Housekeeping Grid</div>
        <h1 class="page-title">Room Calendar</h1>
        <p class="page-subtitle">A date-range command view for physical room occupancy, arrivals, departures, housekeeping attention, and room inventory controls.</p>
        <div class="vpms-hero-chip-row">
            <span class="vpms-mini-chip">@dateRangeLabel</span>
            <span class="vpms-mini-chip">Business date @Model.BusinessDate.ToString("MMM d, yyyy")</span>
            <span class="vpms-mini-chip">@Model.TotalRooms physical rooms</span>
            <span class="vpms-mini-chip">@Model.AverageOccupancyInRange.ToString("N1")% average occupancy</span>
        </div>
    </div>
    <div class="vpms-hero-actions">
        <a class="btn vpms-btn-secondary" asp-page="/Housekeeping/Index">Housekeeping</a>
        <a class="btn vpms-btn-secondary" href="@Model.BuildRouteFor(Model.BusinessDate)">Today</a>
        <a class="btn vpms-btn-primary" asp-page="/FrontOffice/Reservations/Create" data-vpms-native-dialog data-vpms-native-handler="Native" data-vpms-native-dialog-title="Create Reservation">New Reservation</a>
    </div>
</section>

<section class="vpms-calendar-command-strip" aria-label="Room calendar operating pulse">
    <article>
        <span>Available now</span>
        <strong>@Model.AvailableRooms</strong>
        <small>Ready, clean, or inspected</small>
    </article>
    <article>
        <span>Occupied now</span>
        <strong>@Model.OccupiedRooms</strong>
        <small>Checked-in rooms</small>
    </article>
    <article class="@(Model.UnassignedReservationsInRange > 0 ? "attention" : "")">
        <span>Unassigned stays</span>
        <strong>@Model.UnassignedReservationsInRange</strong>
        <small>Need room assignment</small>
    </article>
    <article class="@(Model.ArrivalsInRange > 0 ? "attention" : "")">
        <span>Arrivals</span>
        <strong>@Model.ArrivalsInRange</strong>
        <small>In selected range</small>
    </article>
    <article>
        <span>Departures</span>
        <strong>@Model.DeparturesInRange</strong>
        <small>In selected range</small>
    </article>
    <article class="@(Model.OpenHousekeepingTasks > 0 ? "warning" : "positive")">
        <span>HK attention</span>
        <strong>@Model.OpenHousekeepingTasks</strong>
        <small>Open room tasks</small>
    </article>
    <article class="@(Model.OutOfOrderRooms > 0 ? "danger" : "")">
        <span>Blocked rooms</span>
        <strong>@Model.OutOfOrderRooms</strong>
        <small>OOO / maintenance</small>
    </article>
</section>

<section class="vpms-card vpms-calendar-filter-card">
    <form method="get" class="vpms-calendar-filters">
        <div>
            <label class="form-label" asp-for="Search">Search</label>
            <input class="form-control" asp-for="Search" placeholder="Room, room type, guest, confirmation" data-vpms-calendar-search />
        </div>
        <div>
            <label class="form-label" asp-for="StartDate">Start date</label>
            @Html.Raw($"<input class=\"form-control\" id=\"StartDate\" name=\"StartDate\" type=\"date\" value=\"{startDateValue}\" />")
        </div>
        <div>
            <label class="form-label" asp-for="Days">Range</label>
            <select class="form-select" asp-for="Days">
                <option value="7">7 days</option>
                <option value="14">14 days</option>
                <option value="21">21 days</option>
                <option value="30">30 days</option>
            </select>
        </div>
        <div>
            <label class="form-label" asp-for="RoomTypeId">Room type</label>
            <select class="form-select" asp-for="RoomTypeId" asp-items="Model.RoomTypeOptions">
                <option value="">All room types</option>
            </select>
        </div>
        <div>
            <label class="form-label" asp-for="Status">Room status</label>
            <select class="form-select" asp-for="Status" asp-items="Model.StatusOptions">
                <option value="">All statuses</option>
            </select>
        </div>
        <div class="vpms-calendar-filter-actions">
            <button type="submit" class="btn vpms-btn-primary">Apply</button>
            <a class="btn vpms-btn-secondary" asp-page="/FrontOffice/RoomRack/Index">Reset</a>
        </div>
    </form>
</section>

<section class="vpms-calendar-focus-panel" aria-live="polite">
    <div>
        <span>Calendar Focus</span>
        <strong id="vpmsCalendarFocusTitle">Hover a room, date, or stay</strong>
        <small id="vpmsCalendarFocusDetail">Open cells create a one-night reservation from that room and date. Stay bars open the reservation control page.</small>
    </div>
    <a id="vpmsCalendarFocusAction" class="btn btn-sm vpms-btn-secondary" asp-page="/FrontOffice/Reservations/Index">Open Reservations</a>
</section>

<section class="vpms-calendar-operations-layout">
    <div class="vpms-calendar-operations-main">
        <section class="vpms-calendar-legend-panel" aria-label="Room calendar legend">
            <div class="vpms-calendar-period-nav">
                <a class="btn btn-sm vpms-btn-secondary" href="@Model.BuildRouteFor(Model.EffectiveStartDate.AddDays(-Model.Days))">Previous</a>
                <strong>@dateRangeLabel</strong>
                <a class="btn btn-sm vpms-btn-secondary" href="@Model.BuildRouteFor(Model.EffectiveStartDate.AddDays(Model.Days))">Next</a>
            </div>
            <div class="vpms-calendar-legend">
                <span><i class="vpms-legend-dot reserved"></i> Reserved</span>
                <span><i class="vpms-legend-dot pending"></i> Pending</span>
                <span><i class="vpms-legend-dot checkedin"></i> In-house</span>
                <span><i class="vpms-legend-dot checkedout"></i> Checked out</span>
                <span><i class="vpms-legend-dot noshow"></i> No-show</span>
                <span><i class="vpms-legend-dot today"></i> Today</span>
                <span><i class="vpms-legend-dot task"></i> HK task</span>
                <span><i class="vpms-legend-dot blocked"></i> OOO / Maintenance</span>
            </div>
        </section>

        @if (Model.RoomTypeGroups.Count == 0)
        {
            <section class="vpms-empty-state vpms-calendar-empty">
                <strong>No rooms match this calendar view.</strong>
                <span>Adjust the filters, create active physical rooms, or seed demo data to populate the room calendar. Pseudo rooms and paymaster accounts are intentionally excluded from occupancy inventory.</span>
                <a class="btn vpms-btn-primary" asp-page="/Admin/Rooms/Create">Create Room</a>
            </section>
        }
        else
        {
            <section class="vpms-room-calendar-shell" aria-label="Interactive room calendar">
        <div class="vpms-room-calendar-grid" style="@calendarStyle">
            <div class="vpms-calendar-month-row">
                <div class="vpms-calendar-month-head">
                    <span>Stay Timeline</span>
                    <small>@Model.BusinessDate.ToString("dddd, MMM d")</small>
                </div>
                @foreach (var month in monthBands)
                {
                    <div class="vpms-calendar-month-band" style="grid-column: @month.Start / span @month.Span;">
                        @month.Label
                    </div>
                }
            </div>
            <div class="vpms-calendar-header-row">
                <div class="vpms-calendar-room-head">
                    <span>Physical Rooms</span>
                    <small>Pseudo rooms excluded from occupancy</small>
                </div>
                @foreach (var day in Model.DateColumns)
                {
                    var dayClass = day.IsToday ? "is-today" : day.IsWeekend ? "is-weekend" : string.Empty;
                    <div class="vpms-calendar-day @dayClass">
                        <span>@day.Date.ToString("ddd")</span>
                        <strong>@day.Date.ToString("MMM d")</strong>
                        <small>@day.AvailableRooms available / @day.OccupancyPercentage.ToString("N1")%</small>
                    </div>
                }
            </div>

            @foreach (var group in Model.RoomTypeGroups)
            {
                <details class="vpms-calendar-type-group" open>
                    <summary class="vpms-calendar-type-row">
                        <div class="vpms-calendar-type-title">
                            <span>@group.RoomTypeName</span>
                            <small>@group.Rooms.Count physical rooms</small>
                        </div>
                        @foreach (var summary in group.DateSummaries)
                        {
                            var summaryClass = summary.IsToday ? "is-today" : string.Empty;
                            <div class="vpms-calendar-type-day @summaryClass">
                                <strong>@summary.AvailableRooms</strong>
                                <span>@summary.DisplayRate.ToString("C0")</span>
                                @if (summary.IsStopSell)
                                {
                                    <small>Stop sell</small>
                                }
                                else
                                {
                                    <small>@summary.OccupancyPercentage.ToString("N0")% occ</small>
                                }
                            </div>
                        }
                    </summary>

                    @foreach (var room in group.Rooms)
                    {
                        var roomStatusClass = room.Status.ToString().ToLowerInvariant();
                        var searchText = $"{room.RoomNumber} room {room.RoomTypeName} {room.PropertyName} {string.Join(' ', room.ReservationBars.Select(bar => $"{bar.GuestName} {bar.ConfirmationNumber}"))}";
                        <div class="vpms-calendar-room-row status-@roomStatusClass" data-room-search="@searchText">
                            <div class="vpms-calendar-room-label">
                                <div>
                                    <strong>Room @room.RoomNumber</strong>
                                    <span>@room.RoomTypeName - Floor @room.Floor</span>
                                </div>
                                <div class="vpms-room-label-meta">
                                    <span class="status-badge status-@roomStatusClass">@IndexModel.FormatEnum(room.Status.ToString())</span>
                                    @if (room.UrgentTaskCount > 0)
                                    {
                                        <span class="vpms-calendar-alert-pill danger">@room.UrgentTaskCount urgent</span>
                                    }
                                    else if (room.OpenTaskCount > 0)
                                    {
                                        <span class="vpms-calendar-alert-pill">@room.OpenTaskCount task</span>
                                    }
                                    <a class="vpms-calendar-label-action"
                                       asp-page="/Housekeeping/Rooms/UpdateStatus"
                                       asp-route-id="@room.RoomId"
                                       data-vpms-native-dialog
                                       data-vpms-native-handler="Native"
                                       data-vpms-native-dialog-title="Update Room Status">Status</a>
                                </div>
                            </div>

                            @foreach (var cell in room.Cells)
                            {
                                var arrival = cell.Date.ToString("yyyy-MM-dd");
                                var departure = cell.Date.AddDays(1).ToString("yyyy-MM-dd");
                                var cellTitleDate = cell.Date.ToString("MMM d, yyyy");
                                var hasReservation = cell.ReservationId.HasValue;
                                var isAssignableRoom = room.Status is RoomStatus.Available or RoomStatus.Clean or RoomStatus.Inspected;
                                var canQuickCreate = !hasReservation && isAssignableRoom && !cell.IsStopSell;
                                var usesReservationDialog = hasReservation;
                                var usesStatusDialog = !hasReservation && !isAssignableRoom;
                                var cellActionLabel = hasReservation
                                    ? "Open Reservation"
                                    : !isAssignableRoom
                                        ? "Review Room Status"
                                        : cell.IsStopSell
                                            ? "Review Inventory Control"
                                            : "Create Reservation";
                                var cellClass = string.Join(" ", new[]
                                {
                                    cell.IsToday ? "is-today" : string.Empty,
                                    hasReservation ? "has-reservation" : string.Empty,
                                    canQuickCreate ? "is-open-cell" : "is-controlled-cell",
                                    cell.IsCurrentOccupied ? "is-current-occupied" : string.Empty,
                                    cell.IsCurrentDirty ? "is-current-dirty" : string.Empty,
                                    cell.IsCurrentReady ? "is-current-ready" : string.Empty,
                                    cell.IsUnavailable ? "is-unavailable" : string.Empty,
                                    cell.IsStopSell ? "is-stop-sell" : string.Empty,
                                    cell.HasOpenTask ? "has-task" : string.Empty,
                                    cell.HasUrgentTask ? "has-urgent-task" : string.Empty
                                }.Where(value => !string.IsNullOrWhiteSpace(value)));
                                var cellFocusText = IndexModel.BuildCellFocusText(room, cell);
                                var cellActionUrl = Url.Page("/FrontOffice/Reservations/Create", new
                                {
                                    roomId = room.RoomId,
                                    arrivalDate = arrival,
                                    departureDate = departure
                                }) ?? "#";
                                var cellNavigationUrl = hasReservation
                                    ? Url.Page("/FrontOffice/Reservations/Details", new { id = cell.ReservationId!.Value }) ?? "#"
                                    : !isAssignableRoom
                                        ? Url.Page("/Housekeeping/Rooms/UpdateStatus", new { id = room.RoomId }) ?? "#"
                                        : cell.IsStopSell
                                            ? Url.Page("/Revenue/RoomInventoryControls/Index") ?? "#"
                                            : cellActionUrl;
                                <a class="vpms-calendar-cell @cellClass"
                                   href="@cellNavigationUrl"
                                   data-quick-reservation="@canQuickCreate.ToString().ToLowerInvariant()"
                                   data-room-id="@room.RoomId"
                                   data-room-number="@room.RoomNumber"
                                   data-room-type="@room.RoomTypeName"
                                   data-room-status="@IndexModel.FormatEnum(room.Status.ToString())"
                                   data-arrival="@arrival"
                                   data-departure="@departure"
                                   data-rate="@room.BaseRate.ToString("0.##", global::System.Globalization.CultureInfo.InvariantCulture)"
                                   data-vpms-dialog="@(usesReservationDialog ? string.Empty : null)"
                                   data-vpms-dialog-title="Reservation Control"
                                   data-vpms-native-dialog="@(usesStatusDialog ? string.Empty : null)"
                                   data-vpms-native-handler="@(usesStatusDialog ? "Native" : null)"
                                   data-vpms-native-dialog-title="Update Room Status"
                                   data-calendar-inspector
                                   data-inspector-title="Room @room.RoomNumber - @cellTitleDate"
                                   data-inspector-detail="@cellFocusText"
                                   data-inspector-action="@cellActionLabel"
                                   data-inspector-url="@cellNavigationUrl"
                                   aria-label="@cellActionLabel for Room @room.RoomNumber on @cellTitleDate"
                                   title="@cellActionLabel for Room @room.RoomNumber on @cellTitleDate">
                                    @if (cell.IsCurrentOccupied)
                                    {
                                        <span class="vpms-cell-marker occupied">OCC</span>
                                    }
                                    else if (cell.IsCurrentDirty)
                                    {
                                        <span class="vpms-cell-marker dirty">Dirty</span>
                                    }
                                    else if (cell.IsCurrentReady)
                                    {
                                        <span class="vpms-cell-marker ready">Ready</span>
                                    }
                                    @if (cell.HasArrival)
                                    {
                                        <span class="vpms-cell-marker arrival">CI</span>
                                    }
                                    @if (cell.HasDeparture)
                                    {
                                        <span class="vpms-cell-marker departure">CO</span>
                                    }
                                    @if (cell.HasOpenTask)
                                    {
                                        <span class="vpms-cell-marker task">HK</span>
                                    }
                                    @if (cell.IsStopSell)
                                    {
                                        <span class="vpms-cell-marker stop">Stop</span>
                                    }
                                    @if (hasReservation)
                                    {
                                        <span class="vpms-cell-marker stay">Stay</span>
                                    }
                                </a>
                            }

                            @if (room.ReservationBars.Count > 0)
                            {
                                <div class="vpms-calendar-reservation-layer">
                                    @foreach (var bar in room.ReservationBars)
                                    {
                                        var barStatusClass = bar.Status.ToString().ToLowerInvariant();
                                        var barClass = $"{barStatusClass} {(bar.IsContinuedBefore ? "continues-before" : "")} {(bar.IsContinuedAfter ? "continues-after" : "")}";
                                        var stayTitle = $"{bar.GuestName} - {bar.ConfirmationNumber} - {bar.ArrivalDate:MMM d} to {bar.DepartureDate:MMM d}";
                                        var stayUrl = Url.Page("/FrontOffice/Reservations/Details", new { id = bar.ReservationId }) ?? "#";
                                        <a class="vpms-stay-bar @barClass"
                                           asp-page="/FrontOffice/Reservations/Details"
                                           asp-route-id="@bar.ReservationId"
                                           style="grid-column: @bar.StartOffset / span @bar.Span;"
                                           data-calendar-inspector
                                           data-inspector-title="@bar.GuestName"
                                           data-inspector-detail="@bar.ConfirmationNumber - @IndexModel.FormatEnum(bar.Status.ToString()) - @bar.ArrivalDate.ToString("MMM d") to @bar.DepartureDate.ToString("MMM d")"
                                           data-inspector-action="Open Reservation"
                                           data-inspector-url="@stayUrl"
                                           data-vpms-dialog
                                           data-vpms-dialog-title="Reservation Control"
                                           title="@stayTitle">
                                            <span>@bar.GuestName</span>
                                            <small>@IndexModel.FormatEnum(bar.Status.ToString())</small>
                                        </a>
                                    }
                                </div>
                            }
                        </div>
                    }
                </details>
            }
        </div>
            </section>
        }
    </div>

    <aside class="vpms-calendar-side-inspector" aria-live="polite">
        <div class="vpms-calendar-side-inspector-header">
            <span>Calendar Inspector</span>
            <strong id="vpmsCalendarInspectorTitle">Select a stay, room, or date</strong>
            <p id="vpmsCalendarInspectorDetail">Use the calendar to inspect a room/stay while keeping the date grid in view.</p>
        </div>
        <div class="vpms-calendar-side-inspector-meta">
            <span id="vpmsCalendarInspectorStatus">Context pending</span>
            <span id="vpmsCalendarInspectorDate">@Model.BusinessDate.ToString("MMM d, yyyy")</span>
        </div>
        <div class="vpms-calendar-side-inspector-actions">
            <a id="vpmsCalendarInspectorPrimary" class="btn vpms-btn-primary" asp-page="/FrontOffice/Reservations/Index">Open Reservations</a>
            <a id="vpmsCalendarInspectorRoomStatus"
               class="btn vpms-btn-secondary disabled"
               href="@Url.Page("/Housekeeping/Rooms/UpdateStatus", new { id = 0 })"
               aria-disabled="true"
               data-status-url-template="@Url.Page("/Housekeeping/Rooms/UpdateStatus", new { id = 0 })"
               data-vpms-native-dialog
               data-vpms-native-handler="Native"
               data-vpms-native-dialog-title="Update Room Status">Room Status</a>
            <a class="btn vpms-btn-secondary" asp-page="/Housekeeping/Index">Room Readiness</a>
            <a class="btn vpms-btn-secondary" asp-page="/FrontOffice/Reservations/Create" data-vpms-native-dialog data-vpms-native-handler="Native" data-vpms-native-dialog-title="Create Reservation">New Reservation</a>
        </div>
        <div class="vpms-calendar-side-inspector-note">
            <strong>Stay in context</strong>
            <span>Reservation bars open a control dialog. Sellable open cells launch quick reservation. Room status pills open housekeeping status control.</span>
        </div>
    </aside>
</section>

<section class="vpms-card vpms-calendar-note">
    <div>
        <h2>Operational Notes</h2>
        <p>This grid is designed for Front Office and Housekeeping coordination. It shows active physical rooms only, overlays reservations by stay dates, highlights room readiness risks, and links empty cells to a prefilled reservation workflow.</p>
    </div>
    <div class="vpms-calendar-note-actions">
        <a class="btn vpms-btn-secondary" asp-page="/FrontOffice/Reservations/Index">Reservations</a>
        <a class="btn vpms-btn-secondary" asp-page="/Housekeeping/Tasks/Index">Housekeeping Tasks</a>
    </div>
</section>

<div class="modal fade vpms-command-modal vpms-quick-reservation-modal" id="quickReservationModal" tabindex="-1" aria-labelledby="quickReservationModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <span class="page-kicker">Room Calendar Workflow</span>
                    <h2 class="modal-title" id="quickReservationModalLabel">Create Stay Without Leaving Calendar</h2>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="QuickReservation" id="quickReservationForm" class="vpms-modal-reservation-form">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="vpms-quick-reservation-summary">
                        <article>
                            <span>Selected Room</span>
                            <strong id="quickReservationRoomLabel">Room not selected</strong>
                            <small id="quickReservationRoomMeta">Choose an open calendar cell.</small>
                        </article>
                        <article>
                            <span>Stay Date</span>
                            <strong id="quickReservationStayLabel">Pending</strong>
                            <small>Adjust dates before confirming if this is a multi-night stay.</small>
                        </article>
                    </div>

                    <div class="alert alert-danger vpms-alert d-none" id="quickReservationError" role="alert"></div>
                    <div class="alert alert-success vpms-alert d-none" id="quickReservationSuccess" role="status"></div>

                    <input type="hidden" asp-for="QuickReservation.RoomId" id="QuickReservation_RoomId" />

                    <div class="vpms-modal-form-grid">
                        <div class="vpms-modal-field wide">
                            <label asp-for="QuickReservation.GuestId" class="form-label">Guest</label>
                            <select asp-for="QuickReservation.GuestId" class="form-select" asp-items="Model.ReservationGuestOptions">
                                <option value="">Select guest profile</option>
                            </select>
                            <small class="form-text">For a new guest profile, use the full reservation workflow.</small>
                        </div>
                        <div class="vpms-modal-field">
                            <label asp-for="QuickReservation.ArrivalDate" class="form-label">Check-in</label>
                            <input asp-for="QuickReservation.ArrivalDate" class="form-control" type="date" id="QuickReservation_ArrivalDate" />
                        </div>
                        <div class="vpms-modal-field">
                            <label asp-for="QuickReservation.DepartureDate" class="form-label">Check-out</label>
                            <input asp-for="QuickReservation.DepartureDate" class="form-control" type="date" id="QuickReservation_DepartureDate" />
                        </div>
                        <div class="vpms-modal-field">
                            <label asp-for="QuickReservation.RatePlanId" class="form-label">Rate Plan</label>
                            <select asp-for="QuickReservation.RatePlanId" class="form-select" asp-items="Model.ReservationRatePlanOptions">
                                <option value="">Use room base rate</option>
                            </select>
                        </div>
                        <div class="vpms-modal-field">
                            <label asp-for="QuickReservation.RateAmount" class="form-label">Rate Amount</label>
                            <input asp-for="QuickReservation.RateAmount" class="form-control" type="number" min="0" step="0.01" id="QuickReservation_RateAmount" />
                        </div>
                        <div class="vpms-modal-field">
                            <label asp-for="QuickReservation.Adults" class="form-label">Adults</label>
                            <input asp-for="QuickReservation.Adults" class="form-control" type="number" min="0" value="1" />
                        </div>
                        <div class="vpms-modal-field">
                            <label asp-for="QuickReservation.Children" class="form-label">Children</label>
                            <input asp-for="QuickReservation.Children" class="form-control" type="number" min="0" value="0" />
                        </div>
                        <div class="vpms-modal-field">
                            <label asp-for="QuickReservation.Status" class="form-label">Status</label>
                            <select asp-for="QuickReservation.Status" class="form-select" asp-items="Model.ReservationStatusOptions"></select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <a class="btn vpms-btn-secondary" id="quickReservationFullPageLink" asp-page="/FrontOffice/Reservations/Create">Full Workflow</a>
                    <button type="button" class="btn vpms-btn-secondary d-none" id="quickReservationRefresh">Refresh Calendar</button>
                    <button type="button" class="btn vpms-btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn vpms-btn-primary" id="quickReservationSubmit">Create Stay</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const searchInput = document.querySelector('[data-vpms-calendar-search]');
            const roomRows = Array.from(document.querySelectorAll('.vpms-calendar-room-row[data-room-search]'));
            const focusTitle = document.getElementById('vpmsCalendarFocusTitle');
            const focusDetail = document.getElementById('vpmsCalendarFocusDetail');
            const focusAction = document.getElementById('vpmsCalendarFocusAction');
            const inspectorTitle = document.getElementById('vpmsCalendarInspectorTitle');
            const inspectorDetail = document.getElementById('vpmsCalendarInspectorDetail');
            const inspectorPrimary = document.getElementById('vpmsCalendarInspectorPrimary');
            const inspectorStatus = document.getElementById('vpmsCalendarInspectorStatus');
            const inspectorDate = document.getElementById('vpmsCalendarInspectorDate');
            const inspectorRoomStatus = document.getElementById('vpmsCalendarInspectorRoomStatus');
            const quickReservationModal = document.getElementById('quickReservationModal');
            const quickReservationForm = document.getElementById('quickReservationForm');
            const quickReservationSubmit = document.getElementById('quickReservationSubmit');
            const quickReservationError = document.getElementById('quickReservationError');
            const quickReservationSuccess = document.getElementById('quickReservationSuccess');
            const quickReservationRoomLabel = document.getElementById('quickReservationRoomLabel');
            const quickReservationRoomMeta = document.getElementById('quickReservationRoomMeta');
            const quickReservationStayLabel = document.getElementById('quickReservationStayLabel');
            const quickReservationFullPageLink = document.getElementById('quickReservationFullPageLink');
            const quickReservationRefresh = document.getElementById('quickReservationRefresh');
            const modalInstance = quickReservationModal && window.bootstrap
                ? new bootstrap.Modal(quickReservationModal)
                : null;

            const updateGroupVisibility = () => {
                document.querySelectorAll('.vpms-calendar-type-group').forEach(group => {
                    const visibleRows = group.querySelectorAll('.vpms-calendar-room-row:not([hidden])').length;
                    group.hidden = visibleRows === 0;
                });
            };

            if (searchInput && roomRows.length) {
                searchInput.addEventListener('input', () => {
                    const terms = searchInput.value.trim().toLowerCase().split(/\s+/).filter(Boolean);
                    roomRows.forEach(row => {
                        const haystack = (row.dataset.roomSearch || '').toLowerCase();
                        row.hidden = terms.length > 0 && !terms.every(term => haystack.includes(term));
                    });
                    updateGroupVisibility();
                });
            }

            const resetWorkflowTarget = (target) => {
                if (!target) {
                    return;
                }

                delete target.dataset.vpmsDialog;
                delete target.dataset.vpmsDialogTitle;
                delete target.dataset.vpmsNativeDialog;
                delete target.dataset.vpmsNativeDialogTitle;
                delete target.dataset.vpmsNativeHandler;
            };

            const configureWorkflowTarget = (target, element, action, url) => {
                if (!target) {
                    return;
                }

                resetWorkflowTarget(target);

                let path = '';
                try {
                    path = new URL(url, window.location.origin).pathname.toLowerCase();
                } catch {
                    path = '';
                }

                if (element.dataset.vpmsDialog !== undefined || path.includes('/frontoffice/reservations/details')) {
                    target.dataset.vpmsDialog = '';
                    target.dataset.vpmsDialogTitle = element.dataset.vpmsDialogTitle || 'Reservation Control';
                    return;
                }

                if (element.dataset.vpmsNativeDialog !== undefined || path.includes('/housekeeping/rooms/updatestatus')) {
                    target.dataset.vpmsNativeDialog = '';
                    target.dataset.vpmsNativeHandler = element.dataset.vpmsNativeHandler || 'Native';
                    target.dataset.vpmsNativeDialogTitle = element.dataset.vpmsNativeDialogTitle || 'Update Room Status';
                    return;
                }

                if (element.dataset.quickReservation === 'true' || path.includes('/frontoffice/reservations/create')) {
                    target.dataset.vpmsNativeDialog = '';
                    target.dataset.vpmsNativeHandler = 'Native';
                    target.dataset.vpmsNativeDialogTitle = 'Create Reservation';
                    target.textContent = action || 'Create Reservation';
                }
            };

            const setFocus = (element) => {
                if (!element) {
                    return;
                }

                const title = element.dataset.inspectorTitle || 'Room Calendar';
                const detail = element.dataset.inspectorDetail || 'Select a room, stay, or date to continue.';
                const action = element.dataset.inspectorAction || 'Open';
                const url = element.dataset.inspectorUrl || element.getAttribute('href') || '#';
                const roomContext = element.dataset.roomNumber
                    ? `Room ${element.dataset.roomNumber} - ${element.dataset.roomType || 'Room type pending'}`
                    : action;
                const dateContext = element.dataset.arrival
                    ? `${formatDate(element.dataset.arrival)} to ${formatDate(element.dataset.departure)}`
                    : 'Stay timeline';

                if (focusTitle && focusDetail && focusAction) {
                    focusTitle.textContent = title;
                    focusDetail.textContent = detail;
                    focusAction.textContent = action;
                    focusAction.href = url;
                    configureWorkflowTarget(focusAction, element, action, url);
                }

                if (inspectorTitle && inspectorDetail && inspectorPrimary) {
                    inspectorTitle.textContent = title;
                    inspectorDetail.textContent = detail;
                    inspectorPrimary.textContent = action;
                    inspectorPrimary.href = url;
                    configureWorkflowTarget(inspectorPrimary, element, action, url);
                }

                if (inspectorStatus) {
                    inspectorStatus.textContent = roomContext;
                }

                if (inspectorDate) {
                    inspectorDate.textContent = dateContext;
                }

                if (inspectorRoomStatus) {
                    const template = inspectorRoomStatus.dataset.statusUrlTemplate || inspectorRoomStatus.href;
                    const roomId = element.dataset.roomId;
                    inspectorRoomStatus.classList.toggle('disabled', !roomId);
                    inspectorRoomStatus.setAttribute('aria-disabled', roomId ? 'false' : 'true');
                    if (roomId && template) {
                        inspectorRoomStatus.href = template.replace(/0(?=($|\?|#))/, roomId);
                    }
                }
            };

            const formatDate = (value) => {
                if (!value) {
                    return 'Pending';
                }

                const [year, month, day] = value.split('-').map(Number);
                if (!year || !month || !day) {
                    return value;
                }

                return new Date(year, month - 1, day).toLocaleDateString(undefined, {
                    month: 'short',
                    day: 'numeric',
                    year: 'numeric'
                });
            };

            const setAlert = (element, message, visible) => {
                if (!element) {
                    return;
                }

                element.textContent = message || '';
                element.classList.toggle('d-none', !visible);
            };

            const clearModalFeedback = () => {
                setAlert(quickReservationError, '', false);
                setAlert(quickReservationSuccess, '', false);
            };

            const openQuickReservation = (trigger) => {
                if (!quickReservationForm || !modalInstance) {
                    return false;
                }

                clearModalFeedback();
                quickReservationForm.reset();

                const roomId = trigger.dataset.roomId || '';
                const arrival = trigger.dataset.arrival || '';
                const departure = trigger.dataset.departure || '';
                const rate = trigger.dataset.rate || '0';
                const roomNumber = trigger.dataset.roomNumber || 'Selected room';
                const roomType = trigger.dataset.roomType || 'Room type pending';
                const roomStatus = trigger.dataset.roomStatus || 'Status pending';

                quickReservationForm.querySelector('[name="QuickReservation.RoomId"]').value = roomId;
                quickReservationForm.querySelector('[name="QuickReservation.ArrivalDate"]').value = arrival;
                quickReservationForm.querySelector('[name="QuickReservation.DepartureDate"]').value = departure;
                quickReservationForm.querySelector('[name="QuickReservation.RateAmount"]').value = rate;
                quickReservationForm.querySelector('[name="QuickReservation.Adults"]').value = '1';
                quickReservationForm.querySelector('[name="QuickReservation.Children"]').value = '0';

                if (quickReservationRoomLabel) {
                    quickReservationRoomLabel.textContent = `Room ${roomNumber}`;
                }

                if (quickReservationRoomMeta) {
                    quickReservationRoomMeta.textContent = `${roomType} - ${roomStatus}`;
                }

                if (quickReservationStayLabel) {
                    quickReservationStayLabel.textContent = `${formatDate(arrival)} to ${formatDate(departure)}`;
                }

                if (quickReservationFullPageLink) {
                    quickReservationFullPageLink.href = trigger.dataset.inspectorUrl || trigger.getAttribute('href') || quickReservationFullPageLink.href;
                    quickReservationFullPageLink.textContent = 'Full Workflow';
                }

                if (quickReservationSubmit) {
                    quickReservationSubmit.disabled = false;
                    quickReservationSubmit.textContent = 'Create Stay';
                    delete quickReservationSubmit.dataset.created;
                }

                if (quickReservationRefresh) {
                    quickReservationRefresh.classList.add('d-none');
                }

                modalInstance.show();
                return true;
            };

            document.querySelectorAll('[data-calendar-inspector]').forEach(element => {
                element.addEventListener('mouseenter', () => setFocus(element));
                element.addEventListener('focus', () => setFocus(element));
                element.addEventListener('click', () => setFocus(element));
            });

            document.querySelectorAll('[data-quick-reservation="true"]').forEach(element => {
                element.addEventListener('click', event => {
                    if (!openQuickReservation(element)) {
                        return;
                    }

                    event.preventDefault();
                });
            });

            if (quickReservationForm) {
                quickReservationForm.addEventListener('submit', async event => {
                    event.preventDefault();
                    clearModalFeedback();

                    if (quickReservationSubmit) {
                        quickReservationSubmit.disabled = true;
                        quickReservationSubmit.textContent = 'Creating...';
                    }

                    try {
                        const response = await fetch(quickReservationForm.action, {
                            method: 'POST',
                            body: new FormData(quickReservationForm),
                            headers: {
                                'X-Requested-With': 'XMLHttpRequest'
                            }
                        });

                        const payload = await response.json();

                        if (!response.ok || !payload.success) {
                            const fieldMessages = payload.errors
                                ? Object.values(payload.errors).flat()
                                : [];
                            setAlert(
                                quickReservationError,
                                [payload.message, ...fieldMessages].filter(Boolean).join(' '),
                                true);
                            return;
                        }

                        setAlert(quickReservationSuccess, `${payload.message} Keep working here, refresh the calendar, or open the reservation.`, true);

                        if (quickReservationFullPageLink && payload.reservationUrl) {
                            quickReservationFullPageLink.href = payload.reservationUrl;
                            quickReservationFullPageLink.textContent = 'Open Reservation';
                        }

                        if (quickReservationSubmit) {
                            quickReservationSubmit.textContent = 'Created';
                            quickReservationSubmit.disabled = true;
                            quickReservationSubmit.dataset.created = 'true';
                        }

                        if (quickReservationRefresh) {
                            quickReservationRefresh.classList.remove('d-none');
                        }
                    } catch {
                        setAlert(quickReservationError, 'The reservation could not be created. Check the form and try again.', true);
                    } finally {
                        if (quickReservationSubmit && quickReservationSubmit.dataset.created !== 'true') {
                            quickReservationSubmit.disabled = false;
                            quickReservationSubmit.textContent = 'Create Stay';
                        }
                    }
                });
            }

            quickReservationRefresh?.addEventListener('click', () => window.location.reload());
        })();
    </script>
}
