@page "{id:int}"
@model Vantage.PMS.Pages.FrontOffice.Guests.DeleteModel

@{
    ViewData["Title"] = "Delete Guest";
}

<h1>Delete Guest</h1>
<p class="text-danger">Are you sure you want to delete this guest?</p>

<dl class="row mt-3">
    <dt class="col-sm-3">Name</dt>
    <dd class="col-sm-9">@Model.Guest.FirstName @Model.Guest.LastName</dd>

    <dt class="col-sm-3">Email</dt>
    <dd class="col-sm-9">@Model.Guest.Email</dd>

    <dt class="col-sm-3">Phone</dt>
    <dd class="col-sm-9">@Model.Guest.PhoneNumber</dd>
</dl>

<form method="post">
    <input type="hidden" asp-for="Guest.Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a class="btn btn-outline-secondary" asp-page="./Index">Cancel</a>
</form>
