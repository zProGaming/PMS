@page
@model Vantage.PMS.Pages.FrontOffice.Guests.IndexModel

@{
    ViewData["Title"] = "Guests";
}

<div class="page-header">
    <div>
        <div class="page-kicker">Front Office Profiles</div>
        <h1 class="page-title">Guests</h1>
        <p class="page-subtitle">Guest records, contact details, and stay profile shortcuts for front desk workflows.</p>
    </div>
    <a class="btn btn-primary"
       asp-page="./Create"
       data-vpms-native-dialog
       data-vpms-native-handler="Native"
       data-vpms-native-dialog-title="Create Guest">Create Guest</a>
</div>

<div class="vpms-table-wrapper">
    <table class="table table-striped table-hover align-middle mb-0">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Country</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Guests.Any())
            {
                <tr class="vpms-empty-row">
                    <td colspan="5">
                        <section class="vpms-empty-state vpms-empty-state-table">
                            <strong>No guest profiles found.</strong>
                            <span>Create a guest profile from this screen or directly during the reservation workflow.</span>
                        </section>
                    </td>
                </tr>
            }
            else
            {
                @foreach (var guest in Model.Guests)
                {
                    <tr>
                        <td>@guest.LastName, @guest.FirstName</td>
                        <td>@guest.Email</td>
                        <td>@guest.PhoneNumber</td>
                        <td>@guest.Country</td>
                        <td class="text-end">
                            <div class="vpms-row-actions">
                                <a class="btn btn-sm btn-outline-primary"
                                   asp-page="./Edit"
                                   asp-route-id="@guest.Id"
                                   data-vpms-dialog
                                   data-vpms-dialog-title="Guest Profile">Edit</a>
                                <a class="btn btn-sm btn-outline-secondary"
                                   asp-page="./Details"
                                   asp-route-id="@guest.Id"
                                   data-vpms-dialog
                                   data-vpms-dialog-title="Guest Profile">Details</a>
                                <a class="btn btn-sm btn-outline-danger" asp-page="./Delete" asp-route-id="@guest.Id">Delete</a>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
