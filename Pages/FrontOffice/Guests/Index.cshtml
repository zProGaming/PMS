@page
@model Vantage.PMS.Pages.FrontOffice.Guests.IndexModel

@{
    ViewData["Title"] = "Guests";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="mb-0">Guests</h1>
    <a class="btn btn-primary" asp-page="./Create">Create Guest</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Country</th>
            <th class="text-end">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var guest in Model.Guests)
        {
            <tr>
                <td>@guest.LastName, @guest.FirstName</td>
                <td>@guest.Email</td>
                <td>@guest.PhoneNumber</td>
                <td>@guest.Country</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-primary" asp-page="./Edit" asp-route-id="@guest.Id">Edit</a>
                    <a class="btn btn-sm btn-outline-secondary" asp-page="./Details" asp-route-id="@guest.Id">Details</a>
                    <a class="btn btn-sm btn-outline-danger" asp-page="./Delete" asp-route-id="@guest.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
