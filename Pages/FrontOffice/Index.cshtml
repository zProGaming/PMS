@page
@model Vantage.PMS.Pages.FrontOffice.IndexModel

@{
    ViewData["Title"] = "Front Office";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Dashboard</a></li>
        <li class="breadcrumb-item active" aria-current="page">Front Office</li>
    </ol>
</nav>

<div class="page-header">
    <div>
        <div class="page-kicker">Rooms &amp; Guests</div>
        <h1 class="page-title">Front Office</h1>
        <p class="page-subtitle">Today&apos;s rooms, reservations, arrivals, departures, and in-house guests.</p>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-primary" asp-page="/FrontOffice/Reservations/Create" data-vpms-native-dialog data-vpms-native-handler="Native" data-vpms-native-dialog-title="Create Reservation">New Reservation</a>
        <a class="btn btn-outline-primary" asp-page="/FrontOffice/Guests/Create" data-vpms-native-dialog data-vpms-native-handler="Native" data-vpms-native-dialog-title="Create Guest">New Guest</a>
    </div>
</div>

<section class="vpms-role-command">
    <div>
        <div class="page-kicker">Front Desk Command View</div>
        <h2>Arrivals, room readiness, groups, and paymaster controls in one shift view.</h2>
        <p>Built for the front desk to move quickly without losing visibility on room status, group blocks, pseudo room folios, and guest-facing actions.</p>
    </div>
    <div class="vpms-role-command-grid">
        <a asp-page="/FrontOffice/Reservations/Index"><span>01</span><strong>Work arrivals</strong><small>Search, check in, and manage reservations.</small></a>
        <a asp-page="/FrontOffice/RoomRack/Index"><span>02</span><strong>Review room calendar</strong><small>Confirm stay blocks and readiness before assignment.</small></a>
        <a asp-page="/Groups/Index"><span>03</span><strong>Review groups</strong><small>Blocks, pickup, rooming list, and master folios.</small></a>
        <a asp-page="/Documents/Index"><span>04</span><strong>Print documents</strong><small>Registration cards, confirmations, and folios.</small></a>
    </div>
</section>

<div class="row g-3 vpms-dashboard-kpi-grid">
    <div class="col-md-3">
        <div class="kpi-card">
            <div class="kpi-label">Total Rooms</div>
            <div class="kpi-value">@Model.TotalRooms</div>
            <div class="kpi-note">Active inventory</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="kpi-card">
            <div class="kpi-label">Available Rooms</div>
            <div class="kpi-value">@Model.AvailableRooms</div>
            <div class="kpi-note">Ready to sell</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="kpi-card">
            <div class="kpi-label">Occupied Rooms</div>
            <div class="kpi-value">@Model.OccupiedRooms</div>
            <div class="kpi-note">Current house count</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="kpi-card">
            <div class="kpi-label">Dirty Rooms</div>
            <div class="kpi-value">@Model.DirtyRooms</div>
            <div class="kpi-note">Needs housekeeping</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="kpi-card">
            <div class="kpi-label">Arrivals Today</div>
            <div class="kpi-value">@Model.ArrivalsToday</div>
            <div class="kpi-note">Reserved arrivals</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="kpi-card">
            <div class="kpi-label">Departures Today</div>
            <div class="kpi-value">@Model.DeparturesToday</div>
            <div class="kpi-note">Checked-in due-outs</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="kpi-card">
            <div class="kpi-label">In-house Guests</div>
            <div class="kpi-value">@Model.InHouseGuests</div>
            <div class="kpi-note">Checked in now</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="kpi-card">
            <div class="kpi-label">Tentative Groups</div>
            <div class="kpi-value">@Model.TentativeGroups</div>
            <div class="kpi-note">Awaiting confirmation</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="kpi-card">
            <div class="kpi-label">Groups Arriving</div>
            <div class="kpi-value">@Model.ConfirmedGroupsArrivingThisWeek</div>
            <div class="kpi-note">Confirmed this week</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="kpi-card">
            <div class="kpi-label">Group Rooms</div>
            <div class="kpi-value">@Model.GroupRoomsPickedUp / @Model.GroupRoomsBlocked</div>
            <div class="kpi-note">Picked up / blocked</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="kpi-card">
            <div class="kpi-label">Pseudo Folios</div>
            <div class="kpi-value">@Model.PseudoRoomOpenFolios</div>
            <div class="kpi-note">Open paymaster folios</div>
        </div>
    </div>
</div>

<div class="quick-action-grid mt-4">
    <a class="quick-action-card" asp-page="/FrontOffice/Reservations/Index"><strong>Manage Reservations</strong><small>Search, check in, check out, and folios</small></a>
    <a class="quick-action-card" asp-page="/Groups/Index"><strong>Group Bookings</strong><small>Blocks, rooming lists, and master folios</small></a>
    <a class="quick-action-card" asp-page="/FrontOffice/Guests/Index"><strong>Manage Guests</strong><small>Guest profiles and contact details</small></a>
    <a class="quick-action-card" asp-page="/FrontOffice/RoomRack/Index"><strong>Room Calendar</strong><small>Physical rooms, stays, status, and housekeeping links</small></a>
</div>
