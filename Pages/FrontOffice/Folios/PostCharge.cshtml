@page "{folioId:int}"
@model Vantage.PMS.Pages.FrontOffice.Folios.PostChargeModel

@{
    ViewData["Title"] = "Post Charge";
}

<h1>Post Charge</h1>
<p class="text-muted">Folio @Model.FolioNumber</p>

<form method="post" class="mt-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="row">
        <div class="col-md-3 mb-3">
            <label asp-for="Charge.PostingDate" class="form-label">Posting Date</label>
            <input asp-for="Charge.PostingDate" class="form-control" type="datetime-local" asp-format="{0:yyyy-MM-ddTHH:mm}" />
            <span asp-validation-for="Charge.PostingDate" class="text-danger"></span>
        </div>
        <div class="col-md-3 mb-3">
            <label asp-for="Charge.ChargeCodeId" class="form-label">Charge Code</label>
            <select asp-for="Charge.ChargeCodeId" asp-items="Model.ChargeCodeOptions" class="form-select">
                <option value="">Manual code</option>
            </select>
            <input asp-for="Charge.ChargeCode" class="form-control mt-2" placeholder="Manual charge code" />
            <span asp-validation-for="Charge.ChargeCode" class="text-danger"></span>
        </div>
        <div class="col-md-3 mb-3">
            <label asp-for="Charge.Quantity" class="form-label"></label>
            <input asp-for="Charge.Quantity" class="form-control" type="number" min="0.01" step="0.01" />
            <span asp-validation-for="Charge.Quantity" class="text-danger"></span>
        </div>
        <div class="col-md-3 mb-3">
            <label asp-for="Charge.UnitPrice" class="form-label">Unit Price</label>
            <input asp-for="Charge.UnitPrice" class="form-control" type="number" min="0" step="0.01" />
            <span asp-validation-for="Charge.UnitPrice" class="text-danger"></span>
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="Charge.Description" class="form-label"></label>
        <input asp-for="Charge.Description" class="form-control" />
        <span asp-validation-for="Charge.Description" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Charge.PostedBy" class="form-label">Posted By</label>
        <input asp-for="Charge.PostedBy" class="form-control" />
        <span asp-validation-for="Charge.PostedBy" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Post Charge</button>
    <a class="btn btn-outline-secondary" asp-page="./Details" asp-route-id="@Model.FolioId">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
