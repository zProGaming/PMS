@page
@using Vantage.PMS.Models.FrontOffice
@model Vantage.PMS.Pages.FrontOffice.Reservations.IndexModel

@{
    ViewData["Title"] = "Reservations";
}

@functions {
    private static string StatusClass(ReservationStatus status) => status.ToString().ToLowerInvariant();

    private static int StayNights(Reservation reservation)
    {
        return Math.Max(1, (reservation.DepartureDate.Date - reservation.ArrivalDate.Date).Days);
    }
}

<section class="vpms-ops-hero vpms-ops-hero-compact">
    <div>
        <div class="page-kicker">Front Desk Control</div>
        <h1 class="page-title">Reservations</h1>
        <p class="page-subtitle">Arrival, stay, and rooming control for front desk teams.</p>
    </div>
    <div class="vpms-hero-actions">
        <a class="btn vpms-btn-secondary" asp-page="/FrontOffice/RoomRack/Index">Room Rack</a>
        <a class="btn vpms-btn-primary" asp-page="./Create">Create Reservation</a>
    </div>
</section>

<section class="vpms-signal-strip" aria-label="Reservation operating signals">
    <article>
        <span>Arrivals Today</span>
        <strong>@Model.ArrivalsToday</strong>
        <small>Reserved arrivals</small>
    </article>
    <article>
        <span>Departures Today</span>
        <strong>@Model.DeparturesToday</strong>
        <small>Expected check-outs</small>
    </article>
    <article>
        <span>In-House</span>
        <strong>@Model.InHouseReservations</strong>
        <small>Checked-in stays</small>
    </article>
    <article class="@(Model.UnassignedReservations > 0 ? "needs-attention" : "")">
        <span>Unassigned</span>
        <strong>@Model.UnassignedReservations</strong>
        <small>Need rooming</small>
    </article>
</section>

<form method="get" class="vpms-filter-bar">
    <div>
        <label class="form-label" for="reservationSearch">Search</label>
        <input id="reservationSearch" class="form-control" asp-for="Search" placeholder="Guest, confirmation, or room" />
    </div>
    <div>
        <label class="form-label" asp-for="Status">Status</label>
        <select class="form-select" asp-for="Status" asp-items="Model.StatusOptions">
            <option value="">All statuses</option>
        </select>
    </div>
    <div>
        <label class="form-label" asp-for="StayDate">Stay Date</label>
        <input class="form-control" type="date" asp-for="StayDate" asp-format="{0:yyyy-MM-dd}" />
    </div>
    <div class="vpms-filter-actions">
        <button class="btn vpms-btn-primary" type="submit">Apply</button>
        <a class="btn vpms-btn-secondary" asp-page="./Index">Reset</a>
    </div>
</form>

@if (Model.Reservations.Count == 0)
{
    <div class="vpms-empty-state">
        <strong>No reservations found.</strong>
        <span>Adjust the filters or create a new reservation to begin the front desk workflow.</span>
    </div>
}
else
{
    <div class="vpms-table-wrapper vpms-reservation-board">
        <table class="table vpms-table align-middle">
            <thead>
                <tr>
                    <th>Guest / Confirmation</th>
                    <th>Stay Pattern</th>
                    <th>Rooming</th>
                    <th class="text-end">Rate</th>
                    <th>Guests</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var reservation in Model.Reservations)
                {
                    var statusClass = StatusClass(reservation.Status);
                    var nights = StayNights(reservation);
                    <tr>
                        <td>
                            <div class="vpms-primary-cell">@reservation.Guest?.LastName, @reservation.Guest?.FirstName</div>
                            <div class="vpms-muted-line">@reservation.ConfirmationNumber</div>
                        </td>
                        <td>
                            <div class="vpms-stay-line">
                                <span>@reservation.ArrivalDate.ToString("MMM d")</span>
                                <span class="vpms-stay-arrow">to</span>
                                <span>@reservation.DepartureDate.ToString("MMM d, yyyy")</span>
                            </div>
                            <div class="vpms-muted-line">@nights night@(nights == 1 ? "" : "s")</div>
                        </td>
                        <td>
                            <div class="vpms-primary-cell">@(reservation.Room?.RoomNumber ?? "Unassigned")</div>
                            <div class="vpms-muted-line">@(reservation.RoomType?.Name ?? "Room type pending")</div>
                        </td>
                        <td class="text-end">
                            <div class="vpms-money">@reservation.RateAmount.ToString("C")</div>
                            <div class="vpms-muted-line">per night</div>
                        </td>
                        <td>
                            <span class="vpms-mini-chip">@reservation.Adults adult@(reservation.Adults == 1 ? "" : "s")</span>
                            @if (reservation.Children > 0)
                            {
                                <span class="vpms-mini-chip">@reservation.Children child@(reservation.Children == 1 ? "" : "ren")</span>
                            }
                        </td>
                        <td><span class="vpms-status-badge status-@statusClass">@reservation.Status</span></td>
                        <td class="text-end">
                            <div class="vpms-row-actions">
                                <a class="btn btn-sm vpms-btn-secondary" asp-page="./Details" asp-route-id="@reservation.Id">Open</a>
                                <a class="btn btn-sm btn-outline-secondary" asp-page="./Edit" asp-route-id="@reservation.Id">Edit</a>
                                <a class="btn btn-sm btn-outline-danger" asp-page="./Delete" asp-route-id="@reservation.Id">Cancel</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
