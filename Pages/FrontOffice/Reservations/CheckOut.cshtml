@page "{id:int}"
@model Vantage.PMS.Pages.FrontOffice.Reservations.CheckOutModel

@{
    ViewData["Title"] = "Check Out Reservation";
    var isNativeWorkflow = string.Equals(HttpContext.Request.Query["vpmsNative"], "1", StringComparison.OrdinalIgnoreCase);
}

@if (isNativeWorkflow)
{
    <section class="vpms-native-modal-intro">
        <div>
            <div class="page-kicker">Departure Control</div>
            <h1>Check Out</h1>
            <p>@Model.Reservation.Guest?.FirstName @Model.Reservation.Guest?.LastName | Room @(Model.Reservation.Room?.RoomNumber ?? "Unassigned")</p>
        </div>
        <div class="vpms-native-balance-pill @(Model.HasOutstandingBalance ? "warning" : "positive")">
            <span>Folio Balance</span>
            <strong>@Model.FolioBalance.ToString("C")</strong>
        </div>
    </section>
}
else
{
    <h1>Check Out Reservation</h1>
}

<div asp-validation-summary="ModelOnly" class="text-danger"></div>

<dl class="row mt-3 @(isNativeWorkflow ? "vpms-native-definition-strip" : "")">
    <dt class="col-sm-3">Confirmation</dt>
    <dd class="col-sm-9">@Model.Reservation.ConfirmationNumber</dd>

    <dt class="col-sm-3">Guest</dt>
    <dd class="col-sm-9">@Model.Reservation.Guest?.FirstName @Model.Reservation.Guest?.LastName</dd>

    <dt class="col-sm-3">Room</dt>
    <dd class="col-sm-9">@Model.Reservation.Room?.RoomNumber</dd>

    <dt class="col-sm-3">Departure</dt>
    <dd class="col-sm-9">@Model.Reservation.DepartureDate.ToString("d")</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Reservation.Status</dd>

    <dt class="col-sm-3">Folio Balance</dt>
    <dd class="col-sm-9">@Model.FolioBalance.ToString("C")</dd>
</dl>

@if (Model.HasOutstandingBalance)
{
    <div class="alert alert-warning">
        Guest has outstanding balance. Please settle the folio before check-out, or use an authorized manager override to check out while keeping the folio open for collection follow-up.
    </div>
}

<form method="post" class="@(isNativeWorkflow ? "vpms-native-workflow-form" : "")">
    <input type="hidden" asp-for="Reservation.Id" />
    @if (Model.HasOutstandingBalance)
    {
        <div class="form-check mb-3">
            <input asp-for="ManagerOverrideRequested" class="form-check-input" disabled="@(!Model.CanUseManagerOverride)" />
            <label asp-for="ManagerOverrideRequested" class="form-check-label">Authorize checkout with outstanding balance</label>
            @if (!Model.CanUseManagerOverride)
            {
                <div class="form-text text-muted">Manager override is restricted to SystemAdmin, GeneralManager, FrontOfficeManager, and FinanceManager.</div>
            }
            else
            {
                <div class="form-text text-muted">The reservation will check out, the room will become Dirty, and any unpaid folio remains open for finance collection.</div>
            }
        </div>
    }
    <div class="vpms-native-action-row">
        <a class="btn btn-outline-secondary" asp-page="./Details" asp-route-id="@Model.Reservation.Id">Cancel</a>
        @if (Model.FolioId is not null)
        {
            <a class="btn btn-outline-primary" asp-page="/FrontOffice/Folios/PostPayment" asp-route-folioId="@Model.FolioId">Post Payment</a>
        }
        <button type="submit" class="btn btn-warning" disabled="@(!Model.CanSubmitCheckOut)">Confirm Check Out</button>
    </div>
</form>
