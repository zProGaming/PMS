@page "{id:int}"
@model Vantage.PMS.Pages.FrontOffice.Reservations.DetailsModel

@{
    ViewData["Title"] = "Reservation Details";
}

<h1>Reservation Details</h1>

<dl class="row mt-3">
    <dt class="col-sm-3">Confirmation</dt>
    <dd class="col-sm-9">@Model.Reservation.ConfirmationNumber</dd>

    <dt class="col-sm-3">Guest</dt>
    <dd class="col-sm-9">@Model.Reservation.Guest?.FirstName @Model.Reservation.Guest?.LastName</dd>

    <dt class="col-sm-3">Property</dt>
    <dd class="col-sm-9">@Model.Reservation.Property?.Name</dd>

    <dt class="col-sm-3">Room</dt>
    <dd class="col-sm-9">@Model.Reservation.Room?.RoomNumber</dd>

    <dt class="col-sm-3">Room Type</dt>
    <dd class="col-sm-9">@Model.Reservation.RoomType?.Name</dd>

    <dt class="col-sm-3">Check-in</dt>
    <dd class="col-sm-9">@Model.Reservation.ArrivalDate.ToString("d")</dd>

    <dt class="col-sm-3">Check-out</dt>
    <dd class="col-sm-9">@Model.Reservation.DepartureDate.ToString("d")</dd>

    <dt class="col-sm-3">Rate Amount</dt>
    <dd class="col-sm-9">@Model.Reservation.RateAmount.ToString("N2")</dd>

    <dt class="col-sm-3">Guests</dt>
    <dd class="col-sm-9">@Model.Reservation.Adults adult(s), @Model.Reservation.Children child(ren)</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Reservation.Status</dd>
</dl>

<a class="btn btn-primary" asp-page="./Edit" asp-route-id="@Model.Reservation.Id">Edit</a>
<a class="btn btn-outline-secondary" asp-page="./Index">Back</a>
