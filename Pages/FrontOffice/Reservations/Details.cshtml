@page "{id:int}"
@using Vantage.PMS.Models.FrontOffice
@model Vantage.PMS.Pages.FrontOffice.Reservations.DetailsModel

@{
    ViewData["Title"] = "Reservation Details";
    var statusClass = Model.Reservation.Status.ToString().ToLowerInvariant();
    var nights = Math.Max(1, (Model.Reservation.DepartureDate.Date - Model.Reservation.ArrivalDate.Date).Days);
    var hasFolio = Model.FolioId is not null;
}

<section class="vpms-ops-hero vpms-reservation-control">
    <div>
        <div class="page-kicker">Reservation Control</div>
        <h1 class="page-title">@Model.Reservation.ConfirmationNumber</h1>
        <p class="page-subtitle">
            @Model.Reservation.Guest?.FirstName @Model.Reservation.Guest?.LastName |
            @Model.Reservation.ArrivalDate.ToString("MMM d") to @Model.Reservation.DepartureDate.ToString("MMM d, yyyy")
        </p>
        <div class="vpms-hero-chip-row">
            <span class="vpms-status-badge status-@statusClass">@Model.Reservation.Status</span>
            <span class="vpms-mini-chip">@(Model.Reservation.Room?.RoomNumber ?? "Unassigned room")</span>
            <span class="vpms-mini-chip">@(hasFolio ? "Folio linked" : "Folio pending")</span>
        </div>
    </div>
    <div class="vpms-hero-actions">
        @if (Model.Reservation.Status == ReservationStatus.Reserved)
        {
            <a class="btn vpms-btn-primary" asp-page="./CheckIn" asp-route-id="@Model.Reservation.Id">Check In</a>
        }
        @if (Model.Reservation.Status == ReservationStatus.CheckedIn)
        {
            <a class="btn btn-warning" asp-page="./CheckOut" asp-route-id="@Model.Reservation.Id">Check Out</a>
        }
        <a class="btn vpms-btn-secondary" asp-page="./Edit" asp-route-id="@Model.Reservation.Id">Edit</a>
        <a class="btn btn-outline-secondary" asp-page="./Index">Back</a>
    </div>
</section>

<section class="vpms-control-strip">
    <article>
        <span>Rooming</span>
        <strong>@(Model.Reservation.Room?.RoomNumber ?? "Unassigned")</strong>
        <small>@(Model.Reservation.RoomType?.Name ?? "Room type pending")</small>
    </article>
    <article>
        <span>Stay Length</span>
        <strong>@nights</strong>
        <small>night@(nights == 1 ? "" : "s")</small>
    </article>
    <article>
        <span>Rate</span>
        <strong>@Model.Reservation.RateAmount.ToString("C")</strong>
        <small>per night</small>
    </article>
    <article class="@(hasFolio ? "" : "needs-attention")">
        <span>Folio</span>
        <strong>@(hasFolio ? "Ready" : "Pending")</strong>
        <small>@(hasFolio ? "Posting enabled" : "Create on check-in")</small>
    </article>
</section>

<div class="vpms-two-column">
    <section class="vpms-card vpms-operational-panel">
        <div class="vpms-section-titlebar">
            <div>
                <h2>Stay Profile</h2>
                <p>Core reservation and arrival details.</p>
            </div>
        </div>
        <dl class="vpms-definition-list">
            <dt>Guest</dt>
            <dd>@Model.Reservation.Guest?.FirstName @Model.Reservation.Guest?.LastName</dd>
            <dt>Property</dt>
            <dd>@(Model.Reservation.Property?.Name ?? "Not assigned")</dd>
            <dt>Arrival</dt>
            <dd>@Model.Reservation.ArrivalDate.ToString("D")</dd>
            <dt>Departure</dt>
            <dd>@Model.Reservation.DepartureDate.ToString("D")</dd>
            <dt>Occupancy</dt>
            <dd>@Model.Reservation.Adults adult@(Model.Reservation.Adults == 1 ? "" : "s"), @Model.Reservation.Children child@(Model.Reservation.Children == 1 ? "" : "ren")</dd>
        </dl>
    </section>

    <section class="vpms-card vpms-operational-panel">
        <div class="vpms-section-titlebar">
            <div>
                <h2>Operational Status</h2>
                <p>Rooming, actual movement, and next action readiness.</p>
            </div>
        </div>
        <div class="vpms-status-timeline">
            <div class="@(Model.Reservation.Status == ReservationStatus.Reserved ? "active" : "complete")">
                <span>Reserved</span>
                <strong>@Model.Reservation.ArrivalDate.ToString("MMM d")</strong>
            </div>
            <div class="@(Model.Reservation.ActualCheckInDate is not null ? "complete" : "")">
                <span>Checked In</span>
                <strong>@(Model.Reservation.ActualCheckInDate?.ToString("MMM d, h:mm tt") ?? "Pending")</strong>
            </div>
            <div class="@(Model.Reservation.ActualCheckOutDate is not null ? "complete" : "")">
                <span>Checked Out</span>
                <strong>@(Model.Reservation.ActualCheckOutDate?.ToString("MMM d, h:mm tt") ?? "Pending")</strong>
            </div>
        </div>
    </section>
</div>

<section class="vpms-card vpms-operational-panel">
    <div class="vpms-section-titlebar">
        <div>
            <h2>Guest Folio Control</h2>
            <p>Charge posting and payment actions tied to this stay.</p>
        </div>
        @if (hasFolio)
        {
            <a class="btn vpms-btn-secondary" asp-page="/FrontOffice/Folios/Details" asp-route-id="@Model.FolioId">Open Folio</a>
        }
    </div>

    @if (hasFolio)
    {
        <div class="vpms-action-grid">
            <a asp-page="/FrontOffice/Folios/Details" asp-route-id="@Model.FolioId">View folio ledger</a>
            <a asp-page="/FrontOffice/Folios/PostCharge" asp-route-folioId="@Model.FolioId">Post charge</a>
            <a asp-page="/FrontOffice/Folios/PostPayment" asp-route-folioId="@Model.FolioId">Post payment</a>
        </div>
    }
    else
    {
        <div class="vpms-empty-state">
            <strong>No folio is linked yet.</strong>
            <span>The folio will be created or attached during check-in based on the current workflow.</span>
        </div>
    }
</section>
