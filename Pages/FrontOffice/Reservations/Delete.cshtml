@page "{id:int}"
@model Vantage.PMS.Pages.FrontOffice.Reservations.DeleteModel

@{
    ViewData["Title"] = "Cancel Reservation";
}

<h1>Cancel Reservation</h1>
<p class="text-danger">This will cancel the reservation without deleting audit history.</p>

<dl class="row mt-3">
    <dt class="col-sm-3">Confirmation</dt>
    <dd class="col-sm-9">@Model.Reservation.ConfirmationNumber</dd>

    <dt class="col-sm-3">Guest</dt>
    <dd class="col-sm-9">@Model.Reservation.Guest?.FirstName @Model.Reservation.Guest?.LastName</dd>

    <dt class="col-sm-3">Room</dt>
    <dd class="col-sm-9">@Model.Reservation.Room?.RoomNumber</dd>

    <dt class="col-sm-3">Dates</dt>
    <dd class="col-sm-9">@Model.Reservation.ArrivalDate.ToString("d") - @Model.Reservation.DepartureDate.ToString("d")</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Reservation.Status</dd>
</dl>

<form method="post">
    <input type="hidden" asp-for="Reservation.Id" />
    <button type="submit" class="btn btn-danger">Cancel Reservation</button>
    <a class="btn btn-outline-secondary" asp-page="./Index">Back</a>
</form>
