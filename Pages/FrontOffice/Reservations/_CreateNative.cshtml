@model Vantage.PMS.Pages.FrontOffice.Reservations.CreateModel

<section class="vpms-native-modal-intro">
    <div>
        <div class="page-kicker">Reservation Desk</div>
        <h1>Create Reservation</h1>
        <p>Guest, stay dates, room, and rate.</p>
    </div>
    <a class="btn vpms-btn-secondary" asp-page="/FrontOffice/Guests/Create" data-vpms-native-dialog data-vpms-native-handler="Native" data-vpms-native-dialog-title="Create Guest">New Guest</a>
</section>

<form method="post" asp-page="./Create" class="vpms-native-workflow-form vpms-native-reservation-form">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger vpms-alert"></div>

    <div class="vpms-native-step-grid" aria-label="Reservation workflow checks">
        <span><strong>Guest</strong><small>Profile selected</small></span>
        <span><strong>Room</strong><small>Available inventory only</small></span>
        <span><strong>Rate</strong><small>Controls checked</small></span>
    </div>

    <section class="vpms-form-section vpms-native-form-section">
        <div class="vpms-form-section-heading">
            <span>01</span>
            <div>
                <h2>Guest and Rooming</h2>
                <p>Select the guest profile and assign a room that is operationally available.</p>
            </div>
        </div>
        <div class="row g-3">
            <div class="col-lg-6">
                <label asp-for="Reservation.GuestId" class="form-label">Guest</label>
                <select asp-for="Reservation.GuestId" class="form-select" asp-items="Model.GuestOptions">
                    <option value="">Select guest</option>
                </select>
                <span asp-validation-for="Reservation.GuestId" class="text-danger"></span>
            </div>
            <div class="col-lg-6">
                <label asp-for="Reservation.RoomId" class="form-label">Room</label>
                <select asp-for="Reservation.RoomId" class="form-select" asp-items="Model.RoomOptions">
                    <option value="">Select room</option>
                </select>
                <span asp-validation-for="Reservation.RoomId" class="text-danger"></span>
                <div class="form-text">Assignable rooms only.</div>
            </div>
        </div>
    </section>

    <section class="vpms-form-section vpms-native-form-section">
        <div class="vpms-form-section-heading">
            <span>02</span>
            <div>
                <h2>Stay Details</h2>
                <p>Confirm arrival, departure, reservation status, and occupancy.</p>
            </div>
        </div>
        <div class="row g-3">
            <div class="col-md-3">
                <label asp-for="Reservation.ArrivalDate" class="form-label">Check-in Date</label>
                <input asp-for="Reservation.ArrivalDate" class="form-control" type="date" asp-format="{0:yyyy-MM-dd}" />
                <span asp-validation-for="Reservation.ArrivalDate" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="Reservation.DepartureDate" class="form-label">Check-out Date</label>
                <input asp-for="Reservation.DepartureDate" class="form-control" type="date" asp-format="{0:yyyy-MM-dd}" />
                <span asp-validation-for="Reservation.DepartureDate" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="Reservation.Status" class="form-label"></label>
                <select asp-for="Reservation.Status" class="form-select" asp-items="Model.ReservationStatusOptions"></select>
                <span asp-validation-for="Reservation.Status" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="Reservation.RatePlanId" class="form-label">Rate Plan</label>
                <select asp-for="Reservation.RatePlanId" class="form-select" asp-items="Model.RatePlanOptions">
                    <option value="">Use room type base rate</option>
                </select>
                <span asp-validation-for="Reservation.RatePlanId" class="text-danger"></span>
            </div>
        </div>
    </section>

    <section class="vpms-form-section vpms-native-form-section">
        <div class="vpms-form-section-heading">
            <span>03</span>
            <div>
                <h2>Rate and Occupancy</h2>
                <p>Review the suggested rate and guest count before confirming the booking.</p>
            </div>
        </div>
        <div class="row g-3 align-items-start">
            <div class="col-lg-4">
                <label asp-for="Reservation.RateAmount" class="form-label">Rate Amount</label>
                <input asp-for="Reservation.RateAmount" class="form-control" type="number" min="0" step="0.01" />
                <span asp-validation-for="Reservation.RateAmount" class="text-danger"></span>
            </div>
            <div class="col-md-4 col-lg-2">
                <label asp-for="Reservation.Adults" class="form-label"></label>
                <input asp-for="Reservation.Adults" class="form-control" type="number" min="0" />
                <span asp-validation-for="Reservation.Adults" class="text-danger"></span>
            </div>
            <div class="col-md-4 col-lg-2">
                <label asp-for="Reservation.Children" class="form-label"></label>
                <input asp-for="Reservation.Children" class="form-control" type="number" min="0" />
                <span asp-validation-for="Reservation.Children" class="text-danger"></span>
            </div>
            <div class="col-lg-4">
                <div class="vpms-guidance-panel">
                    <span>Rate Guidance</span>
                    <strong>@(Model.SuggestedRate?.ToString("C") ?? "Pending")</strong>
                    <small>Enter 0 to apply the suggested rate after room and rate controls are evaluated.</small>
                </div>
            </div>
        </div>
    </section>

    <div class="vpms-native-action-row">
        <a class="btn vpms-btn-secondary" asp-page="./Index" data-vpms-dialog-close>Cancel</a>
        <button type="submit" class="btn vpms-btn-primary">Create Reservation</button>
    </div>
</form>
