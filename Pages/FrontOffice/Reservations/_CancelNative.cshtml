@model Vantage.PMS.Pages.FrontOffice.Reservations.DeleteModel

<section class="vpms-native-modal-intro">
    <div>
        <span class="page-kicker">Reservation Control</span>
        <h1>Cancel Reservation</h1>
        <p>Cancel this reservation without deleting the operational record or audit trail.</p>
    </div>
    <div class="vpms-native-balance-pill warning">
        <span>Status</span>
        <strong>@Model.Reservation.Status</strong>
    </div>
</section>

<dl class="row mt-3 vpms-native-definition-strip">
    <dt class="col-sm-4">Confirmation</dt>
    <dd class="col-sm-8">@Model.Reservation.ConfirmationNumber</dd>
    <dt class="col-sm-4">Guest</dt>
    <dd class="col-sm-8">@Model.Reservation.Guest?.FirstName @Model.Reservation.Guest?.LastName</dd>
    <dt class="col-sm-4">Room</dt>
    <dd class="col-sm-8">@(Model.Reservation.Room?.RoomNumber ?? "Unassigned")</dd>
    <dt class="col-sm-4">Dates</dt>
    <dd class="col-sm-8">@Model.Reservation.ArrivalDate.ToString("d") - @Model.Reservation.DepartureDate.ToString("d")</dd>
</dl>

<form method="post" asp-page="./Delete" asp-route-id="@Model.Reservation.Id" class="vpms-native-workflow-form">
    <input type="hidden" asp-for="Reservation.Id" />
    <div class="vpms-native-action-row">
        <a class="btn btn-outline-secondary" href="#" data-vpms-dialog-close>Keep Reservation</a>
        <button type="submit" class="btn btn-danger">Cancel Reservation</button>
    </div>
</form>
