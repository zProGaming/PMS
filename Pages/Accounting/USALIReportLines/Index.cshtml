@page
@model Vantage.PMS.Pages.Accounting.USALIReportLines.IndexModel
@using Vantage.PMS.Models.Accounting
@{
    ViewData["Title"] = "USALI Report Lines";
}

<div class="page-header">
    <div>
        <div class="page-kicker">Accounting Setup</div>
        <h1 class="page-title">USALI Report Lines</h1>
        <p class="page-subtitle">Configurable management statement lines and subtotals.</p>
    </div>
</div>

<form method="post" class="vpms-form-card mb-4">
    <div class="row g-3">
        <div class="col-md-2"><label asp-for="Input.Code" class="form-label">Code</label><input asp-for="Input.Code" class="form-control" required /></div>
        <div class="col-md-4"><label asp-for="Input.Name" class="form-label">Name</label><input asp-for="Input.Name" class="form-control" required /></div>
        <div class="col-md-3"><label asp-for="Input.ReportSection" class="form-label">Section</label><select asp-for="Input.ReportSection" asp-items="Html.GetEnumSelectList<USALIReportSection>()" class="form-select"></select></div>
        <div class="col-md-1"><label asp-for="Input.SortOrder" class="form-label">Sort</label><input asp-for="Input.SortOrder" class="form-control" type="number" /></div>
        <div class="col-md-2 d-flex align-items-end"><div class="form-check"><input asp-for="Input.IsSubtotal" class="form-check-input" /><label asp-for="Input.IsSubtotal" class="form-check-label">Subtotal</label></div></div>
        <div class="col-12"><button class="btn vpms-btn-primary" type="submit">Add Report Line</button></div>
    </div>
</form>

<div class="vpms-table-wrapper">
    <table class="table vpms-table">
        <thead><tr><th>Code</th><th>Name</th><th>Section</th><th>Sort</th><th>Subtotal</th></tr></thead>
        <tbody>
        @foreach (var line in Model.Lines)
        {
            <tr><td class="fw-semibold">@line.Code</td><td>@line.Name</td><td>@line.ReportSection</td><td>@line.SortOrder</td><td>@(line.IsSubtotal ? "Yes" : "No")</td></tr>
        }
        </tbody>
    </table>
</div>
