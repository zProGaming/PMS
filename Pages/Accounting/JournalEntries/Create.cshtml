@page
@model Vantage.PMS.Pages.Accounting.JournalEntries.CreateModel
@{
    ViewData["Title"] = "Manual Journal";
}
<div class="page-header">
    <div><div class="page-kicker">Accounting</div><h1 class="page-title">Manual Journal Entry</h1><p class="page-subtitle">Draft manual journal entries must balance before posting.</p></div>
</div>
<form method="post" class="vpms-form-card">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="row g-3 mb-4">
        <div class="col-md-3"><label asp-for="JournalDate" class="form-label">Journal Date</label><input asp-for="JournalDate" class="form-control" type="date" required /></div>
        <div class="col-md-9"><label asp-for="Description" class="form-label">Description</label><input asp-for="Description" class="form-control" required /></div>
    </div>
    <div class="vpms-table-wrapper">
        <table class="table vpms-table">
            <thead><tr><th>GL Account</th><th>USALI Dept</th><th>Description</th><th>Debit</th><th>Credit</th></tr></thead>
            <tbody>
            @for (var i = 0; i < Model.Lines.Count; i++)
            {
                <tr>
                    <td><select asp-for="Lines[i].GLAccountId" asp-items="Model.AccountOptions" class="form-select"><option value="">Select account</option></select></td>
                    <td><select asp-for="Lines[i].USALIDepartmentId" asp-items="Model.DepartmentOptions" class="form-select"><option value="">None</option></select></td>
                    <td><input asp-for="Lines[i].Description" class="form-control" /></td>
                    <td><input asp-for="Lines[i].DebitAmount" class="form-control text-end" type="number" step="0.01" /></td>
                    <td><input asp-for="Lines[i].CreditAmount" class="form-control text-end" type="number" step="0.01" /></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
    <div class="vpms-actions mt-3">
        <button type="submit" class="btn vpms-btn-primary">Save Draft</button>
        <a asp-page="Index" class="btn vpms-btn-secondary">Cancel</a>
    </div>
</form>
