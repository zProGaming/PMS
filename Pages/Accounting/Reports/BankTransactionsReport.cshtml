@page
@model Vantage.PMS.Pages.Accounting.Reports.BankTransactionsReportModel
@{
    ViewData["Title"] = "Bank Transactions Report";
}
<div class="page-header"><div><div class="page-kicker">Banking Report</div><h1 class="page-title">Bank Transactions Report</h1><p class="page-subtitle">Bank account debit and credit activity.</p></div><div class="page-actions no-print"><button class="btn vpms-btn-secondary" onclick="window.print()">Print</button></div></div>
<div class="vpms-table-wrapper"><table class="table vpms-table align-middle"><thead><tr><th>Date</th><th>Bank</th><th>Description</th><th>Reference</th><th>Source</th><th class="text-end">Debit</th><th class="text-end">Credit</th><th>Reconciled</th></tr></thead><tbody>
@foreach (var item in Model.Transactions)
{
    <tr><td>@item.TransactionDate.ToString("yyyy-MM-dd")</td><td>@item.BankAccount?.AccountName</td><td>@item.Description</td><td>@item.ReferenceNumber</td><td>@item.SourceModule</td><td class="text-end">@item.DebitAmount.ToString("C")</td><td class="text-end">@item.CreditAmount.ToString("C")</td><td>@(item.IsReconciled ? "Yes" : "No")</td></tr>
}
</tbody></table></div>
