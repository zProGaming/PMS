@page
@model Vantage.PMS.Pages.Accounting.Reports.SupplierLedgerModel
@{
    ViewData["Title"] = "Supplier Ledger";
}
<div class="page-header"><div><div class="page-kicker">Accounts Payable Report</div><h1 class="page-title">Supplier Ledger</h1><p class="page-subtitle">Supplier invoice and payment activity.</p></div><div class="page-actions no-print"><button class="btn vpms-btn-secondary" onclick="window.print()">Print</button></div></div>
<div class="vpms-table-wrapper"><table class="table vpms-table align-middle"><thead><tr><th>Supplier</th><th>Date</th><th>Reference</th><th>Type</th><th class="text-end">Debit</th><th class="text-end">Credit</th><th class="text-end">Balance Effect</th></tr></thead><tbody>
@foreach (var row in Model.Rows)
{
    <tr><td>@row.Supplier</td><td>@row.Date.ToString("yyyy-MM-dd")</td><td>@row.Reference</td><td>@row.Type</td><td class="text-end">@row.Debit.ToString("C")</td><td class="text-end">@row.Credit.ToString("C")</td><td class="text-end">@row.BalanceEffect.ToString("C")</td></tr>
}
</tbody></table></div>
