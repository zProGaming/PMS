@page
@using Microsoft.EntityFrameworkCore
@using Vantage.PMS.Models.Finance
@inject Vantage.PMS.Data.ApplicationDbContext Db
@{
    ViewData["Title"] = "Sales Journal";
    var start = DateTime.TryParse(Request.Query["StartDate"], out var s) ? s : new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    var end = DateTime.TryParse(Request.Query["EndDate"], out var e) ? e : DateTime.Today;
    var rows = await Db.FinanceDocuments.AsNoTracking().Where(document => document.DocumentDate >= start && document.DocumentDate <= end && document.Status != FinanceDocumentStatus.Voided && document.Status != FinanceDocumentStatus.Cancelled).OrderBy(document => document.DocumentDate).ToListAsync();
}
<div class="page-header"><div><div class="page-kicker">Philippine Reports</div><h1 class="page-title">Sales Journal</h1><p class="page-subtitle">Sales document readiness report.</p></div><button class="btn vpms-btn-secondary" onclick="window.print()">Print</button></div>
<div class="alert alert-warning">Philippine finance report formats are configurable and must be validated by a Philippine CPA/accountant before filing or official submission.</div>
<form method="get" class="vpms-card mb-3 report-filter"><div class="row g-3 align-items-end"><div class="col-md-4"><label class="form-label">From</label><input name="StartDate" value="@start.ToString("yyyy-MM-dd")" type="date" class="form-control" /></div><div class="col-md-4"><label class="form-label">To</label><input name="EndDate" value="@end.ToString("yyyy-MM-dd")" type="date" class="form-control" /></div><div class="col-md-4"><button class="btn vpms-btn-primary w-100">Run</button></div></div></form>
<div class="vpms-table-wrapper"><table class="table vpms-table"><thead><tr><th>Date</th><th>Document</th><th>Customer</th><th>Revenue Account</th><th class="text-end">Gross Sales</th><th class="text-end">VAT</th><th class="text-end">Service Charge</th><th class="text-end">Discounts</th><th class="text-end">Net Amount</th></tr></thead><tbody>@foreach (var row in rows){<tr><td>@row.DocumentDate.ToString("yyyy-MM-dd")</td><td>@row.DocumentNumber</td><td>@row.BillingName</td><td>Configured by posting rules</td><td class="text-end">@row.SubTotal.ToString("C")</td><td class="text-end">@row.TaxAmount.ToString("C")</td><td class="text-end">@row.ServiceCharge.ToString("C")</td><td class="text-end">@row.DiscountAmount.ToString("C")</td><td class="text-end">@row.TotalAmount.ToString("C")</td></tr>}</tbody></table></div>
