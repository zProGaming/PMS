@page
@model Vantage.PMS.Pages.Accounting.Reports.AccrualRegisterModel
@{
    ViewData["Title"] = "Accrual Register";
}
<div class="page-header"><div><div class="page-kicker">Month-End Report</div><h1 class="page-title">Accrual Register</h1><p class="page-subtitle">Month-end accruals and reversal status.</p></div><div class="page-actions no-print"><button class="btn vpms-btn-secondary" onclick="window.print()">Print</button></div></div>
<div class="vpms-table-wrapper"><table class="table vpms-table align-middle"><thead><tr><th>Date</th><th>Accrual</th><th>Period</th><th>Description</th><th>Debit</th><th>Credit</th><th>Status</th><th class="text-end">Amount</th></tr></thead><tbody>
@foreach (var item in Model.Accruals)
{
    <tr><td>@item.AccrualDate.ToString("yyyy-MM-dd")</td><td>@item.AccrualNumber</td><td>@item.AccountingPeriod?.PeriodName</td><td>@item.Description</td><td>@item.DebitGLAccount?.AccountCode</td><td>@item.CreditGLAccount?.AccountCode</td><td><span class="status-badge">@item.Status</span></td><td class="text-end">@item.Amount.ToString("C")</td></tr>
}
</tbody></table></div>
