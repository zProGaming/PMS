@page
@using Microsoft.EntityFrameworkCore
@using Vantage.PMS.Models.Finance
@inject Vantage.PMS.Data.ApplicationDbContext Db
@{
    ViewData["Title"] = "VAT Output Summary";
    var start = DateTime.TryParse(Request.Query["StartDate"], out var s) ? s : new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    var end = DateTime.TryParse(Request.Query["EndDate"], out var e) ? e : DateTime.Today;
    var rows = await Db.FinanceDocuments.AsNoTracking()
        .Where(document => document.DocumentDate >= start && document.DocumentDate <= end && document.Status != FinanceDocumentStatus.Voided && document.Status != FinanceDocumentStatus.Cancelled)
        .OrderBy(document => document.DocumentDate)
        .ToListAsync();
}
<div class="page-header"><div><div class="page-kicker">Philippine Reports</div><h1 class="page-title">VAT Output Summary</h1><p class="page-subtitle">Internal tax-support output VAT summary from finance documents.</p></div><button class="btn vpms-btn-secondary" onclick="window.print()">Print</button></div>
<div class="alert alert-warning">Internal tax-support report only. This is not a certified filing output or real BIR submission tool. Validate VAT treatment with a Philippine CPA/accountant before official use.</div>
<form method="get" class="vpms-card mb-3 report-filter"><div class="row g-3 align-items-end"><div class="col-md-4"><label class="form-label">From</label><input name="StartDate" value="@start.ToString("yyyy-MM-dd")" type="date" class="form-control" /></div><div class="col-md-4"><label class="form-label">To</label><input name="EndDate" value="@end.ToString("yyyy-MM-dd")" type="date" class="form-control" /></div><div class="col-md-4"><button class="btn vpms-btn-primary w-100">Run</button></div></div></form>
<div class="vpms-table-wrapper"><table class="table vpms-table"><thead><tr><th>Date</th><th>Document</th><th>Customer</th><th class="text-end">Gross</th><th class="text-end">VATable Sales</th><th class="text-end">VAT-Exempt</th><th class="text-end">Zero-Rated</th><th class="text-end">Output VAT</th><th class="text-end">Total</th></tr></thead><tbody>@foreach (var row in rows){<tr><td>@row.DocumentDate.ToString("yyyy-MM-dd")</td><td>@row.DocumentNumber</td><td>@row.BillingName</td><td class="text-end">@row.TotalAmount.ToString("C")</td><td class="text-end">@row.SubTotal.ToString("C")</td><td class="text-end">@(0.ToString("C"))</td><td class="text-end">@(0.ToString("C"))</td><td class="text-end">@row.TaxAmount.ToString("C")</td><td class="text-end">@row.TotalAmount.ToString("C")</td></tr>}</tbody><tfoot><tr><th colspan="3">Totals</th><th class="text-end">@rows.Sum(r => r.TotalAmount).ToString("C")</th><th class="text-end">@rows.Sum(r => r.SubTotal).ToString("C")</th><th class="text-end">@(0.ToString("C"))</th><th class="text-end">@(0.ToString("C"))</th><th class="text-end">@rows.Sum(r => r.TaxAmount).ToString("C")</th><th class="text-end">@rows.Sum(r => r.TotalAmount).ToString("C")</th></tr></tfoot></table></div>
