@page
@using Microsoft.EntityFrameworkCore
@using Vantage.PMS.Models.Finance
@inject Vantage.PMS.Data.ApplicationDbContext Db
@{
    ViewData["Title"] = "Cash Receipts Journal";
    var start = DateTime.TryParse(Request.Query["StartDate"], out var s) ? s : new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    var end = DateTime.TryParse(Request.Query["EndDate"], out var e) ? e : DateTime.Today;
    var rows = await Db.Payments.AsNoTracking().Include(payment => payment.Folio).ThenInclude(folio => folio!.Guest).Where(payment => payment.PaymentDate >= start && payment.PaymentDate <= end && payment.Status == PaymentStatus.Completed).OrderBy(payment => payment.PaymentDate).ToListAsync();
}
<div class="page-header"><div><div class="page-kicker">Philippine Reports</div><h1 class="page-title">Cash Receipts Journal</h1><p class="page-subtitle">Folio payment receipt readiness report.</p></div><button class="btn vpms-btn-secondary" onclick="window.print()">Print</button></div>
<form method="get" class="vpms-card mb-3 report-filter"><div class="row g-3 align-items-end"><div class="col-md-4"><label class="form-label">From</label><input name="StartDate" value="@start.ToString("yyyy-MM-dd")" type="date" class="form-control" /></div><div class="col-md-4"><label class="form-label">To</label><input name="EndDate" value="@end.ToString("yyyy-MM-dd")" type="date" class="form-control" /></div><div class="col-md-4"><button class="btn vpms-btn-primary w-100">Run</button></div></div></form>
<div class="vpms-table-wrapper"><table class="table vpms-table"><thead><tr><th>Date</th><th>Reference</th><th>Guest/Account</th><th>Method</th><th class="text-end">Cash</th><th class="text-end">Card</th><th class="text-end">Bank Transfer</th><th class="text-end">E-wallet</th><th class="text-end">Total</th></tr></thead><tbody>@foreach (var row in rows){var method=row.PaymentMethod?.ToUpperInvariant() ?? "";<tr><td>@row.PaymentDate.ToString("yyyy-MM-dd")</td><td>@row.ReferenceNumber</td><td>@($"{row.Folio?.Guest?.FirstName} {row.Folio?.Guest?.LastName}".Trim())</td><td>@row.PaymentMethod</td><td class="text-end">@(method.Contains("CASH") ? row.Amount.ToString("C") : 0.ToString("C"))</td><td class="text-end">@(method.Contains("CARD") ? row.Amount.ToString("C") : 0.ToString("C"))</td><td class="text-end">@(method.Contains("BANK") ? row.Amount.ToString("C") : 0.ToString("C"))</td><td class="text-end">@(method.Contains("WALLET") || method.Contains("GCASH") || method.Contains("MAYA") ? row.Amount.ToString("C") : 0.ToString("C"))</td><td class="text-end">@row.Amount.ToString("C")</td></tr>}</tbody></table></div>
