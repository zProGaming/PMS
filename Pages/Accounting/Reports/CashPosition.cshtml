@page
@model Vantage.PMS.Pages.Accounting.Reports.CashPositionModel
@{
    ViewData["Title"] = "Cash Position";
}
<div class="page-header"><div><div class="page-kicker">Banking Report</div><h1 class="page-title">Cash Position</h1><p class="page-subtitle">Bank account balances based on opening balance and bank transactions.</p></div><div class="page-actions no-print"><button class="btn vpms-btn-secondary" onclick="window.print()">Print</button></div></div>
<div class="vpms-table-wrapper"><table class="table vpms-table align-middle"><thead><tr><th>Account</th><th>Bank</th><th>Currency</th><th>Status</th><th class="text-end">Book Balance</th></tr></thead><tbody>
@foreach (var row in Model.Rows)
{
    <tr><td class="fw-semibold">@row.AccountName</td><td>@row.BankName</td><td>@row.Currency</td><td><span class="status-badge @(row.IsActive ? "status-paid" : "status-cancelled")">@(row.IsActive ? "Active" : "Inactive")</span></td><td class="text-end">@row.Balance.ToString("C")</td></tr>
}
</tbody><tfoot><tr><th colspan="4">Total</th><th class="text-end">@Model.Rows.Sum(row => row.Balance).ToString("C")</th></tr></tfoot></table></div>
