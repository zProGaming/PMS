@page
@model Vantage.PMS.Pages.Accounting.Reports.DisbursementSummaryModel
@{
    ViewData["Title"] = "Disbursement Summary";
}
<div class="page-header"><div><div class="page-kicker">Accounts Payable Report</div><h1 class="page-title">Disbursement Summary</h1><p class="page-subtitle">Released supplier payments.</p></div><div class="page-actions no-print"><button class="btn vpms-btn-secondary" onclick="window.print()">Print</button></div></div>
<div class="vpms-table-wrapper"><table class="table vpms-table align-middle"><thead><tr><th>Date</th><th>Disbursement</th><th>Voucher</th><th>Supplier</th><th>Method</th><th>Status</th><th class="text-end">Amount</th></tr></thead><tbody>
@foreach (var item in Model.Disbursements)
{
    <tr><td>@item.DisbursementDate.ToString("yyyy-MM-dd")</td><td>@item.DisbursementNumber</td><td>@item.PaymentVoucher?.VoucherNumber</td><td>@item.Supplier?.SupplierName</td><td>@item.PaymentMethod</td><td><span class="status-badge">@item.Status</span></td><td class="text-end">@item.Amount.ToString("C")</td></tr>
}
</tbody><tfoot><tr><th colspan="6">Total</th><th class="text-end">@Model.Disbursements.Sum(item => item.Amount).ToString("C")</th></tr></tfoot></table></div>
