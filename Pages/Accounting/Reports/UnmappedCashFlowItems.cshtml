@page
@model Vantage.PMS.Pages.Accounting.Reports.UnmappedCashFlowItemsModel
@using Vantage.PMS.ViewModels.Reports
@{
    ViewData["Title"] = "Unmapped Cash Flow Items";
    var csvUrl = Url.Page("/Reports/Export", "Csv", new
    {
        reportKey = "unmapped-cash-flow-items",
        dateRangeStart = Model.StartDate.ToString("yyyy-MM-dd"),
        dateRangeEnd = Model.EndDate.ToString("yyyy-MM-dd")
    });
}

<div class="page-header vpms-no-print">
    <div>
        <div class="page-kicker">Accounting Setup</div>
        <h1 class="page-title">Unmapped Cash Flow Items</h1>
        <p class="page-subtitle">Review posted cash movements that defaulted to Other Operating Cash Flows.</p>
    </div>
</div>

<form method="get" class="vpms-card mb-3 vpms-report-filters">
    <div class="row g-3 align-items-end">
        <div class="col-md-4">
            <label class="form-label">Date From</label>
            <input name="StartDate" value="@Model.StartDate.ToString("yyyy-MM-dd")" type="date" class="form-control" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Date To</label>
            <input name="EndDate" value="@Model.EndDate.ToString("yyyy-MM-dd")" type="date" class="form-control" />
        </div>
        <div class="col-md-4">
            <button class="btn vpms-btn-primary w-100" type="submit">Run</button>
        </div>
    </div>
</form>

@await Html.PartialAsync("_ReportActions", new ReportActionsViewModel
{
    CsvAvailable = true,
    CsvUrl = csvUrl,
    HtmlAvailable = true,
    HtmlUrl = Url.Page("/Accounting/Reports/UnmappedCashFlowItems", new { startDate = Model.StartDate.ToString("yyyy-MM-dd"), endDate = Model.EndDate.ToString("yyyy-MM-dd") }),
    BackUrl = Url.Page("/Accounting/Reports/StatementOfCashFlows", new { startDate = Model.StartDate.ToString("yyyy-MM-dd"), endDate = Model.EndDate.ToString("yyyy-MM-dd") })
})

<section class="vpms-print-document vpms-report-page">
    @await Html.PartialAsync("_ReportHeader", new ReportHeaderViewModel
    {
        ReportTitle = "Unmapped Cash Flow Items",
        ReportCategory = "Accounting",
        DateRangeStart = Model.StartDate,
        DateRangeEnd = Model.EndDate,
        GeneratedBy = User.Identity?.Name,
        Disclaimer = "Create cash flow mapping rules from these items. Do not edit posted journal entries from this report."
    })

    @if (!Model.Rows.Any())
    {
        <div class="vpms-empty-state">
            <h2>No unmapped cash flow items</h2>
            <p>All detected cash movements have a configured source or offset-account classification for the selected date range.</p>
        </div>
    }
    else
    {
        <div class="vpms-table-wrapper">
            <table class="table vpms-table vpms-report-table align-middle">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Journal</th>
                        <th>Source</th>
                        <th>Cash Account</th>
                        <th>Offset Account</th>
                        <th>Description</th>
                        <th class="text-end">Net Cash</th>
                        <th class="text-end vpms-no-print">Action</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in Model.Rows)
                {
                    <tr>
                        <td>@row.JournalDate.ToString("MMM d, yyyy")</td>
                        <td>@row.JournalNumber</td>
                        <td>@row.SourceModule / @row.SourceTransactionType</td>
                        <td>@row.CashAccountCode - @row.CashAccountName</td>
                        <td>@row.OffsetAccountCode @row.OffsetAccountName</td>
                        <td>@row.Description</td>
                        <td class="text-end">@row.Amount.ToString("C")</td>
                        <td class="text-end vpms-no-print">
                            <a class="btn btn-sm vpms-btn-primary" asp-page="/Accounting/CashFlow/MappingRules/Index" asp-route-glAccountId="@row.OffsetAccountId" asp-route-sourceModule="@row.SourceModule" asp-route-sourceTransactionType="@row.SourceTransactionType">Create Rule</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }

    @await Html.PartialAsync("_ReportFooter", new ReportFooterViewModel
    {
        FooterText = "Generated by Vantage PMS.",
        ShowComplianceNote = true
    })
</section>
