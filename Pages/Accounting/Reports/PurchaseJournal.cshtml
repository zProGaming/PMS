@page
@using Microsoft.EntityFrameworkCore
@using Vantage.PMS.Models.Inventory
@inject Vantage.PMS.Data.ApplicationDbContext Db
@{
    ViewData["Title"] = "Purchase Journal";
    var start = DateTime.TryParse(Request.Query["StartDate"], out var s) ? s : new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    var end = DateTime.TryParse(Request.Query["EndDate"], out var e) ? e : DateTime.Today;
    var rows = await Db.ReceivingRecords.AsNoTracking().Include(record => record.Supplier).Include(record => record.Items).Where(record => record.ReceivedDate >= start && record.ReceivedDate <= end && record.Status == ReceivingStatus.Posted).OrderBy(record => record.ReceivedDate).ToListAsync();
}
<div class="page-header"><div><div class="page-kicker">Philippine Reports</div><h1 class="page-title">Purchase Journal</h1><p class="page-subtitle">Posted receiving purchase readiness report.</p></div><button class="btn vpms-btn-secondary" onclick="window.print()">Print</button></div>
<div class="alert alert-warning">Philippine finance report formats are configurable and must be validated by a Philippine CPA/accountant before filing or official submission.</div>
<form method="get" class="vpms-card mb-3 report-filter"><div class="row g-3 align-items-end"><div class="col-md-4"><label class="form-label">From</label><input name="StartDate" value="@start.ToString("yyyy-MM-dd")" type="date" class="form-control" /></div><div class="col-md-4"><label class="form-label">To</label><input name="EndDate" value="@end.ToString("yyyy-MM-dd")" type="date" class="form-control" /></div><div class="col-md-4"><button class="btn vpms-btn-primary w-100">Run</button></div></div></form>
<div class="vpms-table-wrapper"><table class="table vpms-table"><thead><tr><th>Date</th><th>Supplier</th><th>Reference</th><th>Expense/Inventory Account</th><th class="text-end">Gross Purchase</th><th class="text-end">VAT</th><th class="text-end">Net Amount</th></tr></thead><tbody>@foreach (var row in rows){var gross=row.Items.Sum(item=>item.Amount); var vat=Math.Round(gross*0.12m/1.12m,2);<tr><td>@row.ReceivedDate.ToString("yyyy-MM-dd")</td><td>@row.Supplier?.SupplierName</td><td>@row.ReceivingNumber</td><td>Configured by posting rules</td><td class="text-end">@gross.ToString("C")</td><td class="text-end">@vat.ToString("C")</td><td class="text-end">@((gross-vat).ToString("C"))</td></tr>}</tbody></table></div>
