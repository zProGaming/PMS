@model Vantage.PMS.Pages.Accounting.AccountsPayable.PaymentVouchers.DetailsModel

<div class="vpms-native-workflow-card">
    <div class="vpms-native-workflow-kicker">Treasury control</div>
    <h2>@Model.NativeActionTitle</h2>
    <p>@Model.NativeActionMessage</p>

    <div class="vpms-native-workflow-summary">
        <span>Payment Voucher</span>
        <strong>@Model.Voucher.VoucherNumber</strong>
        <span>Supplier</span>
        <strong>@(Model.Voucher.Supplier?.SupplierName ?? "Not assigned")</strong>
        <span>Status</span>
        <strong>@Model.Voucher.Status</strong>
        <span>Net Payment</span>
        <strong>@Model.Voucher.NetPaymentAmount.ToString("C")</strong>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.NativeActionSupport))
    {
        <div class="vpms-native-workflow-note">@Model.NativeActionSupport</div>
    }

    <form method="post" asp-page="./Details" asp-page-handler="@Model.NativeActionHandler" asp-route-id="@Model.Voucher.Id" class="vpms-native-workflow-actions">
        <button type="submit" class="btn @Model.NativeActionButtonClass">@Model.NativeActionButtonText</button>
        <a href="#" class="btn vpms-btn-secondary" data-vpms-dialog-close>Keep Reviewing</a>
    </form>
</div>
