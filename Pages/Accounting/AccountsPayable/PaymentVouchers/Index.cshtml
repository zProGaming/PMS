@page
@model Vantage.PMS.Pages.Accounting.AccountsPayable.PaymentVouchers.IndexModel
@using Vantage.PMS.Models.Accounting
@{
    ViewData["Title"] = "Payment Vouchers";
}

<div class="page-header">
    <div><div class="page-kicker">Accounts Payable</div><h1 class="page-title">Payment Vouchers</h1><p class="page-subtitle">Supplier payment approval and release controls.</p></div>
    <div class="page-actions"><a class="btn vpms-btn-primary" asp-page="Create">Create Payment Voucher</a></div>
</div>

<form method="get" class="vpms-card mb-3">
    <div class="row g-3 align-items-end">
        <div class="col-md-4"><label class="form-label">Status</label><select name="status" class="form-select" asp-items="Html.GetEnumSelectList<PaymentVoucherStatus>()"><option value="">All</option></select></div>
        <div class="col-md-3"><button class="btn vpms-btn-secondary" type="submit">Filter</button></div>
    </div>
</form>

<div class="vpms-table-wrapper">
    <table class="table vpms-table align-middle">
        <thead><tr><th>Voucher</th><th>Supplier</th><th>AP Invoice</th><th>Date</th><th>Method</th><th>Status</th><th class="text-end">Amount</th><th class="text-end">Net</th><th></th></tr></thead>
        <tbody>
        @foreach (var voucher in Model.Vouchers)
        {
            <tr>
                <td class="fw-semibold">@voucher.VoucherNumber</td>
                <td>@voucher.Supplier?.SupplierName</td>
                <td>@voucher.APInvoice?.InvoiceNumber</td>
                <td>@voucher.VoucherDate.ToString("yyyy-MM-dd")</td>
                <td>@voucher.PaymentMethod</td>
                <td><span class="status-badge">@voucher.Status</span></td>
                <td class="text-end">@voucher.Amount.ToString("C")</td>
                <td class="text-end">@voucher.NetPaymentAmount.ToString("C")</td>
                <td class="text-end"><a class="btn btn-sm vpms-btn-secondary" asp-page="Details" asp-route-id="@voucher.Id">Details</a></td>
            </tr>
        }
        </tbody>
    </table>
</div>
