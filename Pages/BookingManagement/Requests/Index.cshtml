@page
@model Vantage.PMS.Pages.BookingManagement.Requests.IndexModel
@{
    ViewData["Title"] = "Booking Requests";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">Booking Requests</h1>
    <a asp-page="/BookingManagement/Index" class="btn btn-outline-secondary">Dashboard</a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>Reference</th>
                <th>Guest</th>
                <th>Stay</th>
                <th>Room Type</th>
                <th>Total</th>
                <th>Status</th>
                <th>Created</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var request in Model.BookingRequests)
            {
                <tr>
                    <td>@request.BookingReference</td>
                    <td>@request.GuestLastName, @request.GuestFirstName</td>
                    <td>@request.CheckInDate.ToString("yyyy-MM-dd") - @request.CheckOutDate.ToString("yyyy-MM-dd")</td>
                    <td>@(request.RoomType?.Code ?? "Unknown")</td>
                    <td>@request.TotalRoomAmount.ToString("C")</td>
                    <td><span class="badge bg-secondary">@request.BookingStatus</span></td>
                    <td>@request.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                    <td class="text-end">
                        <a asp-page="Details" asp-route-id="@request.Id" class="btn btn-sm btn-outline-primary">Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
