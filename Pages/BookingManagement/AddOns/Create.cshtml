@page
@model Vantage.PMS.Pages.BookingManagement.AddOns.CreateModel
@{
    ViewData["Title"] = "Create Booking Add-on";
}

<h1 class="h3 mb-3">Create Booking Add-on</h1>

<form method="post" class="row g-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="col-md-8">
        <label asp-for="AddOn.Name" class="form-label"></label>
        <input asp-for="AddOn.Name" class="form-control" />
        <span asp-validation-for="AddOn.Name" class="text-danger"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="AddOn.Price" class="form-label"></label>
        <input asp-for="AddOn.Price" class="form-control" type="number" min="0" step="0.01" />
        <span asp-validation-for="AddOn.Price" class="text-danger"></span>
    </div>
    <div class="col-12">
        <label asp-for="AddOn.Description" class="form-label"></label>
        <textarea asp-for="AddOn.Description" class="form-control" rows="3"></textarea>
    </div>
    <div class="col-12 d-flex gap-3 flex-wrap">
        <div class="form-check">
            <input asp-for="AddOn.IsPerNight" class="form-check-input" />
            <label asp-for="AddOn.IsPerNight" class="form-check-label"></label>
        </div>
        <div class="form-check">
            <input asp-for="AddOn.IsPerPerson" class="form-check-input" />
            <label asp-for="AddOn.IsPerPerson" class="form-check-label"></label>
        </div>
        <div class="form-check">
            <input asp-for="AddOn.IsActive" class="form-check-input" />
            <label asp-for="AddOn.IsActive" class="form-check-label"></label>
        </div>
    </div>
    <div class="col-12">
        <button type="submit" class="btn btn-primary">Create</button>
        <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
