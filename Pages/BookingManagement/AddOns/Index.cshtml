@page
@model Vantage.PMS.Pages.BookingManagement.AddOns.IndexModel
@{
    ViewData["Title"] = "Booking Add-ons";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">Booking Add-ons</h1>
    <a asp-page="Create" class="btn btn-primary">New Add-on</a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>Name</th>
                <th>Price</th>
                <th>Per Night</th>
                <th>Per Person</th>
                <th>Active</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.AddOns)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Price.ToString("C")</td>
                    <td>@(item.IsPerNight ? "Yes" : "No")</td>
                    <td>@(item.IsPerPerson ? "Yes" : "No")</td>
                    <td>@(item.IsActive ? "Yes" : "No")</td>
                    <td class="text-end">
                        <a asp-page="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                        <a asp-page="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
