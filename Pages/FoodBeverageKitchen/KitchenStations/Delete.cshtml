@page "/FoodBeverage/Kitchen/KitchenStations/Delete/{id:int}"
@model Vantage.PMS.Pages.FoodBeverageKitchen.KitchenStations.DeleteModel

@{
    ViewData["Title"] = "Delete Kitchen Station";
}

<h1>Delete Kitchen Station</h1>

<div class="alert alert-warning">
    Delete kitchen station <strong>@Model.KitchenStation.Name</strong>?
</div>

<dl class="row">
    <dt class="col-sm-2">Description</dt>
    <dd class="col-sm-10">@Model.KitchenStation.Description</dd>
    <dt class="col-sm-2">Active</dt>
    <dd class="col-sm-10">@(Model.KitchenStation.IsActive ? "Yes" : "No")</dd>
</dl>

<form method="post">
    <button type="submit" class="btn btn-danger">Delete</button>
    <a class="btn btn-outline-secondary" asp-page="./Index">Cancel</a>
</form>
