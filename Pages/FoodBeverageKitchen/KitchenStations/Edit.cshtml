@page "/FoodBeverage/Kitchen/KitchenStations/Edit/{id:int}"
@model Vantage.PMS.Pages.FoodBeverageKitchen.KitchenStations.EditModel

@{
    ViewData["Title"] = "Edit Kitchen Station";
}

<h1>Edit Kitchen Station</h1>

<form method="post" class="mt-3">
    <input type="hidden" asp-for="KitchenStation.Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="KitchenStation.Name" class="form-label"></label>
        <input asp-for="KitchenStation.Name" class="form-control" />
        <span asp-validation-for="KitchenStation.Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="KitchenStation.Description" class="form-label"></label>
        <textarea asp-for="KitchenStation.Description" class="form-control" rows="3"></textarea>
        <span asp-validation-for="KitchenStation.Description" class="text-danger"></span>
    </div>

    <div class="form-check mb-3">
        <input asp-for="KitchenStation.IsActive" class="form-check-input" />
        <label asp-for="KitchenStation.IsActive" class="form-check-label">Active</label>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a class="btn btn-outline-secondary" asp-page="./Index">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
