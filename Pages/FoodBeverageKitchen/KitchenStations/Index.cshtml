@page "/FoodBeverage/Kitchen/KitchenStations"
@model Vantage.PMS.Pages.FoodBeverageKitchen.KitchenStations.IndexModel

@{
    ViewData["Title"] = "Kitchen Stations";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="mb-1">Kitchen Stations</h1>
        <p class="text-muted mb-0">Preparation stations used by the kitchen display.</p>
    </div>
    <a class="btn btn-primary" asp-page="./Create">Create Station</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>Name</th>
            <th>Description</th>
            <th>Active</th>
            <th class="text-end">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var station in Model.KitchenStations)
        {
            <tr>
                <td>@station.Name</td>
                <td>@station.Description</td>
                <td>@(station.IsActive ? "Yes" : "No")</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-primary" asp-page="./Edit" asp-route-id="@station.Id">Edit</a>
                    <a class="btn btn-sm btn-outline-danger" asp-page="./Delete" asp-route-id="@station.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
