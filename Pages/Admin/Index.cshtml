@page
@model Vantage.PMS.Pages.Admin.IndexModel

@{
    ViewData["Title"] = "Admin";
    var setupSteps = new[]
    {
        new { Number = "01", Title = "Company Code", Description = "Create the hotel/company record that binds users to the correct tenant.", Count = Model.Hotels, IndexPage = "/Admin/Hotels/Index", CreatePage = "/Admin/Hotels/Create", Action = "Create Company" },
        new { Number = "02", Title = "Property", Description = "Define the operating property, address, and property-level context.", Count = Model.Properties, IndexPage = "/Admin/Properties/Index", CreatePage = "/Admin/Properties/Create", Action = "Create Property" },
        new { Number = "03", Title = "Departments", Description = "Set front office, rooms, finance, F&B, and operating departments.", Count = Model.Departments, IndexPage = "/Admin/Departments/Index", CreatePage = "/Admin/Departments/Create", Action = "Create Department" },
        new { Number = "04", Title = "Room Types", Description = "Build sellable categories before loading physical room inventory.", Count = Model.RoomTypes, IndexPage = "/Admin/RoomTypes/Index", CreatePage = "/Admin/RoomTypes/Create", Action = "Create Room Type" },
        new { Number = "05", Title = "Rooms", Description = "Create physical rooms that power the room calendar and housekeeping board.", Count = Model.Rooms, IndexPage = "/Admin/Rooms/Index", CreatePage = "/Admin/Rooms/Create", Action = "Create Room" },
        new { Number = "06", Title = "Users and Roles", Description = "Grant staff access after the operating structure is ready.", Count = Model.Roles, IndexPage = "/Admin/UsersAndRoles/Index", CreatePage = "/Admin/UsersAndRoles/Index", Action = "Manage Access" }
    };
    var completedSteps = setupSteps.Count(step => step.Count > 0);
    var setupPercent = Math.Round(completedSteps * 100m / setupSteps.Length, 0);
    var nextSetupStep = setupSteps.FirstOrDefault(step => step.Count == 0) ?? setupSteps.Last();
    var setupComplete = completedSteps == setupSteps.Length;
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Dashboard</a></li>
        <li class="breadcrumb-item active" aria-current="page">Admin</li>
    </ol>
</nav>

<div class="page-header">
    <div>
        <div class="page-kicker">System Administration</div>
        <h1 class="page-title">Admin Setup</h1>
        <p class="page-subtitle">Central setup landing page for hotel structure, property records, rooms, departments, and access roles.</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <button class="btn vpms-btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#adminSetupGuide">Setup Guide</button>
        <a class="btn vpms-btn-primary" asp-page="/Admin/Properties/Index">Properties</a>
        <a class="btn vpms-btn-secondary" asp-page="/Admin/UsersAndRoles/Index">Users and Roles</a>
    </div>
</div>

<section class="vpms-admin-setup-command" aria-label="Global admin setup guide">
    <div class="vpms-admin-setup-summary">
        <span>Trial Readiness Setup</span>
        <strong>@setupPercent.ToString("N0")%</strong>
        <small>@completedSteps of @setupSteps.Length setup controls have records.</small>
        <div class="progress" aria-hidden="true">
            <div class="progress-bar" style="width: @setupPercent%"></div>
        </div>
        <div class="vpms-admin-next-step">
            <span>@(setupComplete ? "Ready for Trial" : "Next Recommended Step")</span>
            <strong>@(setupComplete ? "Review Access" : nextSetupStep.Title)</strong>
            <small>@(setupComplete ? "Core setup is populated. Review user access before live trial use." : nextSetupStep.Description)</small>
            <div>
                <a class="btn btn-sm vpms-btn-primary"
                   asp-page="@nextSetupStep.CreatePage"
                   data-vpms-dialog
                   data-vpms-dialog-title="@nextSetupStep.Action">@(setupComplete ? "Manage Access" : nextSetupStep.Action)</a>
                <a class="btn btn-sm vpms-btn-secondary" asp-page="@nextSetupStep.IndexPage">Open List</a>
            </div>
        </div>
    </div>
    <div class="vpms-admin-setup-flow">
        @foreach (var step in setupSteps)
        {
            var isComplete = step.Count > 0;
            <article class="@(isComplete ? "complete" : "attention")">
                <span>@step.Number</span>
                <div>
                    <strong>@step.Title</strong>
                    <small>@(isComplete ? $"{step.Count} configured" : "Needs setup")</small>
                </div>
                <a asp-page="@step.CreatePage"
                   data-vpms-dialog
                   data-vpms-dialog-title="@step.Action">@step.Action</a>
            </article>
        }
    </div>
</section>

<div class="row g-3 mb-4">
    <div class="col-md-4 col-xl-2">
        <div class="kpi-card">
            <div class="kpi-label">Hotels</div>
            <div class="kpi-value">@Model.Hotels</div>
            <div class="kpi-note">Hotel records</div>
        </div>
    </div>
    <div class="col-md-4 col-xl-2">
        <div class="kpi-card">
            <div class="kpi-label">Properties</div>
            <div class="kpi-value">@Model.Properties</div>
            <div class="kpi-note">Operating sites</div>
        </div>
    </div>
    <div class="col-md-4 col-xl-2">
        <div class="kpi-card">
            <div class="kpi-label">Departments</div>
            <div class="kpi-value">@Model.Departments</div>
            <div class="kpi-note">Org structure</div>
        </div>
    </div>
    <div class="col-md-4 col-xl-2">
        <div class="kpi-card">
            <div class="kpi-label">Rooms</div>
            <div class="kpi-value">@Model.Rooms</div>
            <div class="kpi-note">Physical inventory</div>
        </div>
    </div>
    <div class="col-md-4 col-xl-2">
        <div class="kpi-card">
            <div class="kpi-label">Room Types</div>
            <div class="kpi-value">@Model.RoomTypes</div>
            <div class="kpi-note">Sellable categories</div>
        </div>
    </div>
    <div class="col-md-4 col-xl-2">
        <div class="kpi-card">
            <div class="kpi-label">Roles</div>
            <div class="kpi-value">@Model.Roles</div>
            <div class="kpi-note">Access profiles</div>
        </div>
    </div>
</div>

<section class="vpms-card p-3">
    <div class="row g-3">
        <div class="col-md-6 col-xl-4">
            <a class="quick-action-card h-100" asp-page="/Admin/Hotels/Index">
                <strong>Hotels and Organizations</strong>
                <small>Brand, hotel, and ownership setup.</small>
            </a>
        </div>
        <div class="col-md-6 col-xl-4">
            <a class="quick-action-card h-100" asp-page="/Admin/Properties/Index">
                <strong>Properties</strong>
                <small>Property records for multi-property operations.</small>
            </a>
        </div>
        <div class="col-md-6 col-xl-4">
            <a class="quick-action-card h-100" asp-page="/Admin/Departments/Index">
                <strong>Departments</strong>
                <small>Operational and reporting departments.</small>
            </a>
        </div>
        <div class="col-md-6 col-xl-4">
            <a class="quick-action-card h-100" asp-page="/Admin/RoomTypes/Index">
                <strong>Room Types</strong>
                <small>Rates, occupancy, and sellable room categories.</small>
            </a>
        </div>
        <div class="col-md-6 col-xl-4">
            <a class="quick-action-card h-100" asp-page="/Admin/Rooms/Index">
                <strong>Rooms</strong>
                <small>Physical room inventory for the Room Rack.</small>
            </a>
        </div>
        <div class="col-md-6 col-xl-4">
            <a class="quick-action-card h-100" asp-page="/Admin/UsersAndRoles/Index">
                <strong>Users and Roles</strong>
                <small>Staff access and role assignment.</small>
            </a>
        </div>
    </div>
</section>

<div class="modal fade vpms-command-modal" id="adminSetupGuide" tabindex="-1" aria-labelledby="adminSetupGuideLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <div class="page-kicker">Global Admin</div>
                    <h2 class="modal-title" id="adminSetupGuideLabel">Hotel Setup Sequence</h2>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="vpms-setup-guidance-callout">
                    <div>
                        <span>Guided sequence</span>
                        <strong>@(setupComplete ? "Core property setup is populated" : $"Continue with {nextSetupStep.Title}")</strong>
                        <p>Use this order for trials: company code first, then property context, departments, sellable room types, physical rooms, and staff access.</p>
                    </div>
                    <a class="btn vpms-btn-primary"
                       asp-page="@nextSetupStep.CreatePage"
                       data-vpms-dialog
                       data-vpms-dialog-title="@nextSetupStep.Action">@nextSetupStep.Action</a>
                </div>
                <div class="vpms-setup-guide-grid">
                    @foreach (var step in setupSteps)
                    {
                        var isComplete = step.Count > 0;
                        <article class="@(isComplete ? "complete" : "attention")">
                            <span>@step.Number</span>
                            <div>
                                <h3>@step.Title</h3>
                                <p>@step.Description</p>
                                <small>@(isComplete ? $"{step.Count} configured" : "Required before trials")</small>
                            </div>
                            <div class="vpms-setup-guide-actions">
                                <a class="btn btn-sm vpms-btn-secondary" asp-page="@step.IndexPage">Open List</a>
                                <a class="btn btn-sm vpms-btn-primary"
                                   asp-page="@step.CreatePage"
                                   data-vpms-dialog
                                   data-vpms-dialog-title="@step.Action">@step.Action</a>
                            </div>
                        </article>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
