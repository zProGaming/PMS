@page "{id:int}"
@model Vantage.PMS.Pages.Admin.Properties.EditModel

@{
    ViewData["Title"] = "Edit Property";
}

<h1>Edit Property</h1>

<form method="post" class="mt-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="Property.Id" />

    <div class="mb-3">
        <label asp-for="Property.HotelId" class="form-label">Hotel</label>
        <select asp-for="Property.HotelId" class="form-select" asp-items="Model.HotelOptions"></select>
        <span asp-validation-for="Property.HotelId" class="text-danger"></span>
    </div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <label asp-for="Property.Code" class="form-label"></label>
            <input asp-for="Property.Code" class="form-control" />
            <span asp-validation-for="Property.Code" class="text-danger"></span>
        </div>
        <div class="col-md-8 mb-3">
            <label asp-for="Property.Name" class="form-label"></label>
            <input asp-for="Property.Name" class="form-control" />
            <span asp-validation-for="Property.Name" class="text-danger"></span>
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="Property.AddressLine1" class="form-label">Address Line 1</label>
        <input asp-for="Property.AddressLine1" class="form-control" />
        <span asp-validation-for="Property.AddressLine1" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Property.AddressLine2" class="form-label">Address Line 2</label>
        <input asp-for="Property.AddressLine2" class="form-control" />
        <span asp-validation-for="Property.AddressLine2" class="text-danger"></span>
    </div>

    <div class="row">
        <div class="col-md-3 mb-3">
            <label asp-for="Property.City" class="form-label"></label>
            <input asp-for="Property.City" class="form-control" />
            <span asp-validation-for="Property.City" class="text-danger"></span>
        </div>
        <div class="col-md-3 mb-3">
            <label asp-for="Property.StateProvince" class="form-label">State/Province</label>
            <input asp-for="Property.StateProvince" class="form-control" />
            <span asp-validation-for="Property.StateProvince" class="text-danger"></span>
        </div>
        <div class="col-md-3 mb-3">
            <label asp-for="Property.PostalCode" class="form-label">Postal Code</label>
            <input asp-for="Property.PostalCode" class="form-control" />
            <span asp-validation-for="Property.PostalCode" class="text-danger"></span>
        </div>
        <div class="col-md-3 mb-3">
            <label asp-for="Property.Country" class="form-label"></label>
            <input asp-for="Property.Country" class="form-control" />
            <span asp-validation-for="Property.Country" class="text-danger"></span>
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a class="btn btn-outline-secondary" asp-page="./Index">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
