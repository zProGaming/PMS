@page
@model Vantage.PMS.Pages.Admin.Properties.IndexModel

@{
    ViewData["Title"] = "Properties";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="mb-0">Properties</h1>
    <a class="btn btn-primary" asp-page="./Create">Create Property</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>Hotel</th>
            <th>Code</th>
            <th>Name</th>
            <th>City</th>
            <th>Country</th>
            <th class="text-end">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var property in Model.Properties)
        {
            <tr>
                <td>@property.Hotel?.Name</td>
                <td>@property.Code</td>
                <td>@property.Name</td>
                <td>@property.City</td>
                <td>@property.Country</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-primary" asp-page="./Edit" asp-route-id="@property.Id">Edit</a>
                    <a class="btn btn-sm btn-outline-secondary" asp-page="./Details" asp-route-id="@property.Id">Details</a>
                    <a class="btn btn-sm btn-outline-danger" asp-page="./Delete" asp-route-id="@property.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
