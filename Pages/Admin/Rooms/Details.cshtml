@page "{id:int}"
@model Vantage.PMS.Pages.Admin.Rooms.DetailsModel

@{
    ViewData["Title"] = "Room Details";
}

<h1>Room Details</h1>

<dl class="row mt-3">
    <dt class="col-sm-3">Property</dt>
    <dd class="col-sm-9">@Model.Room.Property?.Name</dd>

    <dt class="col-sm-3">Room Number</dt>
    <dd class="col-sm-9">@Model.Room.RoomNumber</dd>

    <dt class="col-sm-3">Room Type</dt>
    <dd class="col-sm-9">@Model.Room.RoomType?.Name</dd>

    <dt class="col-sm-3">Floor</dt>
    <dd class="col-sm-9">@Model.Room.Floor</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Room.Status</dd>

    <dt class="col-sm-3">Active</dt>
    <dd class="col-sm-9">@(Model.Room.IsActive ? "Yes" : "No")</dd>
</dl>

<a class="btn btn-primary" asp-page="./Edit" asp-route-id="@Model.Room.Id">Edit</a>
<a class="btn btn-outline-secondary" asp-page="./Index">Back</a>
