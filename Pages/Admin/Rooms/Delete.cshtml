@page "{id:int}"
@model Vantage.PMS.Pages.Admin.Rooms.DeleteModel

@{
    ViewData["Title"] = "Delete Room";
}

<h1>Delete Room</h1>
<p class="text-danger">Are you sure you want to delete this room?</p>

<dl class="row mt-3">
    <dt class="col-sm-3">Property</dt>
    <dd class="col-sm-9">@Model.Room.Property?.Name</dd>

    <dt class="col-sm-3">Room Number</dt>
    <dd class="col-sm-9">@Model.Room.RoomNumber</dd>

    <dt class="col-sm-3">Room Type</dt>
    <dd class="col-sm-9">@Model.Room.RoomType?.Name</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Room.Status</dd>

    <dt class="col-sm-3">Active</dt>
    <dd class="col-sm-9">@(Model.Room.IsActive ? "Yes" : "No")</dd>
</dl>

<form method="post">
    <input type="hidden" asp-for="Room.Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a class="btn btn-outline-secondary" asp-page="./Index">Cancel</a>
</form>
