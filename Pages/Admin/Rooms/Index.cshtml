@page
@model Vantage.PMS.Pages.Admin.Rooms.IndexModel

@{
    ViewData["Title"] = "Rooms";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="mb-0">Rooms</h1>
    <a class="btn btn-primary" asp-page="./Create">Create Room</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>Property</th>
            <th>Room Number</th>
            <th>Room Type</th>
            <th>Floor</th>
            <th>Status</th>
            <th>Active</th>
            <th class="text-end">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var room in Model.Rooms)
        {
            <tr>
                <td>@room.Property?.Name</td>
                <td>@room.RoomNumber</td>
                <td>@room.RoomType?.Name</td>
                <td>@room.Floor</td>
                <td>@room.Status</td>
                <td>@(room.IsActive ? "Yes" : "No")</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-primary" asp-page="./Edit" asp-route-id="@room.Id">Edit</a>
                    <a class="btn btn-sm btn-outline-secondary" asp-page="./Details" asp-route-id="@room.Id">Details</a>
                    <a class="btn btn-sm btn-outline-danger" asp-page="./Delete" asp-route-id="@room.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
