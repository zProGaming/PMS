@page "{id:int}"
@model Vantage.PMS.Pages.Admin.Hotels.EditModel

@{
    ViewData["Title"] = "Edit Hotel";
}

<h1>Edit Hotel</h1>

<form method="post" class="mt-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="Hotel.Id" />

    <div class="mb-3">
        <label asp-for="Hotel.Code" class="form-label">Company Code</label>
        <input asp-for="Hotel.Code" class="form-control text-uppercase" autocomplete="organization" />
        <div class="form-text">Used on the login screen. Changing this affects how users sign in to this company.</div>
        <span asp-validation-for="Hotel.Code" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Hotel.Name" class="form-label"></label>
        <input asp-for="Hotel.Name" class="form-control" />
        <span asp-validation-for="Hotel.Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Hotel.LegalName" class="form-label"></label>
        <input asp-for="Hotel.LegalName" class="form-control" />
        <span asp-validation-for="Hotel.LegalName" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a class="btn btn-outline-secondary" asp-page="./Index">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
