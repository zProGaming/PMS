@page "{id:int}"
@model Vantage.PMS.Pages.Admin.Hotels.DeleteModel

@{
    ViewData["Title"] = "Delete Hotel";
}

<h1>Delete Hotel</h1>
<p class="text-danger">Are you sure you want to delete this hotel?</p>

<dl class="row mt-3">
    <dt class="col-sm-3">Code</dt>
    <dd class="col-sm-9">@Model.Hotel.Code</dd>

    <dt class="col-sm-3">Name</dt>
    <dd class="col-sm-9">@Model.Hotel.Name</dd>

    <dt class="col-sm-3">Legal Name</dt>
    <dd class="col-sm-9">@Model.Hotel.LegalName</dd>
</dl>

<form method="post">
    <input type="hidden" asp-for="Hotel.Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a class="btn btn-outline-secondary" asp-page="./Index">Cancel</a>
</form>
