@page "{id:int}"
@model Vantage.PMS.Pages.Admin.RoomTypes.EditModel

@{
    ViewData["Title"] = "Edit Room Type";
}

<h1>Edit Room Type</h1>

<form method="post" class="mt-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="RoomType.Id" />

    <div class="mb-3">
        <label asp-for="RoomType.PropertyId" class="form-label">Property</label>
        <select asp-for="RoomType.PropertyId" class="form-select" asp-items="Model.PropertyOptions"></select>
        <span asp-validation-for="RoomType.PropertyId" class="text-danger"></span>
    </div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <label asp-for="RoomType.Code" class="form-label"></label>
            <input asp-for="RoomType.Code" class="form-control" />
            <span asp-validation-for="RoomType.Code" class="text-danger"></span>
        </div>
        <div class="col-md-8 mb-3">
            <label asp-for="RoomType.Name" class="form-label"></label>
            <input asp-for="RoomType.Name" class="form-control" />
            <span asp-validation-for="RoomType.Name" class="text-danger"></span>
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="RoomType.Description" class="form-label"></label>
        <textarea asp-for="RoomType.Description" class="form-control" rows="3"></textarea>
        <span asp-validation-for="RoomType.Description" class="text-danger"></span>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="RoomType.MaxOccupancy" class="form-label">Max Occupancy</label>
            <input asp-for="RoomType.MaxOccupancy" class="form-control" type="number" min="0" />
            <span asp-validation-for="RoomType.MaxOccupancy" class="text-danger"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="RoomType.BaseRate" class="form-label">Base Rate</label>
            <input asp-for="RoomType.BaseRate" class="form-control" type="number" min="0" step="0.01" />
            <span asp-validation-for="RoomType.BaseRate" class="text-danger"></span>
        </div>
    </div>

    <div class="form-check mb-3">
        <input asp-for="RoomType.IsActive" class="form-check-input" />
        <label asp-for="RoomType.IsActive" class="form-check-label">Active</label>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a class="btn btn-outline-secondary" asp-page="./Index">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
