@page "{id:int}"
@model Vantage.PMS.Pages.Admin.Departments.DetailsModel

@{
    ViewData["Title"] = "Department Details";
}

<h1>Department Details</h1>

<dl class="row mt-3">
    <dt class="col-sm-3">Property</dt>
    <dd class="col-sm-9">@Model.Department.Property?.Name</dd>

    <dt class="col-sm-3">Code</dt>
    <dd class="col-sm-9">@Model.Department.Code</dd>

    <dt class="col-sm-3">Name</dt>
    <dd class="col-sm-9">@Model.Department.Name</dd>

    <dt class="col-sm-3">Active</dt>
    <dd class="col-sm-9">@(Model.Department.IsActive ? "Yes" : "No")</dd>
</dl>

<a class="btn btn-primary" asp-page="./Edit" asp-route-id="@Model.Department.Id">Edit</a>
<a class="btn btn-outline-secondary" asp-page="./Index">Back</a>
