@page "{id:int}"
@model Vantage.PMS.Pages.Admin.Departments.DeleteModel

@{
    ViewData["Title"] = "Delete Department";
}

<h1>Delete Department</h1>
<p class="text-danger">Are you sure you want to delete this department?</p>

<dl class="row mt-3">
    <dt class="col-sm-3">Property</dt>
    <dd class="col-sm-9">@Model.Department.Property?.Name</dd>

    <dt class="col-sm-3">Code</dt>
    <dd class="col-sm-9">@Model.Department.Code</dd>

    <dt class="col-sm-3">Name</dt>
    <dd class="col-sm-9">@Model.Department.Name</dd>

    <dt class="col-sm-3">Active</dt>
    <dd class="col-sm-9">@(Model.Department.IsActive ? "Yes" : "No")</dd>
</dl>

<form method="post">
    <input type="hidden" asp-for="Department.Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a class="btn btn-outline-secondary" asp-page="./Index">Cancel</a>
</form>
