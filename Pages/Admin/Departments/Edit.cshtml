@page "{id:int}"
@model Vantage.PMS.Pages.Admin.Departments.EditModel

@{
    ViewData["Title"] = "Edit Department";
}

<h1>Edit Department</h1>

<form method="post" class="mt-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="Department.Id" />

    <div class="mb-3">
        <label asp-for="Department.PropertyId" class="form-label">Property</label>
        <select asp-for="Department.PropertyId" class="form-select" asp-items="Model.PropertyOptions"></select>
        <span asp-validation-for="Department.PropertyId" class="text-danger"></span>
    </div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <label asp-for="Department.Code" class="form-label"></label>
            <input asp-for="Department.Code" class="form-control" />
            <span asp-validation-for="Department.Code" class="text-danger"></span>
        </div>
        <div class="col-md-8 mb-3">
            <label asp-for="Department.Name" class="form-label"></label>
            <input asp-for="Department.Name" class="form-control" />
            <span asp-validation-for="Department.Name" class="text-danger"></span>
        </div>
    </div>

    <div class="form-check mb-3">
        <input asp-for="Department.IsActive" class="form-check-input" />
        <label asp-for="Department.IsActive" class="form-check-label">Active</label>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a class="btn btn-outline-secondary" asp-page="./Index">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
