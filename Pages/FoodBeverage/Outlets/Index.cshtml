@page
@model Vantage.PMS.Pages.FoodBeverage.Outlets.IndexModel

@{
    ViewData["Title"] = "Outlets";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="mb-1">Outlets</h1>
        <p class="text-muted mb-0">Restaurant, bar, cafe, room service, and banquet outlets.</p>
    </div>
    <a class="btn btn-primary" asp-page="./Create">Create Outlet</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>Name</th>
            <th>Type</th>
            <th>Active</th>
            <th class="text-end">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var outlet in Model.Outlets)
        {
            <tr>
                <td>@outlet.Name</td>
                <td>@outlet.OutletType</td>
                <td>@(outlet.IsActive ? "Yes" : "No")</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-primary" asp-page="./Edit" asp-route-id="@outlet.Id">Edit</a>
                    <a class="btn btn-sm btn-outline-danger" asp-page="./Delete" asp-route-id="@outlet.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
