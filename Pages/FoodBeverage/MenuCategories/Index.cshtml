@page
@model Vantage.PMS.Pages.FoodBeverage.MenuCategories.IndexModel

@{
    ViewData["Title"] = "Menu Categories";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="mb-1">Menu Categories</h1>
        <p class="text-muted mb-0">Menu grouping and display order.</p>
    </div>
    <a class="btn btn-primary" asp-page="./Create">Create Category</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th class="text-end">Sort</th>
            <th>Name</th>
            <th>Active</th>
            <th class="text-end">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var category in Model.MenuCategories)
        {
            <tr>
                <td class="text-end">@category.SortOrder</td>
                <td>@category.Name</td>
                <td>@(category.IsActive ? "Yes" : "No")</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-primary" asp-page="./Edit" asp-route-id="@category.Id">Edit</a>
                    <a class="btn btn-sm btn-outline-danger" asp-page="./Delete" asp-route-id="@category.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
