@page "{id:int}"
@model Vantage.PMS.Pages.FoodBeverage.MenuItems.DeleteModel

@{
    ViewData["Title"] = "Delete Menu Item";
}

<h1>Delete Menu Item</h1>

<div class="alert alert-warning">
    Delete menu item <strong>@Model.MenuItem.Name</strong>?
</div>

<dl class="row">
    <dt class="col-sm-2">Category</dt>
    <dd class="col-sm-10">@Model.MenuItem.MenuCategory?.Name</dd>
    <dt class="col-sm-2">Price</dt>
    <dd class="col-sm-10">@Model.MenuItem.Price.ToString("N2")</dd>
    <dt class="col-sm-2">Available</dt>
    <dd class="col-sm-10">@(Model.MenuItem.IsAvailable ? "Yes" : "No")</dd>
</dl>

<form method="post">
    <button type="submit" class="btn btn-danger">Delete</button>
    <a class="btn btn-outline-secondary" asp-page="./Index">Cancel</a>
</form>
