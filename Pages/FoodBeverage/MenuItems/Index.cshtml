@page
@model Vantage.PMS.Pages.FoodBeverage.MenuItems.IndexModel

@{
    ViewData["Title"] = "Menu Items";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="mb-1">Menu Items</h1>
        <p class="text-muted mb-0">Sellable food and beverage items.</p>
    </div>
    <a class="btn btn-primary" asp-page="./Create">Create Menu Item</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>Category</th>
            <th>Kitchen Station</th>
            <th>Name</th>
            <th class="text-end">Price</th>
            <th>Available</th>
            <th>Taxable</th>
            <th>Service Charge</th>
            <th class="text-end">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.MenuItems)
        {
            <tr>
                <td>@item.MenuCategory?.Name</td>
                <td>@(item.KitchenStation?.Name ?? "Unassigned")</td>
                <td>
                    <div>@item.Name</div>
                    <div class="text-muted small">@item.Description</div>
                </td>
                <td class="text-end">@item.Price.ToString("N2")</td>
                <td>@(item.IsAvailable ? "Yes" : "No")</td>
                <td>@(item.IsTaxable ? "Yes" : "No")</td>
                <td>@(item.IsServiceChargeable ? "Yes" : "No")</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-primary" asp-page="./Edit" asp-route-id="@item.Id">Edit</a>
                    <a class="btn btn-sm btn-outline-danger" asp-page="./Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
