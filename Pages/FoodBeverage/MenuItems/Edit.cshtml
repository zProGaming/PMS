@page "{id:int}"
@model Vantage.PMS.Pages.FoodBeverage.MenuItems.EditModel

@{
    ViewData["Title"] = "Edit Menu Item";
}

<h1>Edit Menu Item</h1>

<form method="post" class="mt-3">
    <input type="hidden" asp-for="MenuItem.Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="MenuItem.MenuCategoryId" class="form-label">Category</label>
            <select asp-for="MenuItem.MenuCategoryId" class="form-select" asp-items="Model.CategoryOptions"></select>
            <span asp-validation-for="MenuItem.MenuCategoryId" class="text-danger"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="MenuItem.Name" class="form-label"></label>
            <input asp-for="MenuItem.Name" class="form-control" />
            <span asp-validation-for="MenuItem.Name" class="text-danger"></span>
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="MenuItem.KitchenStationId" class="form-label">Kitchen Station</label>
        <select asp-for="MenuItem.KitchenStationId" class="form-select" asp-items="Model.KitchenStationOptions">
            <option value="">Unassigned</option>
        </select>
        <span asp-validation-for="MenuItem.KitchenStationId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="MenuItem.Description" class="form-label"></label>
        <textarea asp-for="MenuItem.Description" class="form-control" rows="2"></textarea>
        <span asp-validation-for="MenuItem.Description" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="MenuItem.Price" class="form-label"></label>
        <input asp-for="MenuItem.Price" class="form-control" />
        <span asp-validation-for="MenuItem.Price" class="text-danger"></span>
    </div>

    <div class="d-flex flex-wrap gap-3 mb-3">
        <div class="form-check">
            <input asp-for="MenuItem.IsAvailable" class="form-check-input" />
            <label asp-for="MenuItem.IsAvailable" class="form-check-label">Available</label>
        </div>
        <div class="form-check">
            <input asp-for="MenuItem.IsTaxable" class="form-check-input" />
            <label asp-for="MenuItem.IsTaxable" class="form-check-label">Taxable</label>
        </div>
        <div class="form-check">
            <input asp-for="MenuItem.IsServiceChargeable" class="form-check-input" />
            <label asp-for="MenuItem.IsServiceChargeable" class="form-check-label">Service chargeable</label>
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a class="btn btn-outline-secondary" asp-page="./Index">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
