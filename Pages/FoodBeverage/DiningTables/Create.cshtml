@page
@model Vantage.PMS.Pages.FoodBeverage.DiningTables.CreateModel

@{
    ViewData["Title"] = "Create Dining Table";
}

<h1>Create Dining Table</h1>

<form method="post" class="mt-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="DiningTable.OutletId" class="form-label">Outlet</label>
            <select asp-for="DiningTable.OutletId" class="form-select" asp-items="Model.OutletOptions"></select>
            <span asp-validation-for="DiningTable.OutletId" class="text-danger"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="DiningTable.TableName" class="form-label">Table Name</label>
            <input asp-for="DiningTable.TableName" class="form-control" />
            <span asp-validation-for="DiningTable.TableName" class="text-danger"></span>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="DiningTable.SeatingCapacity" class="form-label">Seating Capacity</label>
            <input asp-for="DiningTable.SeatingCapacity" class="form-control" />
            <span asp-validation-for="DiningTable.SeatingCapacity" class="text-danger"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="DiningTable.Status" class="form-label"></label>
            <select asp-for="DiningTable.Status" class="form-select" asp-items="Model.StatusOptions"></select>
            <span asp-validation-for="DiningTable.Status" class="text-danger"></span>
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Create</button>
    <a class="btn btn-outline-secondary" asp-page="./Index">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
