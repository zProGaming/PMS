@page
@model Vantage.PMS.Pages.FoodBeverage.Orders.VoidItemModel

@{
    ViewData["Title"] = "Void Order Item";
}

<h1>Void Item</h1>

<div class="alert alert-warning">
    Void <strong>@Model.OrderItem.MenuItem?.Name</strong> from order <strong>@Model.OrderItem.POSOrder?.OrderNumber</strong>?
</div>

<dl class="row">
    <dt class="col-sm-2">Quantity</dt>
    <dd class="col-sm-10">@Model.OrderItem.Quantity.ToString("N2")</dd>
    <dt class="col-sm-2">Line Total</dt>
    <dd class="col-sm-10">@Model.OrderItem.LineTotal.ToString("N2")</dd>
</dl>

<form method="post" asp-route-orderItemId="@Model.OrderItem.Id">
    <button type="submit" class="btn btn-danger">Void Item</button>
    <a class="btn btn-outline-secondary" asp-page="./Details" asp-route-id="@Model.OrderItem.POSOrderId">Cancel</a>
</form>
