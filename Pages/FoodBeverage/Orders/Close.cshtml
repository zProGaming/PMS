@page "{id:int}"
@model Vantage.PMS.Pages.FoodBeverage.Orders.CloseModel

@{
    ViewData["Title"] = "Close POS Order";
    var isNativeWorkflow = string.Equals(HttpContext.Request.Query["vpmsNative"], "1", StringComparison.OrdinalIgnoreCase);
}

@if (isNativeWorkflow)
{
    <section class="vpms-native-modal-intro vpms-native-pos-intro">
        <div>
            <div class="page-kicker">F&amp;B Settlement</div>
            <h1>Close Order @Model.Order.OrderNumber</h1>
            <p>@Model.Order.Outlet?.Name | @Model.Order.OrderType | @Model.Order.PaymentStatus</p>
        </div>
        <div class="vpms-native-balance-pill">
            <span>Total Due</span>
            <strong>@Model.Order.TotalAmount.ToString("C")</strong>
        </div>
    </section>
}
else
{
    <h1>Close Order @Model.Order.OrderNumber</h1>
}

<div class="row g-3 mb-4 @(isNativeWorkflow ? "vpms-native-summary-row" : "")">
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Outlet</div>
            <div class="fs-5">@Model.Order.Outlet?.Name</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Order Type</div>
            <div class="fs-5">@Model.Order.OrderType</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Payment Status</div>
            <div class="fs-5">@Model.Order.PaymentStatus</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Total</div>
            <div class="fs-5">@Model.Order.TotalAmount.ToString("C")</div>
        </div>
    </div>
</div>

<form method="post" class="@(isNativeWorkflow ? "vpms-native-workflow-form vpms-native-pos-form" : "mt-3")">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    @if (isNativeWorkflow)
    {
        <div class="vpms-native-step-grid compact" aria-label="Settlement controls">
            <span><strong>Cash/Card</strong><small>Settle immediately</small></span>
            <span><strong>E-wallet</strong><small>Trace reference</small></span>
            <span><strong>Room Charge</strong><small>In-house folio only</small></span>
        </div>
    }

    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="SettlementMethod" class="form-label">Close As</label>
            <select asp-for="SettlementMethod" class="form-select" asp-items="Model.SettlementMethodOptions"></select>
            <span asp-validation-for="SettlementMethod" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="SelectedReservationId" class="form-label">Checked-in Guest / Reservation</label>
            <select asp-for="SelectedReservationId" class="form-select" asp-items="Model.ReservationOptions">
                <option value="">Not assigned</option>
            </select>
            <span asp-validation-for="SelectedReservationId" class="text-danger"></span>
        </div>
    </div>

    <div class="alert alert-info">
        Charge to room creates a folio charge for checked-in reservations only.
    </div>

    <div class="vpms-native-action-row">
        <a class="btn btn-outline-secondary" asp-page="./Details" asp-route-id="@Model.Order.Id">Cancel</a>
        <button type="submit" class="btn btn-success">Close Order</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
