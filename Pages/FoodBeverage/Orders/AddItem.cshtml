@page
@model Vantage.PMS.Pages.FoodBeverage.Orders.AddItemModel

@{
    ViewData["Title"] = "Add Order Item";
}

<h1>Add Item</h1>
<p class="text-muted">Order @Model.OrderNumber</p>

<form method="post" asp-route-orderId="@Model.OrderId" class="mt-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="OrderItem.MenuItemId" class="form-label">Menu Item</label>
            <select asp-for="OrderItem.MenuItemId" class="form-select" asp-items="Model.MenuItemOptions"></select>
            <span asp-validation-for="OrderItem.MenuItemId" class="text-danger"></span>
        </div>
        <div class="col-md-3 mb-3">
            <label asp-for="OrderItem.Quantity" class="form-label"></label>
            <input asp-for="OrderItem.Quantity" class="form-control" />
            <span asp-validation-for="OrderItem.Quantity" class="text-danger"></span>
        </div>
        <div class="col-md-3 mb-3">
            <label asp-for="OrderItem.DiscountAmount" class="form-label">Discount</label>
            <input asp-for="OrderItem.DiscountAmount" class="form-control" />
            <span asp-validation-for="OrderItem.DiscountAmount" class="text-danger"></span>
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="OrderItem.Notes" class="form-label"></label>
        <textarea asp-for="OrderItem.Notes" class="form-control" rows="2"></textarea>
        <span asp-validation-for="OrderItem.Notes" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Add Item</button>
    <a class="btn btn-outline-secondary" asp-page="./Details" asp-route-id="@Model.OrderId">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
