@page
@model Vantage.PMS.Pages.FoodBeverage.Orders.IndexModel

@{
    ViewData["Title"] = "POS Orders";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="mb-1">POS Orders</h1>
        <p class="text-muted mb-0">Open and recently closed F&amp;B orders.</p>
    </div>
    <a class="btn btn-primary" asp-page="./Create">New Order</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>Order</th>
            <th>Date</th>
            <th>Outlet</th>
            <th>Type</th>
            <th>Table</th>
            <th>Guest</th>
            <th>Status</th>
            <th>Payment</th>
            <th class="text-end">Total</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var order in Model.Orders)
        {
            <tr>
                <td><a asp-page="./Details" asp-route-id="@order.Id">@order.OrderNumber</a></td>
                <td>@order.OrderDate.ToString("g")</td>
                <td>@order.Outlet?.Name</td>
                <td>@order.OrderType</td>
                <td>@(order.DiningTable?.TableName ?? "-")</td>
                <td>@order.Guest?.FirstName @order.Guest?.LastName</td>
                <td>@order.OrderStatus</td>
                <td>@order.PaymentStatus</td>
                <td class="text-end">@order.TotalAmount.ToString("N2")</td>
            </tr>
        }
    </tbody>
</table>
