@page
@model Vantage.PMS.Pages.FoodBeverage.Orders.IndexModel
@using Vantage.PMS.Models.FoodBeverage

@{
    ViewData["Title"] = "POS Orders";
    var openOrders = Model.Orders.Count(order => order.OrderStatus == POSOrderStatus.Open);
    var closedOrders = Model.Orders.Count(order => order.OrderStatus == POSOrderStatus.Closed);
    var paidOrders = Model.Orders.Count(order => order.PaymentStatus == POSPaymentStatus.Paid);
    var totalPosted = Model.Orders.Sum(order => order.TotalAmount);
}

<section class="vpms-ops-hero vpms-ops-hero-compact">
    <div>
        <div class="page-kicker">F&amp;B Service POS</div>
        <h1 class="page-title">POS Orders</h1>
        <p class="page-subtitle">Open checks, room charges, kitchen handoff, and recently closed outlet orders.</p>
    </div>
    <div class="vpms-hero-actions">
        <a class="btn vpms-btn-secondary" asp-page="/FoodBeverageKitchen/Index">Kitchen Display</a>
        <a class="btn vpms-btn-primary" asp-page="./Create" data-vpms-native-dialog data-vpms-native-handler="Native" data-vpms-native-dialog-title="Create POS Order">New Order</a>
    </div>
</section>

<section class="vpms-control-strip" aria-label="POS operating pulse">
    <article class="@(openOrders > 0 ? "warning" : "positive")">
        <span>Open Checks</span>
        <strong>@openOrders</strong>
        <small>Need service or settlement</small>
    </article>
    <article>
        <span>Closed Orders</span>
        <strong>@closedOrders</strong>
        <small>Recently completed</small>
    </article>
    <article class="positive">
        <span>Paid Orders</span>
        <strong>@paidOrders</strong>
        <small>Settled checks</small>
    </article>
    <article>
        <span>Register Total</span>
        <strong>@totalPosted.ToString("C")</strong>
        <small>Latest @Model.Orders.Count order@(Model.Orders.Count == 1 ? "" : "s")</small>
    </article>
</section>

<section class="vpms-card vpms-operational-panel">
    <div class="vpms-section-titlebar">
        <div>
            <h2>Outlet Order Board</h2>
            <p>Open order details in a dialog, add items, close checks, and keep the POS board in context.</p>
        </div>
    </div>

    @if (Model.Orders.Count == 0)
    {
        <div class="vpms-empty-state">
            <strong>No POS orders found.</strong>
            <span>Create a new outlet order or seed demo data to populate the F&amp;B service board.</span>
        </div>
    }
    else
    {
        <div class="vpms-table-wrapper">
            <table class="table vpms-table align-middle">
                <thead>
                    <tr>
                        <th>Order</th>
                        <th>Date</th>
                        <th>Outlet</th>
                        <th>Table / Guest</th>
                        <th>Status</th>
                        <th>Payment</th>
                        <th class="text-end">Total</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model.Orders)
                    {
                        var orderStatusClass = order.OrderStatus.ToString().ToLowerInvariant();
                        var paymentStatusClass = order.PaymentStatus.ToString().ToLowerInvariant();
                        <tr>
                            <td>
                                <a class="vpms-primary-cell"
                                   asp-page="./Details"
                                   asp-route-id="@order.Id"
                                   data-vpms-dialog
                                   data-vpms-dialog-title="POS Order Control">@order.OrderNumber</a>
                                <div class="vpms-muted-line">@order.OrderType</div>
                            </td>
                            <td>@order.OrderDate.ToString("MMM d, h:mm tt")</td>
                            <td>@(order.Outlet?.Name ?? "Outlet pending")</td>
                            <td>
                                <div class="vpms-primary-cell">@(order.DiningTable?.TableName ?? "No table")</div>
                                <div class="vpms-muted-line">@($"{order.Guest?.FirstName} {order.Guest?.LastName}".Trim())</div>
                            </td>
                            <td><span class="vpms-status-badge status-@orderStatusClass">@order.OrderStatus</span></td>
                            <td><span class="vpms-status-badge status-@paymentStatusClass">@order.PaymentStatus</span></td>
                            <td class="text-end vpms-money">@order.TotalAmount.ToString("C")</td>
                            <td class="text-end">
                                <div class="vpms-row-actions">
                                    <a class="btn btn-sm vpms-btn-secondary"
                                       asp-page="./Details"
                                       asp-route-id="@order.Id"
                                       data-vpms-dialog
                                       data-vpms-dialog-title="POS Order Control">Open</a>
                                    @if (order.OrderStatus == POSOrderStatus.Open)
                                    {
                                        <a class="btn btn-sm btn-success"
                                           asp-page="./Close"
                                           asp-route-id="@order.Id"
                                           data-vpms-native-dialog
                                           data-vpms-native-handler="Native"
                                           data-vpms-native-dialog-title="Close POS Order">Close</a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
