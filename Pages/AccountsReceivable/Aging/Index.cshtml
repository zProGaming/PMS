@page
@model Vantage.PMS.Pages.AccountsReceivable.Aging.IndexModel
@{
    ViewData["Title"] = "AR Aging Report";
}

<div class="vpms-report-page">
    <div class="vpms-page-header vpms-print-hide">
        <div>
            <div class="page-kicker">Accounts Receivable</div>
            <h1 class="vpms-page-title">AR Aging Report</h1>
            <p class="vpms-page-subtitle">Invoice-level aging, collection risk, and open city ledger exposure as of a selected date.</p>
        </div>
        <div class="vpms-actions">
            <a class="btn vpms-btn-secondary"
               asp-page="/AccountsReceivable/ARPayments/Index"
               data-vpms-dialog
               data-vpms-dialog-title="Post or Allocate AR Payment">AR Payments</a>
            <a class="btn vpms-btn-secondary"
               asp-page="/AccountsReceivable/Statements/Index"
               data-vpms-dialog
               data-vpms-dialog-title="Statement of Account">SOA</a>
            <button type="button" class="btn vpms-btn-secondary" onclick="window.print()">Print</button>
            <button type="button" class="btn vpms-btn-secondary" onclick="window.print()">Save as PDF</button>
            <a class="btn vpms-btn-primary"
               asp-page-handler="Csv"
               asp-route-AsOfDate="@Model.AsOfDate.ToString("yyyy-MM-dd")"
               asp-route-ARAccountId="@Model.ARAccountId"
               asp-route-Status="@Model.Status"
               asp-route-AgingBucket="@Model.AgingBucket"
               asp-route-Search="@Model.Search"
               asp-route-IncludePaid="@Model.IncludePaid">Export CSV</a>
        </div>
    </div>

    <section class="vpms-report-filters vpms-card mb-4 vpms-print-hide">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-2">
                <label asp-for="AsOfDate" class="form-label">As Of Date</label>
                <input asp-for="AsOfDate" class="form-control" type="date" asp-format="{0:yyyy-MM-dd}" />
            </div>
            <div class="col-md-3">
                <label asp-for="ARAccountId" class="form-label">AR Account</label>
                <select asp-for="ARAccountId" asp-items="Model.ARAccountOptions" class="form-select">
                    <option value="">All accounts</option>
                </select>
            </div>
            <div class="col-md-2">
                <label asp-for="Status" class="form-label">Status</label>
                <select asp-for="Status" asp-items="Model.StatusOptions" class="form-select">
                    <option value="">All statuses</option>
                </select>
            </div>
            <div class="col-md-2">
                <label asp-for="AgingBucket" class="form-label">Aging Bucket</label>
                <select asp-for="AgingBucket" asp-items="Model.AgingBucketOptions" class="form-select">
                    <option value="">All buckets</option>
                </select>
            </div>
            <div class="col-md-3">
                <label asp-for="Search" class="form-label">Search</label>
                <input asp-for="Search" class="form-control" placeholder="Company or invoice number" />
            </div>
            <div class="col-md-3">
                <div class="form-check">
                    <input asp-for="IncludePaid" class="form-check-input" />
                    <label asp-for="IncludePaid" class="form-check-label">Include fully paid invoices</label>
                </div>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button class="btn vpms-btn-primary flex-fill" type="submit">Generate</button>
                <a class="btn vpms-btn-secondary flex-fill" asp-page="./Index">Reset</a>
            </div>
        </form>
    </section>

    <section class="vpms-print-document">
        <header class="vpms-report-header">
            <div>
                <div class="vpms-report-brand">Vantage PMS</div>
                <h2 class="vpms-report-title">AR Aging Report</h2>
                <div class="vpms-report-meta">
                    <span>As of @Model.AsOfDate.ToString("MMMM d, yyyy")</span>
                    <span>Generated @DateTime.Now.ToString("g")</span>
                    <span>Generated by @(User.Identity?.Name ?? "System")</span>
                </div>
            </div>
        </header>

        <div class="row g-3 mb-4">
            <div class="col-md-2"><div class="kpi-card"><div class="kpi-label">Current</div><div class="kpi-value">@Model.Report.Summary.Current.ToString("C")</div></div></div>
            <div class="col-md-2"><div class="kpi-card"><div class="kpi-label">1-30 Days</div><div class="kpi-value">@Model.Report.Summary.Days1To30.ToString("C")</div></div></div>
            <div class="col-md-2"><div class="kpi-card"><div class="kpi-label">31-60 Days</div><div class="kpi-value">@Model.Report.Summary.Days31To60.ToString("C")</div></div></div>
            <div class="col-md-2"><div class="kpi-card"><div class="kpi-label">61-90 Days</div><div class="kpi-value">@Model.Report.Summary.Days61To90.ToString("C")</div></div></div>
            <div class="col-md-2"><div class="kpi-card"><div class="kpi-label">Over 90 Days</div><div class="kpi-value">@Model.Report.Summary.Over90.ToString("C")</div></div></div>
            <div class="col-md-2"><div class="kpi-card"><div class="kpi-label">Total AR</div><div class="kpi-value">@Model.Report.Summary.Total.ToString("C")</div></div></div>
        </div>

        @if (Model.Report.Rows.Count == 0)
        {
            <section class="vpms-empty-state">
                <strong>No AR invoices found.</strong>
                <span>No records matched the selected aging filters. Create AR invoices, seed demo data, or adjust the report criteria.</span>
            </section>
        }
        else
        {
            <div class="table-responsive">
                <table class="table vpms-report-table align-middle">
                    <thead>
                        <tr>
                            <th>AR Account</th>
                            <th>Invoice</th>
                            <th>Invoice Date</th>
                            <th>Due Date</th>
                            <th class="text-end">Original</th>
                            <th class="text-end">Payments</th>
                            <th class="text-end">Credit Memos</th>
                            <th class="text-end">Debit Memos</th>
                            <th class="text-end">Balance</th>
                            <th>Bucket</th>
                            <th class="text-end">Days</th>
                            <th>Last Payment</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Report.Rows)
                        {
                            <tr>
                                <td>@row.AccountName</td>
                                <td>@row.InvoiceNumber</td>
                                <td>@row.InvoiceDate.ToString("d")</td>
                                <td>@row.DueDate.ToString("d")</td>
                                <td class="text-end">@row.OriginalAmount.ToString("C")</td>
                                <td class="text-end">@row.PaymentsApplied.ToString("C")</td>
                                <td class="text-end">@row.CreditMemos.ToString("C")</td>
                                <td class="text-end">@row.DebitMemos.ToString("C")</td>
                                <td class="text-end fw-semibold">@row.Balance.ToString("C")</td>
                                <td><span class="vpms-badge">@row.AgingBucket</span></td>
                                <td class="text-end">@row.DaysOverdue</td>
                                <td>@(row.LastPaymentDate?.ToString("d") ?? "-")</td>
                                <td>@row.Status</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <th colspan="8">Grand Total</th>
                            <th class="text-end">@Model.Report.TotalBalance.ToString("C")</th>
                            <th colspan="4"></th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        }

        <footer class="vpms-report-footer">
            Accounts receivable aging is generated from AR invoices, allocations, and applied memos. Review collection status with authorized finance personnel before external release.
        </footer>
    </section>
</div>
