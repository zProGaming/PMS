@page
@model Vantage.PMS.Pages.AccountsReceivable.ARInvoices.IndexModel
@{
    ViewData["Title"] = "AR Invoices";
}

<div class="page-header">
    <div>
        <div class="page-kicker">Accounts Receivable</div>
        <h1 class="page-title">AR Invoices</h1>
        <p class="page-subtitle">City ledger invoices, balances, and collection-ready AR documents.</p>
    </div>
    <div class="page-actions">
        <a class="btn vpms-btn-primary"
           asp-page="./Index"
           data-vpms-native-dialog
           data-vpms-native-handler="Native"
           data-vpms-native-dialog-title="Create AR Invoice">Create AR Invoice</a>
    </div>
</div>

<form method="post" asp-page-handler="Create" class="row g-3 border rounded p-3 mb-4">
    <div class="col-md-3"><label asp-for="Invoice.InvoiceNumber" class="form-label"></label><input asp-for="Invoice.InvoiceNumber" class="form-control" readonly /></div>
    <div class="col-md-3"><label asp-for="Invoice.ARAccountId" class="form-label">AR Account</label><select asp-for="Invoice.ARAccountId" asp-items="Model.ARAccountOptions" class="form-select"></select></div>
    <div class="col-md-3"><label asp-for="Invoice.FinanceDocumentId" class="form-label">Finance Document</label><select asp-for="Invoice.FinanceDocumentId" asp-items="Model.FinanceDocumentOptions" class="form-select"><option value="">None</option></select></div>
    <div class="col-md-3"><label asp-for="Invoice.OriginalAmount" class="form-label"></label><input asp-for="Invoice.OriginalAmount" class="form-control" /></div>
    <div class="col-md-3"><label asp-for="Invoice.InvoiceDate" class="form-label"></label><input asp-for="Invoice.InvoiceDate" type="date" class="form-control" /></div>
    <div class="col-md-3"><label asp-for="Invoice.DueDate" class="form-label"></label><input asp-for="Invoice.DueDate" type="date" class="form-control" /></div>
    <div class="col-md-6"><label asp-for="Invoice.Notes" class="form-label"></label><input asp-for="Invoice.Notes" class="form-control" /></div>
    <div class="col-12"><button class="btn btn-primary">Create Invoice</button></div>
</form>

<div class="vpms-table-wrapper">
    <table class="table table-striped table-hover align-middle mb-0">
        <thead><tr><th>Invoice #</th><th>Account</th><th>Date</th><th>Due</th><th>Status</th><th class="text-end">Original</th><th class="text-end">Paid</th><th class="text-end">Balance</th></tr></thead>
        <tbody>
            @if (!Model.Invoices.Any())
            {
                <tr class="vpms-empty-row">
                    <td colspan="8">
                        <section class="vpms-empty-state vpms-empty-state-table">
                            <strong>No AR invoices found.</strong>
                            <span>Create an AR invoice when a city ledger balance is ready for collection tracking and aging control.</span>
                        </section>
                    </td>
                </tr>
            }
            else
            {
                @foreach (var invoice in Model.Invoices)
                {
                    <tr>
                        <td>@invoice.InvoiceNumber</td>
                        <td>@invoice.ARAccount?.AccountName</td>
                        <td>@invoice.InvoiceDate.ToString("d")</td>
                        <td>@invoice.DueDate.ToString("d")</td>
                        <td><span class="badge text-bg-secondary">@invoice.Status</span></td>
                        <td class="text-end">@invoice.OriginalAmount.ToString("C")</td>
                        <td class="text-end">@invoice.AmountPaid.ToString("C")</td>
                        <td class="text-end">@invoice.Balance.ToString("C")</td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
