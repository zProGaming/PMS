@page
@model Vantage.PMS.Pages.AccountsReceivable.Statements.IndexModel
@{
    ViewData["Title"] = "AR Statement of Account";
}

<h1 class="h3 mb-3">AR Statement of Account</h1>

<form method="get" class="row g-3 mb-4">
    <div class="col-md-6"><label asp-for="ARAccountId" class="form-label">AR Account</label><select asp-for="ARAccountId" asp-items="Model.AccountOptions" class="form-select"><option value="">Select account</option></select></div>
    <div class="col-md-2 align-self-end"><button class="btn btn-primary">View</button></div>
</form>

@if (Model.Account is not null)
{
    <div class="row g-3 mb-4">
        <div class="col-md-4"><div class="border rounded p-3"><div class="text-muted">Account</div><strong>@Model.Account.AccountName</strong></div></div>
        <div class="col-md-4"><div class="border rounded p-3"><div class="text-muted">Credit Limit</div><strong>@Model.Account.CreditLimit.ToString("C")</strong></div></div>
        <div class="col-md-4"><div class="border rounded p-3"><div class="text-muted">Current Balance</div><strong>@Model.Account.CurrentBalance.ToString("C")</strong></div></div>
    </div>

    <h2 class="h5">Invoices</h2>
    <table class="table table-sm table-striped">
        <thead><tr><th>Invoice</th><th>Date</th><th>Due</th><th>Status</th><th class="text-end">Original</th><th class="text-end">Paid</th><th class="text-end">Balance</th></tr></thead>
        <tbody>
            @foreach (var invoice in Model.Invoices)
            {
                <tr>
                    <td>@invoice.InvoiceNumber</td>
                    <td>@invoice.InvoiceDate.ToString("d")</td>
                    <td>@invoice.DueDate.ToString("d")</td>
                    <td>@invoice.Status</td>
                    <td class="text-end">@invoice.OriginalAmount.ToString("C")</td>
                    <td class="text-end">@invoice.AmountPaid.ToString("C")</td>
                    <td class="text-end">@invoice.Balance.ToString("C")</td>
                </tr>
            }
        </tbody>
    </table>

    <h2 class="h5 mt-4">Payments</h2>
    <table class="table table-sm table-striped">
        <thead><tr><th>Date</th><th>Method</th><th>Reference</th><th class="text-end">Amount</th><th class="text-end">Allocated</th></tr></thead>
        <tbody>
            @foreach (var payment in Model.Payments)
            {
                <tr>
                    <td>@payment.PaymentDate.ToString("d")</td>
                    <td>@payment.PaymentMethod</td>
                    <td>@payment.ReferenceNumber</td>
                    <td class="text-end">@payment.Amount.ToString("C")</td>
                    <td class="text-end">@payment.Allocations.Sum(item => item.AllocatedAmount).ToString("C")</td>
                </tr>
            }
        </tbody>
    </table>
}
