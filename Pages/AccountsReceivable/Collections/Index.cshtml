@page
@model Vantage.PMS.Pages.AccountsReceivable.Collections.IndexModel
@{
    ViewData["Title"] = Model.ReportTitle;
    string Percent(decimal? value) => value is null ? "N/A" : value.Value.ToString("N2") + "%";
    string Dso(decimal? value) => value is null ? "N/A" : value.Value.ToString("N1");
}

<div class="vpms-report-page">
    <div class="vpms-page-header vpms-print-hide">
        <div>
            <div class="page-kicker">Accounts Receivable</div>
            <h1 class="vpms-page-title">@Model.ReportTitle</h1>
            <p class="vpms-page-subtitle">Opening AR, billings, collections, memos, ending AR, and collection risk for hotel finance review.</p>
        </div>
        <div class="vpms-actions">
            <a class="btn vpms-btn-secondary"
               asp-page="/AccountsReceivable/ARPayments/Index"
               data-vpms-native-dialog
               data-vpms-native-handler="Native"
               data-vpms-native-dialog-title="Post AR Payment">AR Payments</a>
            <a class="btn vpms-btn-secondary"
               asp-page="/AccountsReceivable/Aging/Index"
               data-vpms-dialog
               data-vpms-dialog-title="AR Aging Report">AR Aging</a>
            <button type="button" class="btn vpms-btn-secondary" onclick="window.print()">Print</button>
            <button type="button" class="btn vpms-btn-secondary" onclick="window.print()">Save as PDF</button>
            <a class="btn vpms-btn-primary"
               asp-page-handler="Csv"
               asp-route-Period="@Model.Period"
               asp-route-DateFrom="@Model.DateFrom?.ToString("yyyy-MM-dd")"
               asp-route-DateTo="@Model.DateTo?.ToString("yyyy-MM-dd")"
               asp-route-ARAccountId="@Model.ARAccountId"
               asp-route-Status="@Model.Status">Export CSV</a>
        </div>
    </div>

    <section class="vpms-report-filters vpms-card mb-4 vpms-print-hide">
        <div class="d-flex flex-wrap gap-2 mb-3">
            <a class="btn @(Model.Period == "daily" ? "vpms-btn-primary" : "vpms-btn-secondary") btn-sm" asp-page="./Index" asp-route-Period="daily">Daily</a>
            <a class="btn @(Model.Period == "weekly" ? "vpms-btn-primary" : "vpms-btn-secondary") btn-sm" asp-page="./Index" asp-route-Period="weekly">Weekly</a>
            <a class="btn @(Model.Period == "monthly" ? "vpms-btn-primary" : "vpms-btn-secondary") btn-sm" asp-page="./Index" asp-route-Period="monthly">Monthly</a>
            <a class="btn @(Model.Period == "custom" ? "vpms-btn-primary" : "vpms-btn-secondary") btn-sm" asp-page="./Index" asp-route-Period="custom">Custom</a>
        </div>
        <form method="get" class="row g-3 align-items-end">
            <input type="hidden" asp-for="Period" />
            <div class="col-md-2">
                <label asp-for="DateFrom" class="form-label">Date From</label>
                <input asp-for="DateFrom" class="form-control" type="date" asp-format="{0:yyyy-MM-dd}" />
            </div>
            <div class="col-md-2">
                <label asp-for="DateTo" class="form-label">Date To</label>
                <input asp-for="DateTo" class="form-control" type="date" asp-format="{0:yyyy-MM-dd}" />
            </div>
            <div class="col-md-3">
                <label asp-for="ARAccountId" class="form-label">AR Account</label>
                <select asp-for="ARAccountId" asp-items="Model.ARAccountOptions" class="form-select">
                    <option value="">All accounts</option>
                </select>
            </div>
            <div class="col-md-2">
                <label asp-for="Status" class="form-label">Invoice Status</label>
                <select asp-for="Status" asp-items="Model.StatusOptions" class="form-select">
                    <option value="">All statuses</option>
                </select>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button class="btn vpms-btn-primary flex-fill" type="submit">Generate</button>
                <a class="btn vpms-btn-secondary flex-fill" asp-page="./Index" asp-route-Period="@Model.Period">Reset</a>
            </div>
        </form>
    </section>

    <section class="vpms-print-document">
        <header class="vpms-report-header">
            <div>
                <div class="vpms-report-brand">Vantage PMS</div>
                <h2 class="vpms-report-title">@Model.ReportTitle</h2>
                <div class="vpms-report-meta">
                    <span>@Model.Report.PeriodStart.ToString("MMMM d, yyyy") to @Model.Report.PeriodEnd.ToString("MMMM d, yyyy")</span>
                    <span>Generated @DateTime.Now.ToString("g")</span>
                    <span>Generated by @(User.Identity?.Name ?? "System")</span>
                </div>
            </div>
        </header>

        <div class="row g-3 mb-4">
            <div class="col-md-3"><div class="kpi-card"><div class="kpi-label">Opening AR</div><div class="kpi-value">@Model.Report.OpeningAR.ToString("C")</div></div></div>
            <div class="col-md-3"><div class="kpi-card"><div class="kpi-label">Billings</div><div class="kpi-value">@Model.Report.Billings.ToString("C")</div></div></div>
            <div class="col-md-3"><div class="kpi-card"><div class="kpi-label">Collections</div><div class="kpi-value">@Model.Report.Collections.ToString("C")</div></div></div>
            <div class="col-md-3"><div class="kpi-card"><div class="kpi-label">Ending AR</div><div class="kpi-value">@Model.Report.EndingAR.ToString("C")</div></div></div>
            <div class="col-md-3"><div class="kpi-card"><div class="kpi-label">Overdue AR</div><div class="kpi-value">@Model.Report.OverdueAR.ToString("C")</div></div></div>
            <div class="col-md-3"><div class="kpi-card"><div class="kpi-label">Collection Rate</div><div class="kpi-value">@Percent(Model.Report.CollectionRate)</div></div></div>
            <div class="col-md-3"><div class="kpi-card"><div class="kpi-label">Credit Memos</div><div class="kpi-value">@Model.Report.CreditMemos.ToString("C")</div></div></div>
            <div class="col-md-3"><div class="kpi-card"><div class="kpi-label">DSO</div><div class="kpi-value">@Dso(Model.Report.DaysSalesOutstanding)</div></div></div>
        </div>

        <section class="vpms-card mb-4">
            <h3 class="h6 mb-3">Collection Formula</h3>
            <div class="table-responsive">
                <table class="table vpms-report-table align-middle">
                    <tbody>
                        <tr><th>Opening AR</th><td class="text-end">@Model.Report.OpeningAR.ToString("C")</td></tr>
                        <tr><th>+ Billings</th><td class="text-end">@Model.Report.Billings.ToString("C")</td></tr>
                        <tr><th>+ Debit Memos</th><td class="text-end">@Model.Report.DebitMemos.ToString("C")</td></tr>
                        <tr><th>- Collections</th><td class="text-end">@Model.Report.Collections.ToString("C")</td></tr>
                        <tr><th>- Credit Memos</th><td class="text-end">@Model.Report.CreditMemos.ToString("C")</td></tr>
                        <tr><th>+/- Adjustments</th><td class="text-end">@Model.Report.Adjustments.ToString("C")</td></tr>
                        <tr><th>Ending AR</th><td class="text-end fw-semibold">@Model.Report.EndingAR.ToString("C")</td></tr>
                    </tbody>
                </table>
            </div>
        </section>

        @if (Model.Report.OpeningAR == 0 && Model.Report.Billings == 0 && Model.Report.Collections == 0 && Model.Report.EndingAR == 0)
        {
            <section class="vpms-empty-state mb-4">
                <strong>No AR collection activity found.</strong>
                <span>No invoices, payments, or applied memos matched this period. Seed demo data or create AR transactions to populate the report.</span>
            </section>
        }

        <div class="row g-4">
            <div class="col-lg-6">
                <section class="vpms-card h-100">
                    <h3 class="h6 mb-3">Top Collected Accounts</h3>
                    @if (Model.Report.TopCollectedAccounts.Count == 0)
                    {
                        <p class="text-muted mb-0">No collections recorded for this period.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table vpms-report-table align-middle">
                                <thead><tr><th>Account</th><th class="text-end">Collected</th><th>Last Payment</th></tr></thead>
                                <tbody>
                                    @foreach (var row in Model.Report.TopCollectedAccounts)
                                    {
                                        <tr><td>@row.AccountName</td><td class="text-end">@row.Amount.ToString("C")</td><td>@(row.LastPaymentDate?.ToString("d") ?? "-")</td></tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </section>
            </div>
            <div class="col-lg-6">
                <section class="vpms-card h-100">
                    <h3 class="h6 mb-3">Top Overdue Accounts</h3>
                    @if (Model.Report.TopOverdueAccounts.Count == 0)
                    {
                        <p class="text-muted mb-0">No overdue AR found as of the selected period end.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table vpms-report-table align-middle">
                                <thead><tr><th>Account</th><th class="text-end">Overdue</th><th>Last Payment</th></tr></thead>
                                <tbody>
                                    @foreach (var row in Model.Report.TopOverdueAccounts)
                                    {
                                        <tr><td>@row.AccountName</td><td class="text-end">@row.Amount.ToString("C")</td><td>@(row.LastPaymentDate?.ToString("d") ?? "-")</td></tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </section>
            </div>
            <div class="col-lg-6">
                <section class="vpms-card h-100">
                    <h3 class="h6 mb-3">Payments by Method</h3>
                    @if (Model.Report.PaymentsByMethod.Count == 0)
                    {
                        <p class="text-muted mb-0">No AR payments were allocated in this period.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table vpms-report-table align-middle">
                                <thead><tr><th>Method</th><th class="text-end">Amount</th></tr></thead>
                                <tbody>
                                    @foreach (var row in Model.Report.PaymentsByMethod)
                                    {
                                        <tr><td>@row.PaymentMethod</td><td class="text-end">@row.Amount.ToString("C")</td></tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </section>
            </div>
            <div class="col-lg-6">
                <section class="vpms-card h-100">
                    <h3 class="h6 mb-3">Accounts With No Payment in 30 Days</h3>
                    @if (Model.Report.AccountsWithNoRecentPayment.Count == 0)
                    {
                        <p class="text-muted mb-0">No stale collection accounts found for this period.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table vpms-report-table align-middle">
                                <thead><tr><th>Account</th><th class="text-end">Open Balance</th><th>Last Payment</th></tr></thead>
                                <tbody>
                                    @foreach (var row in Model.Report.AccountsWithNoRecentPayment)
                                    {
                                        <tr><td>@row.AccountName</td><td class="text-end">@row.Amount.ToString("C")</td><td>@(row.LastPaymentDate?.ToString("d") ?? "No payment found")</td></tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </section>
            </div>
        </div>

        <section class="vpms-card mt-4">
            <h3 class="h6 mb-3">Collection Trend</h3>
            @if (Model.Report.CollectionTrend.Count == 0)
            {
                <p class="text-muted mb-0">No collections were allocated during this report period.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table vpms-report-table align-middle">
                        <thead><tr><th>Date</th><th class="text-end">Collections</th></tr></thead>
                        <tbody>
                            @foreach (var row in Model.Report.CollectionTrend)
                            {
                                <tr><td>@row.Date.ToString("D")</td><td class="text-end">@row.Collections.ToString("C")</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>

        <footer class="vpms-report-footer">
            AR collection reports are management tools generated from AR invoices, allocations, and applied memos. Review balances with authorized finance personnel before external release.
        </footer>
    </section>
</div>
