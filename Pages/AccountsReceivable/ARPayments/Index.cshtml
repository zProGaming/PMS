@page
@model Vantage.PMS.Pages.AccountsReceivable.ARPayments.IndexModel
@using Vantage.PMS.Models.Finance
@{
    ViewData["Title"] = "AR Payments";
}

<div class="page-header">
    <div>
        <div class="page-kicker">Accounts Receivable</div>
        <h1 class="page-title">AR Payments</h1>
        <p class="page-subtitle">Collections, allocation, and city ledger payment control.</p>
    </div>
    <div class="page-actions">
        <a class="btn vpms-btn-primary"
           asp-page="./Index"
           data-vpms-native-dialog
           data-vpms-native-handler="Native"
           data-vpms-native-dialog-title="Post AR Payment">Post AR Payment</a>
    </div>
</div>

<details class="vpms-refined-card vpms-inline-create-panel mb-4">
    <summary>Manual AR payment entry</summary>
<form method="post" asp-page-handler="Create" class="row g-3 mt-3">
    <div class="col-md-3"><label asp-for="Payment.ARAccountId" class="form-label">AR Account</label><select asp-for="Payment.ARAccountId" asp-items="Model.ARAccountOptions" class="form-select"></select></div>
    <div class="col-md-2"><label asp-for="Payment.PaymentDate" class="form-label"></label><input asp-for="Payment.PaymentDate" type="date" class="form-control" /></div>
    <div class="col-md-2"><label asp-for="Payment.Amount" class="form-label"></label><input asp-for="Payment.Amount" class="form-control" /></div>
    <div class="col-md-2"><label asp-for="Payment.PaymentMethod" class="form-label"></label><select asp-for="Payment.PaymentMethod" asp-items="Html.GetEnumSelectList<FinancePaymentMethod>()" class="form-select"></select></div>
    <div class="col-md-3"><label asp-for="Payment.ReferenceNumber" class="form-label"></label><input asp-for="Payment.ReferenceNumber" class="form-control" /></div>
    <div class="col-md-3"><label asp-for="Payment.ReceivedBy" class="form-label"></label><input asp-for="Payment.ReceivedBy" class="form-control" /></div>
    <div class="col-md-9"><label asp-for="Payment.Notes" class="form-label"></label><input asp-for="Payment.Notes" class="form-control" /></div>
    <div class="col-12"><button class="btn btn-primary">Post AR Payment</button></div>
</form>
</details>

<div class="vpms-table-wrapper">
    <table class="table table-striped table-hover align-middle mb-0">
        <thead><tr><th>Date</th><th>Account</th><th>Method</th><th>Reference</th><th class="text-end">Amount</th><th class="text-end">Allocated</th><th class="text-end">Remaining</th><th></th></tr></thead>
        <tbody>
            @if (!Model.Payments.Any())
            {
                <tr class="vpms-empty-row">
                    <td colspan="8">
                        <section class="vpms-empty-state vpms-empty-state-table">
                            <strong>No AR payments found.</strong>
                            <span>Post a collection when city ledger payments are received, then allocate it to open invoices.</span>
                        </section>
                    </td>
                </tr>
            }
            else
            {
                @foreach (var payment in Model.Payments)
                {
                    <tr>
                        <td>@payment.PaymentDate.ToString("d")</td>
                        <td>@payment.ARAccount?.AccountName</td>
                        <td>@payment.PaymentMethod</td>
                        <td>@payment.ReferenceNumber</td>
                        <td class="text-end">@payment.Amount.ToString("C")</td>
                        <td class="text-end">@payment.Allocations.Sum(allocation => allocation.AllocatedAmount).ToString("C")</td>
                        <td class="text-end">@((payment.Amount - payment.Allocations.Sum(allocation => allocation.AllocatedAmount)).ToString("C"))</td>
                        <td class="text-end">
                            <a asp-page="Details"
                               asp-route-id="@payment.Id"
                               class="btn btn-sm btn-outline-primary"
                               data-vpms-native-dialog
                               data-vpms-native-handler="Native"
                               data-vpms-native-dialog-title="AR Payment Allocation">Allocate</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
