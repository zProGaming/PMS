@page "{id:int}"
@model Vantage.PMS.Pages.AccountsReceivable.ARPayments.DetailsModel
@{
    ViewData["Title"] = "AR Payment Allocation";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">AR Payment @Model.Payment.Id</h1>
    <a asp-page="Index" class="btn btn-outline-secondary">Back</a>
</div>

@if (TempData["ErrorMessage"] is string error)
{
    <div class="alert alert-danger">@error</div>
}

<div class="row g-3 mb-4">
    <div class="col-md-3"><div class="border rounded p-3"><div class="text-muted">Account</div><strong>@Model.Payment.ARAccount?.AccountName</strong></div></div>
    <div class="col-md-3"><div class="border rounded p-3"><div class="text-muted">Payment Amount</div><strong>@Model.Payment.Amount.ToString("C")</strong></div></div>
    <div class="col-md-3"><div class="border rounded p-3"><div class="text-muted">Allocated</div><strong>@Model.Payment.Allocations.Sum(item => item.AllocatedAmount).ToString("C")</strong></div></div>
    <div class="col-md-3"><div class="border rounded p-3"><div class="text-muted">Remaining</div><strong>@Model.RemainingAmount.ToString("C")</strong></div></div>
</div>

@if (Model.RemainingAmount > 0)
{
    <form method="post" asp-page-handler="Allocate" class="row g-3 border rounded p-3 mb-4">
        <div class="col-md-6"><label asp-for="ARInvoiceId" class="form-label">Open Invoice</label><select asp-for="ARInvoiceId" asp-items="Model.InvoiceOptions" class="form-select"></select></div>
        <div class="col-md-3"><label asp-for="AllocatedAmount" class="form-label"></label><input asp-for="AllocatedAmount" class="form-control" /></div>
        <div class="col-md-3 align-self-end"><button class="btn btn-primary w-100">Allocate</button></div>
    </form>
}

<table class="table table-striped table-hover">
    <thead><tr><th>Date</th><th>Invoice</th><th>Allocated By</th><th class="text-end">Amount</th></tr></thead>
    <tbody>
        @foreach (var allocation in Model.Payment.Allocations)
        {
            <tr>
                <td>@allocation.AllocationDate.ToString("g")</td>
                <td>@allocation.ARInvoice?.InvoiceNumber</td>
                <td>@allocation.AllocatedBy</td>
                <td class="text-end">@allocation.AllocatedAmount.ToString("C")</td>
            </tr>
        }
    </tbody>
</table>
