@page
@model Vantage.PMS.Pages.GuestPortalManagement.Feedback.IndexModel
@{
    ViewData["Title"] = "Guest Feedback";
}

<h1 class="h3 mb-3">Guest Feedback</h1>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-info">@Model.StatusMessage</div>
}

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>Submitted</th>
                <th>Guest</th>
                <th>Reservation</th>
                <th>Rating</th>
                <th>Comments</th>
                <th>Resolved</th>
                <th>Resolution Notes</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var feedback in Model.Feedbacks)
            {
                <tr>
                    <td>@feedback.SubmittedAt.ToString("g")</td>
                    <td>@feedback.Guest?.FirstName @feedback.Guest?.LastName</td>
                    <td>@feedback.Reservation?.ConfirmationNumber</td>
                    <td>@feedback.Rating</td>
                    <td>@feedback.Comments</td>
                    <td>@(feedback.IsResolved ? "Yes" : "No")</td>
                    <td>@feedback.ResolutionNotes</td>
                    <td class="text-end">
                        <form method="post" class="d-flex gap-2 justify-content-end" asp-page-handler="Resolve" asp-route-id="@feedback.Id">
                            <input name="resolutionNotes" class="form-control form-control-sm" placeholder="Resolution notes" />
                            <button class="btn btn-sm btn-outline-success">Resolve</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
