@page
@using Vantage.PMS.Models.GuestPortal
@model Vantage.PMS.Pages.GuestPortalManagement.ServiceRequests.IndexModel
@{
    ViewData["Title"] = "Guest Service Requests";
}

<h1 class="h3 mb-3">Guest Service Requests</h1>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-info">@Model.StatusMessage</div>
}

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>Created</th>
                <th>Guest</th>
                <th>Room</th>
                <th>Type</th>
                <th>Priority</th>
                <th>Status</th>
                <th>Description</th>
                <th>Assigned To</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var request in Model.Requests)
            {
                <tr>
                    <td>@request.CreatedAt.ToString("g")</td>
                    <td>@request.Guest?.FirstName @request.Guest?.LastName</td>
                    <td>@request.Room?.RoomNumber</td>
                    <td>@request.RequestType</td>
                    <td>@request.Priority</td>
                    <td><span class="badge bg-secondary">@request.Status</span></td>
                    <td>@request.Description</td>
                    <td>@request.AssignedTo</td>
                    <td class="text-end">
                        <form method="post" class="d-inline" asp-page-handler="SetStatus" asp-route-id="@request.Id" asp-route-status="@GuestServiceRequestStatus.Assigned">
                            <button class="btn btn-sm btn-outline-secondary">Assign</button>
                        </form>
                        <form method="post" class="d-inline" asp-page-handler="SetStatus" asp-route-id="@request.Id" asp-route-status="@GuestServiceRequestStatus.InProgress">
                            <button class="btn btn-sm btn-outline-primary">Start</button>
                        </form>
                        <form method="post" class="d-inline" asp-page-handler="SetStatus" asp-route-id="@request.Id" asp-route-status="@GuestServiceRequestStatus.Completed">
                            <button class="btn btn-sm btn-outline-success">Complete</button>
                        </form>
                        <form method="post" class="d-inline" asp-page-handler="SetStatus" asp-route-id="@request.Id" asp-route-status="@GuestServiceRequestStatus.Cancelled">
                            <button class="btn btn-sm btn-outline-danger">Cancel</button>
                        </form>
                        @if (Model.CanCreateHousekeepingTask(request))
                        {
                            <form method="post" class="d-inline" asp-page-handler="CreateHousekeepingTask" asp-route-id="@request.Id">
                                <button class="btn btn-sm btn-warning">Create HK Task</button>
                            </form>
                        }
                    </td>
                </tr>
                @if (!string.IsNullOrWhiteSpace(request.Notes))
                {
                    <tr>
                        <td></td>
                        <td colspan="8" class="text-muted small">Notes: @request.Notes</td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
