@page
@model Vantage.PMS.Pages.GuestPortalManagement.Settings.IndexModel
@{
    ViewData["Title"] = "Guest Portal Settings";
}

<h1 class="h3 mb-3">Guest Portal Settings</h1>

<form method="post" class="row g-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="Setting.Id" />
    <input type="hidden" asp-for="Setting.CreatedAt" />

    <div class="col-md-6">
        <label asp-for="Setting.PortalTitle" class="form-label"></label>
        <input asp-for="Setting.PortalTitle" class="form-control" />
    </div>
    <div class="col-12">
        <label asp-for="Setting.WelcomeMessage" class="form-label"></label>
        <textarea asp-for="Setting.WelcomeMessage" class="form-control" rows="2"></textarea>
    </div>
    <div class="col-12 d-flex flex-wrap gap-3">
        <div class="form-check"><input asp-for="Setting.AllowPreCheckIn" class="form-check-input" /><label asp-for="Setting.AllowPreCheckIn" class="form-check-label"></label></div>
        <div class="form-check"><input asp-for="Setting.AllowServiceRequests" class="form-check-input" /><label asp-for="Setting.AllowServiceRequests" class="form-check-label"></label></div>
        <div class="form-check"><input asp-for="Setting.AllowFolioView" class="form-check-input" /><label asp-for="Setting.AllowFolioView" class="form-check-label"></label></div>
        <div class="form-check"><input asp-for="Setting.AllowExpressCheckoutRequest" class="form-check-input" /><label asp-for="Setting.AllowExpressCheckoutRequest" class="form-check-label"></label></div>
        <div class="form-check"><input asp-for="Setting.AllowFeedback" class="form-check-input" /><label asp-for="Setting.AllowFeedback" class="form-check-label"></label></div>
        <div class="form-check"><input asp-for="Setting.RequireReservationLookupVerification" class="form-check-input" /><label asp-for="Setting.RequireReservationLookupVerification" class="form-check-label"></label></div>
        <div class="form-check"><input asp-for="Setting.IsGuestPortalEnabled" class="form-check-input" /><label asp-for="Setting.IsGuestPortalEnabled" class="form-check-label"></label></div>
    </div>
    <div class="col-md-6">
        <label asp-for="Setting.TermsAndConditions" class="form-label"></label>
        <textarea asp-for="Setting.TermsAndConditions" class="form-control" rows="5"></textarea>
    </div>
    <div class="col-md-6">
        <label asp-for="Setting.PrivacyPolicy" class="form-label"></label>
        <textarea asp-for="Setting.PrivacyPolicy" class="form-control" rows="5"></textarea>
    </div>
    <div class="col-12">
        <button type="submit" class="btn btn-primary">Save Settings</button>
        <a asp-page="/GuestPortalManagement/Index" class="btn btn-outline-secondary">Dashboard</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
