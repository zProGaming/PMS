@page "{id:int}"
@model Vantage.PMS.Pages.Sales.Accounts.DeleteModel

@{
    ViewData["Title"] = "Delete Sales Account";
}

<h1>Delete Sales Account</h1>

<div class="alert alert-warning">
    Delete account <strong>@Model.SalesAccount.AccountName</strong>?
</div>

<dl class="row">
    <dt class="col-sm-2">Type</dt>
    <dd class="col-sm-10">@Model.SalesAccount.AccountType</dd>
    <dt class="col-sm-2">Phone</dt>
    <dd class="col-sm-10">@Model.SalesAccount.Phone</dd>
    <dt class="col-sm-2">Email</dt>
    <dd class="col-sm-10">@Model.SalesAccount.Email</dd>
</dl>

<form method="post">
    <button type="submit" class="btn btn-danger">Delete</button>
    <a class="btn btn-outline-secondary" asp-page="./Index">Cancel</a>
</form>
