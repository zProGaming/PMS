@page
@model Vantage.PMS.Pages.Sales.Activities.IndexModel

@{
    ViewData["Title"] = "Sales Activities";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="mb-1">Sales Activities</h1>
        <p class="text-muted mb-0">Calls, meetings, proposals, site inspections, and follow-ups.</p>
    </div>
    <a class="btn btn-primary" asp-page="./Create">Create Activity</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>Date</th>
            <th>Type</th>
            <th>Account</th>
            <th>Lead</th>
            <th>Next Follow-up</th>
            <th>Created By</th>
            <th class="text-end">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var activity in Model.SalesActivities)
        {
            <tr>
                <td>@activity.ActivityDate.ToString("g")</td>
                <td>@activity.ActivityType</td>
                <td>@activity.SalesAccount?.AccountName</td>
                <td>@activity.SalesLead?.LeadName</td>
                <td>@activity.NextFollowUpDate?.ToString("d")</td>
                <td>@activity.CreatedBy</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-primary" asp-page="./Edit" asp-route-id="@activity.Id">Edit</a>
                    <a class="btn btn-sm btn-outline-danger" asp-page="./Delete" asp-route-id="@activity.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
