@page "{id:int}"
@model Vantage.PMS.Pages.Sales.Leads.EditModel

@{
    ViewData["Title"] = "Edit Sales Lead";
}

<h1>Edit Sales Lead</h1>

<form method="post" class="mt-3">
    <input type="hidden" asp-for="SalesLead.Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="SalesLead.SalesAccountId" class="form-label">Sales Account</label>
            <select asp-for="SalesLead.SalesAccountId" class="form-select" asp-items="Model.AccountOptions">
                <option value="">No account assigned</option>
            </select>
            <span asp-validation-for="SalesLead.SalesAccountId" class="text-danger"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="SalesLead.LeadName" class="form-label">Lead Name</label>
            <input asp-for="SalesLead.LeadName" class="form-control" />
            <span asp-validation-for="SalesLead.LeadName" class="text-danger"></span>
        </div>
    </div>

    <div class="row">
        <div class="col-md-3 mb-3">
            <label asp-for="SalesLead.LeadSource" class="form-label">Lead Source</label>
            <input asp-for="SalesLead.LeadSource" class="form-control" />
            <span asp-validation-for="SalesLead.LeadSource" class="text-danger"></span>
        </div>
        <div class="col-md-3 mb-3">
            <label asp-for="SalesLead.EstimatedValue" class="form-label">Estimated Value</label>
            <input asp-for="SalesLead.EstimatedValue" class="form-control" />
            <span asp-validation-for="SalesLead.EstimatedValue" class="text-danger"></span>
        </div>
        <div class="col-md-3 mb-3">
            <label asp-for="SalesLead.Status" class="form-label"></label>
            <select asp-for="SalesLead.Status" class="form-select" asp-items="Model.StatusOptions"></select>
            <span asp-validation-for="SalesLead.Status" class="text-danger"></span>
        </div>
        <div class="col-md-3 mb-3">
            <label asp-for="SalesLead.ExpectedCloseDate" class="form-label">Expected Close Date</label>
            <input asp-for="SalesLead.ExpectedCloseDate" type="date" class="form-control" />
            <span asp-validation-for="SalesLead.ExpectedCloseDate" class="text-danger"></span>
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="SalesLead.AssignedTo" class="form-label">Assigned To</label>
        <input asp-for="SalesLead.AssignedTo" class="form-control" />
        <span asp-validation-for="SalesLead.AssignedTo" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="SalesLead.Notes" class="form-label"></label>
        <textarea asp-for="SalesLead.Notes" class="form-control" rows="3"></textarea>
        <span asp-validation-for="SalesLead.Notes" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a class="btn btn-outline-secondary" asp-page="./Index">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
