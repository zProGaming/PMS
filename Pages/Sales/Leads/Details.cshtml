@page "{id:int}"
@model Vantage.PMS.Pages.Sales.Leads.DetailsModel

@{
    ViewData["Title"] = "Sales Lead Details";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="mb-1">@Model.SalesLead.LeadName</h1>
        <p class="text-muted mb-0">@Model.SalesLead.Status - @Model.SalesLead.SalesAccount?.AccountName</p>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-primary" asp-page="/Sales/Activities/Create" asp-route-leadId="@Model.SalesLead.Id">Add Activity</a>
        <a class="btn btn-outline-secondary" asp-page="./Edit" asp-route-id="@Model.SalesLead.Id">Edit</a>
    </div>
</div>

<dl class="row">
    <dt class="col-sm-2">Account</dt>
    <dd class="col-sm-10">@Model.SalesLead.SalesAccount?.AccountName</dd>
    <dt class="col-sm-2">Lead Source</dt>
    <dd class="col-sm-10">@Model.SalesLead.LeadSource</dd>
    <dt class="col-sm-2">Estimated Value</dt>
    <dd class="col-sm-10">@Model.SalesLead.EstimatedValue.ToString("N2")</dd>
    <dt class="col-sm-2">Expected Close</dt>
    <dd class="col-sm-10">@Model.SalesLead.ExpectedCloseDate?.ToString("d")</dd>
    <dt class="col-sm-2">Assigned To</dt>
    <dd class="col-sm-10">@Model.SalesLead.AssignedTo</dd>
    <dt class="col-sm-2">Next Follow-up</dt>
    <dd class="col-sm-10">@Model.NextFollowUpDate?.ToString("d")</dd>
    <dt class="col-sm-2">Created</dt>
    <dd class="col-sm-10">@Model.SalesLead.CreatedAt.ToString("g") by @Model.SalesLead.CreatedBy</dd>
    <dt class="col-sm-2">Notes</dt>
    <dd class="col-sm-10">@Model.SalesLead.Notes</dd>
</dl>

<h2 class="h4 mt-4">Activities</h2>
<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>Date</th>
            <th>Type</th>
            <th>Account</th>
            <th>Next Follow-up</th>
            <th>Created By</th>
            <th>Notes</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var activity in Model.SalesLead.SalesActivities.OrderByDescending(activity => activity.ActivityDate))
        {
            <tr>
                <td>@activity.ActivityDate.ToString("g")</td>
                <td>@activity.ActivityType</td>
                <td>@activity.SalesAccount?.AccountName</td>
                <td>@activity.NextFollowUpDate?.ToString("d")</td>
                <td>@activity.CreatedBy</td>
                <td>@activity.Notes</td>
            </tr>
        }
    </tbody>
</table>

<a class="btn btn-outline-secondary" asp-page="./Index">Back to Leads</a>
