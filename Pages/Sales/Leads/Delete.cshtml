@page "{id:int}"
@model Vantage.PMS.Pages.Sales.Leads.DeleteModel

@{
    ViewData["Title"] = "Delete Sales Lead";
}

<h1>Delete Sales Lead</h1>

<div class="alert alert-warning">
    Delete lead <strong>@Model.SalesLead.LeadName</strong>?
</div>

<dl class="row">
    <dt class="col-sm-2">Account</dt>
    <dd class="col-sm-10">@Model.SalesLead.SalesAccount?.AccountName</dd>
    <dt class="col-sm-2">Status</dt>
    <dd class="col-sm-10">@Model.SalesLead.Status</dd>
    <dt class="col-sm-2">Value</dt>
    <dd class="col-sm-10">@Model.SalesLead.EstimatedValue.ToString("N2")</dd>
</dl>

<form method="post">
    <button type="submit" class="btn btn-danger">Delete</button>
    <a class="btn btn-outline-secondary" asp-page="./Index">Cancel</a>
</form>
