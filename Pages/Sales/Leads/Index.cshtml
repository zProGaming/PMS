@page
@model Vantage.PMS.Pages.Sales.Leads.IndexModel

@{
    ViewData["Title"] = "Sales Leads";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="mb-1">Sales Leads</h1>
        <p class="text-muted mb-0">Pipeline opportunities and business development leads.</p>
    </div>
    <a class="btn btn-primary" asp-page="./Create">Create Lead</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>Lead</th>
            <th>Account</th>
            <th>Source</th>
            <th>Status</th>
            <th>Expected Close</th>
            <th>Assigned To</th>
            <th class="text-end">Value</th>
            <th class="text-end">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var lead in Model.SalesLeads)
        {
            <tr>
                <td><a asp-page="./Details" asp-route-id="@lead.Id">@lead.LeadName</a></td>
                <td>@lead.SalesAccount?.AccountName</td>
                <td>@lead.LeadSource</td>
                <td>@lead.Status</td>
                <td>@lead.ExpectedCloseDate?.ToString("d")</td>
                <td>@lead.AssignedTo</td>
                <td class="text-end">@lead.EstimatedValue.ToString("N2")</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-secondary" asp-page="/Sales/Activities/Create" asp-route-leadId="@lead.Id">Activity</a>
                    <a class="btn btn-sm btn-outline-primary" asp-page="./Edit" asp-route-id="@lead.Id">Edit</a>
                    <a class="btn btn-sm btn-outline-danger" asp-page="./Delete" asp-route-id="@lead.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
