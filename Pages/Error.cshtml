@page
@model ErrorModel
@{
    ViewData["Title"] = "Error";
}

<section class="vpms-error-panel" aria-labelledby="error-title">
    <div class="vpms-error-mark" aria-hidden="true">!</div>
    <div>
        <div class="page-kicker">System Notice</div>
        <h1 id="error-title" class="page-title">We could not complete that request.</h1>
        <p class="page-subtitle">The issue has been logged for review. Please try again, or contact the system administrator if it continues.</p>

        @if (Model.ShowRequestId)
        {
            <div class="vpms-error-reference">
                <span>Request ID</span>
                <code>@Model.RequestId</code>
            </div>
        }

        <div class="d-flex flex-wrap gap-2 mt-3">
            <a class="btn vpms-btn-primary" asp-page="/Index">Return to Dashboard</a>
            <a class="btn vpms-btn-secondary" asp-page="/System/HealthCheck/Index">System Health</a>
        </div>
    </div>
</section>
