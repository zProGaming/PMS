@page
@model ErrorModel
@{
    ViewData["Title"] = "Error";
}

<h1 class="text-danger">Something went wrong.</h1>
<h2 class="h5">The issue has been logged for system review.</h2>

@if (Model.ShowRequestId)
{
    <p>
        <strong>Request ID:</strong> <code>@Model.RequestId</code>
    </p>
}

<p class="text-muted">Please try again. If the problem continues, contact the system administrator and provide the request ID above.</p>
