@page
@model Vantage.PMS.Pages.Revenue.RoomTypeRates.CreateModel
@{
    ViewData["Title"] = "Create Room Type Rate";
}
<h1>Create Room Type Rate</h1>
<form method="post" class="mt-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <partial name="_RoomTypeRateForm" model="Model" />
    <button type="submit" class="btn btn-primary">Create</button>
    <a class="btn btn-outline-secondary" asp-page="./Index">Cancel</a>
</form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
