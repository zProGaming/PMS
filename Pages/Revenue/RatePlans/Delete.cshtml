@page "{id:int}"
@model Vantage.PMS.Pages.Revenue.RatePlans.DeleteModel

@{
    ViewData["Title"] = "Delete Rate Plan";
}

<h1>Delete Rate Plan</h1>

<div class="alert alert-warning">
    Delete rate plan <strong>@Model.RatePlan.Code - @Model.RatePlan.Name</strong>?
</div>

<form method="post">
    <button type="submit" class="btn btn-danger">Delete</button>
    <a class="btn btn-outline-secondary" asp-page="./Index">Cancel</a>
</form>
