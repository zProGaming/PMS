@page
@model Vantage.PMS.Pages.Revenue.RateRestrictions.IndexModel
@{
    ViewData["Title"] = "Rate Restrictions";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">Rate Restrictions</h1>
    <a asp-page="Create" class="btn btn-primary">New Restriction</a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>Date</th>
                <th>Rate Plan</th>
                <th>Room Type</th>
                <th>Min LOS</th>
                <th>Max LOS</th>
                <th>CTA</th>
                <th>CTD</th>
                <th>Stop Sell</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.RateRestrictions)
            {
                <tr>
                    <td>@item.RestrictionDate.ToString("yyyy-MM-dd")</td>
                    <td>@(item.RatePlan?.Code ?? "All")</td>
                    <td>@(item.RoomType?.Code ?? "All")</td>
                    <td>@item.MinimumLengthOfStay</td>
                    <td>@(item.MaximumLengthOfStay?.ToString() ?? "-")</td>
                    <td>@(item.ClosedToArrival ? "Yes" : "No")</td>
                    <td>@(item.ClosedToDeparture ? "Yes" : "No")</td>
                    <td>@(item.StopSell ? "Yes" : "No")</td>
                    <td class="text-end">
                        <a asp-page="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                        <a asp-page="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
