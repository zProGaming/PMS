@page
@model Vantage.PMS.Pages.Revenue.Calendar.IndexModel
@{
    ViewData["Title"] = "Revenue Calendar";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1">Revenue Calendar</h1>
        <div class="text-muted">Next 30 days from @Model.BusinessDate.ToString("yyyy-MM-dd")</div>
    </div>
    <a asp-page="/Revenue/Index" class="btn btn-outline-secondary">Dashboard</a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>Date</th>
                <th>Total Rooms</th>
                <th>Rooms Sold</th>
                <th>Rooms Available</th>
                <th>Occupancy</th>
                <th>Base Rate Range</th>
                <th>Stop Sell</th>
                <th>Min LOS</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var day in Model.CalendarDays)
            {
                <tr>
                    <td>@day.Date.ToString("ddd, MMM d")</td>
                    <td>@day.TotalRooms</td>
                    <td>@day.RoomsSold</td>
                    <td>@day.RoomsAvailable</td>
                    <td>@day.OccupancyPercentage.ToString("N1")%</td>
                    <td>@day.BaseRateRange</td>
                    <td>
                        @if (day.StopSell)
                        {
                            <span class="badge bg-danger">Stop Sell</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Open</span>
                        }
                    </td>
                    <td>
                        @if (day.MinimumLengthOfStay > 1)
                        {
                            <span class="badge bg-warning text-dark">@day.MinimumLengthOfStay nights</span>
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
