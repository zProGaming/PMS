@page "{id:int}"
@model Vantage.PMS.Pages.Revenue.Restrictions.DeleteModel
@{
    ViewData["Title"] = "Delete Restriction";
}
<h1>Delete Restriction</h1>
<div class="alert alert-warning">Delete restriction for <strong>@Model.RateRestriction.RestrictionDate.ToString("d")</strong>?</div>
<form method="post">
    <button type="submit" class="btn btn-danger">Delete</button>
    <a class="btn btn-outline-secondary" asp-page="./Index">Cancel</a>
</form>
