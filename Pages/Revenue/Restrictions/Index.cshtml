@page
@model Vantage.PMS.Pages.Revenue.Restrictions.IndexModel
@{
    ViewData["Title"] = "Rate Restrictions";
}
<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="mb-1">Rate Restrictions</h1>
        <p class="text-muted mb-0">Stop sell, arrival/departure, and length-of-stay controls.</p>
    </div>
    <a class="btn btn-primary" asp-page="./Create">Create Restriction</a>
</div>
<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>Date</th>
            <th>Rate Plan</th>
            <th>Room Type</th>
            <th>Min/Max LOS</th>
            <th>CTA</th>
            <th>CTD</th>
            <th>Stop Sell</th>
            <th class="text-end">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var restriction in Model.RateRestrictions)
        {
            <tr>
                <td>@restriction.RestrictionDate.ToString("d")</td>
                <td>@(restriction.RatePlan?.Code ?? "All")</td>
                <td>@(restriction.RoomType?.Code ?? "All")</td>
                <td>@restriction.MinimumLengthOfStay / @(restriction.MaximumLengthOfStay?.ToString() ?? "-")</td>
                <td>@(restriction.ClosedToArrival ? "Yes" : "No")</td>
                <td>@(restriction.ClosedToDeparture ? "Yes" : "No")</td>
                <td>@(restriction.StopSell ? "Yes" : "No")</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-primary" asp-page="./Edit" asp-route-id="@restriction.Id">Edit</a>
                    <a class="btn btn-sm btn-outline-danger" asp-page="./Delete" asp-route-id="@restriction.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
