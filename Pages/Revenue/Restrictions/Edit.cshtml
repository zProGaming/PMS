@page "{id:int}"
@model Vantage.PMS.Pages.Revenue.Restrictions.EditModel
@{
    ViewData["Title"] = "Edit Restriction";
}
<h1>Edit Restriction</h1>
<form method="post" class="mt-3">
    <input type="hidden" asp-for="RateRestriction.Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <partial name="_RestrictionForm" model="Model" />
    <button type="submit" class="btn btn-primary">Save</button>
    <a class="btn btn-outline-secondary" asp-page="./Index">Cancel</a>
</form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
