@page "{id:int}"
@model Vantage.PMS.Pages.Revenue.RoomInventoryControls.DeleteModel
@{
    ViewData["Title"] = "Delete Room Inventory Control";
}

<h1 class="h3 mb-3">Delete Room Inventory Control</h1>

<div class="alert alert-warning">Delete this inventory control?</div>

<dl class="row">
    <dt class="col-sm-3">Date</dt>
    <dd class="col-sm-9">@Model.RoomInventoryControl.InventoryDate.ToString("yyyy-MM-dd")</dd>
    <dt class="col-sm-3">Room Type</dt>
    <dd class="col-sm-9">@(Model.RoomInventoryControl.RoomType?.Code ?? "Unknown")</dd>
    <dt class="col-sm-3">Rooms to Sell</dt>
    <dd class="col-sm-9">@Model.RoomInventoryControl.RoomsToSell</dd>
    <dt class="col-sm-3">Stop Sell</dt>
    <dd class="col-sm-9">@(Model.RoomInventoryControl.StopSell ? "Yes" : "No")</dd>
</dl>

<form method="post">
    <input type="hidden" asp-for="RoomInventoryControl.Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
</form>
