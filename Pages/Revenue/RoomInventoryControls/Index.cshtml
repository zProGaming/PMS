@page
@model Vantage.PMS.Pages.Revenue.RoomInventoryControls.IndexModel
@{
    ViewData["Title"] = "Room Inventory Controls";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">Room Inventory Controls</h1>
    <a asp-page="Create" class="btn btn-primary">New Control</a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>Date</th>
                <th>Room Type</th>
                <th>Total Rooms</th>
                <th>Rooms to Sell</th>
                <th>Overbooking</th>
                <th>Stop Sell</th>
                <th>Notes</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.RoomInventoryControls)
            {
                <tr>
                    <td>@item.InventoryDate.ToString("yyyy-MM-dd")</td>
                    <td>@(item.RoomType?.Code ?? "Unknown")</td>
                    <td>@item.TotalRooms</td>
                    <td>@item.RoomsToSell</td>
                    <td>@item.OverbookingLimit</td>
                    <td>@(item.StopSell ? "Yes" : "No")</td>
                    <td>@item.Notes</td>
                    <td class="text-end">
                        <a asp-page="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                        <a asp-page="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
