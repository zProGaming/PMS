@page "{id:int}"
@model Vantage.PMS.Pages.Revenue.SeasonalRates.EditModel
@{
    ViewData["Title"] = "Edit Seasonal Rate";
}
<h1>Edit Seasonal Rate</h1>
<form method="post" class="mt-3">
    <input type="hidden" asp-for="SeasonalRate.Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <partial name="_SeasonalRateForm" model="Model" />
    <button type="submit" class="btn btn-primary">Save</button>
    <a class="btn btn-outline-secondary" asp-page="./Index">Cancel</a>
</form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
