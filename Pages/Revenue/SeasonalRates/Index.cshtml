@page
@model Vantage.PMS.Pages.Revenue.SeasonalRates.IndexModel
@{
    ViewData["Title"] = "Seasonal Rates";
}
<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="mb-1">Seasonal Rates</h1>
        <p class="text-muted mb-0">Date-specific seasonal pricing overrides.</p>
    </div>
    <a class="btn btn-primary" asp-page="./Create">Create Seasonal Rate</a>
</div>
<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>Season</th>
            <th>Rate Plan</th>
            <th>Room Type</th>
            <th>Dates</th>
            <th class="text-end">Rate</th>
            <th class="text-end">Extra Adult</th>
            <th class="text-end">Extra Child</th>
            <th>Active</th>
            <th class="text-end">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var rate in Model.SeasonalRates)
        {
            <tr>
                <td>@rate.SeasonName</td>
                <td>@rate.RatePlan?.Code</td>
                <td>@rate.RoomType?.Code</td>
                <td>@rate.StartDate.ToString("d") - @rate.EndDate.ToString("d")</td>
                <td class="text-end">@rate.Rate.ToString("N2")</td>
                <td class="text-end">@rate.ExtraAdultRate.ToString("N2")</td>
                <td class="text-end">@rate.ExtraChildRate.ToString("N2")</td>
                <td>@(rate.IsActive ? "Yes" : "No")</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-primary" asp-page="./Edit" asp-route-id="@rate.Id">Edit</a>
                    <a class="btn btn-sm btn-outline-danger" asp-page="./Delete" asp-route-id="@rate.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
