@page
@model Vantage.PMS.Pages.Finance.VoidRequests.IndexModel
@{
    ViewData["Title"] = "Void Requests";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1">Void Requests</h1>
        <p class="text-muted mb-0">Finance-controlled void approvals and processing.</p>
    </div>
    <a asp-page="./Index" asp-page-handler="CreateNative" class="btn btn-primary" data-vpms-native-dialog data-vpms-native-dialog-title="New Void Request">New Void Request</a>
</div>
@if (TempData["ErrorMessage"] is string error) { <div class="alert alert-danger">@error</div> }

<details class="vpms-refined-card vpms-inline-create-panel mb-4">
    <summary>Manual void request entry</summary>
<form method="post" asp-page-handler="Create" class="row g-3 mt-3">
    <div class="col-md-2">
        <label asp-for="VoidRequest.ReferenceType" class="form-label"></label>
        <select asp-for="VoidRequest.ReferenceType" class="form-select">
            <option>FolioItem</option>
            <option>Payment</option>
            <option>POSOrder</option>
            <option>FinanceDocument</option>
        </select>
    </div>
    <div class="col-md-2"><label asp-for="VoidRequest.ReferenceId" class="form-label"></label><input asp-for="VoidRequest.ReferenceId" class="form-control" /></div>
    <div class="col-md-3"><label asp-for="VoidRequest.RequestedBy" class="form-label"></label><input asp-for="VoidRequest.RequestedBy" class="form-control" /></div>
    <div class="col-md-5"><label asp-for="VoidRequest.Reason" class="form-label"></label><input asp-for="VoidRequest.Reason" class="form-control" /></div>
    <div class="col-12"><button class="btn btn-primary">Create Void Request</button></div>
</form>
</details>

<div class="vpms-table-wrapper">
    <table class="table table-striped table-hover align-middle mb-0">
        <thead><tr><th>Date</th><th>Reference</th><th>Status</th><th>Reason</th><th>Requested By</th><th>Approved By</th><th></th></tr></thead>
        <tbody>
            @if (!Model.VoidRequests.Any())
            {
                <tr class="vpms-empty-row">
                    <td colspan="7">
                        <section class="vpms-empty-state vpms-empty-state-table">
                            <strong>No void requests found.</strong>
                            <span>Void controls will appear here when a transaction needs finance review before processing.</span>
                        </section>
                    </td>
                </tr>
            }
            else
            {
                @foreach (var request in Model.VoidRequests)
                {
                    <tr>
                        <td>@request.RequestedAt.ToString("g")</td>
                        <td>@request.ReferenceType #@request.ReferenceId</td>
                        <td><span class="badge text-bg-secondary">@request.Status</span></td>
                        <td>@request.Reason</td>
                        <td>@request.RequestedBy</td>
                        <td>@request.ApprovedBy</td>
                        <td class="text-end">
                            @if (request.Status == Vantage.PMS.Models.Finance.ApprovalStatus.Pending)
                            {
                                <a asp-page="./Index" asp-page-handler="ApproveNative" asp-route-id="@request.Id" class="btn btn-sm btn-success" data-vpms-native-dialog data-vpms-native-dialog-title="Approve Void Request">Approve</a>
                                <a asp-page="./Index" asp-page-handler="RejectNative" asp-route-id="@request.Id" class="btn btn-sm btn-outline-danger" data-vpms-native-dialog data-vpms-native-dialog-title="Reject Void Request">Reject</a>
                            }
                            @if (request.Status == Vantage.PMS.Models.Finance.ApprovalStatus.Approved)
                            {
                                <a asp-page="./Index" asp-page-handler="ProcessNative" asp-route-id="@request.Id" class="btn btn-sm btn-primary" data-vpms-native-dialog data-vpms-native-dialog-title="Process Void Request">Process Void</a>
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
