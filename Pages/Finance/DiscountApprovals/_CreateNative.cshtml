@model Vantage.PMS.Pages.Finance.DiscountApprovals.IndexModel
@using Vantage.PMS.Models.Finance

<div class="vpms-native-workflow-card">
    <div class="vpms-native-workflow-kicker">Discount request</div>
    <h2>New discount request</h2>
    <p>Create a controlled discount approval request for folio, POS, or banquet targets.</p>

    <form method="post" asp-page="./Index" asp-page-handler="Create" class="vpms-native-workflow-form">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <section class="vpms-form-section">
            <div class="vpms-form-section-heading">
                <div>
                    <h2>Target and Amount</h2>
                    <p>Enter one target reference and the proposed discount value.</p>
                </div>
            </div>
            <div class="row g-3">
                <div class="col-md-3">
                    <label asp-for="Discount.FolioId" class="form-label"></label>
                    <input asp-for="Discount.FolioId" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label asp-for="Discount.FolioItemId" class="form-label"></label>
                    <input asp-for="Discount.FolioItemId" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label asp-for="Discount.POSOrderId" class="form-label"></label>
                    <input asp-for="Discount.POSOrderId" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label asp-for="Discount.BanquetEventId" class="form-label"></label>
                    <input asp-for="Discount.BanquetEventId" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="Discount.DiscountType" class="form-label"></label>
                    <select asp-for="Discount.DiscountType" asp-items="Html.GetEnumSelectList<DiscountType>()" class="form-select"></select>
                </div>
                <div class="col-md-4">
                    <label asp-for="Discount.DiscountValue" class="form-label"></label>
                    <input asp-for="Discount.DiscountValue" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label asp-for="Discount.DiscountAmount" class="form-label"></label>
                    <input asp-for="Discount.DiscountAmount" class="form-control" />
                    <span asp-validation-for="Discount.DiscountAmount" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Discount.RequestedBy" class="form-label"></label>
                    <input asp-for="Discount.RequestedBy" class="form-control" />
                </div>
                <div class="col-md-8">
                    <label asp-for="Discount.Reason" class="form-label"></label>
                    <input asp-for="Discount.Reason" class="form-control" />
                </div>
            </div>
        </section>
        <div class="vpms-native-workflow-actions">
            <button class="btn vpms-btn-primary">Create Discount Request</button>
            <a href="#" class="btn vpms-btn-secondary" data-vpms-dialog-close>Cancel</a>
        </div>
    </form>
</div>
