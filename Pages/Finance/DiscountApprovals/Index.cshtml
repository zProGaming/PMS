@page
@model Vantage.PMS.Pages.Finance.DiscountApprovals.IndexModel
@using Vantage.PMS.Models.Finance
@{
    ViewData["Title"] = "Discount Approvals";
}

<h1 class="h3 mb-3">Discount Approvals</h1>
@if (TempData["ErrorMessage"] is string error) { <div class="alert alert-danger">@error</div> }

<form method="post" asp-page-handler="Create" class="row g-3 border rounded p-3 mb-4">
    <div class="col-md-2"><label asp-for="Discount.FolioId" class="form-label"></label><input asp-for="Discount.FolioId" class="form-control" /></div>
    <div class="col-md-2"><label asp-for="Discount.FolioItemId" class="form-label"></label><input asp-for="Discount.FolioItemId" class="form-control" /></div>
    <div class="col-md-2"><label asp-for="Discount.POSOrderId" class="form-label"></label><input asp-for="Discount.POSOrderId" class="form-control" /></div>
    <div class="col-md-2"><label asp-for="Discount.BanquetEventId" class="form-label"></label><input asp-for="Discount.BanquetEventId" class="form-control" /></div>
    <div class="col-md-2"><label asp-for="Discount.DiscountType" class="form-label"></label><select asp-for="Discount.DiscountType" asp-items="Html.GetEnumSelectList<Vantage.PMS.Models.Finance.DiscountType>()" class="form-select"></select></div>
    <div class="col-md-2"><label asp-for="Discount.DiscountValue" class="form-label"></label><input asp-for="Discount.DiscountValue" class="form-control" /></div>
    <div class="col-md-2"><label asp-for="Discount.DiscountAmount" class="form-label"></label><input asp-for="Discount.DiscountAmount" class="form-control" /></div>
    <div class="col-md-3"><label asp-for="Discount.RequestedBy" class="form-label"></label><input asp-for="Discount.RequestedBy" class="form-control" /></div>
    <div class="col-md-7"><label asp-for="Discount.Reason" class="form-label"></label><input asp-for="Discount.Reason" class="form-control" /></div>
    <div class="col-12"><button class="btn btn-primary">Create Discount Request</button></div>
</form>

<table class="table table-striped table-hover align-middle">
    <thead><tr><th>Date</th><th>Target</th><th>Status</th><th>Type</th><th class="text-end">Amount</th><th>Reason</th><th>Approved By</th><th></th></tr></thead>
    <tbody>
        @foreach (var discount in Model.Discounts)
        {
            var target = discount.FolioId is not null ? $"Folio #{discount.FolioId}" :
                discount.FolioItemId is not null ? $"FolioItem #{discount.FolioItemId}" :
                discount.POSOrderId is not null ? $"POSOrder #{discount.POSOrderId}" :
                discount.BanquetEventId is not null ? $"BanquetEvent #{discount.BanquetEventId}" : "Unassigned";
            <tr>
                <td>@discount.RequestedAt.ToString("g")</td>
                <td>@target</td>
                <td><span class="badge text-bg-secondary">@discount.Status</span></td>
                <td>@discount.DiscountType</td>
                <td class="text-end">@discount.DiscountAmount.ToString("C")</td>
                <td>@discount.Reason</td>
                <td>@discount.ApprovedBy</td>
                <td class="text-end">
                    @if (discount.Status == ApprovalStatus.Pending)
                    {
                        <form method="post" asp-page-handler="Approve" asp-route-id="@discount.Id" class="d-inline"><button class="btn btn-sm btn-success">Approve</button></form>
                        <form method="post" asp-page-handler="Reject" asp-route-id="@discount.Id" class="d-inline"><button class="btn btn-sm btn-outline-danger">Reject</button></form>
                    }
                    @if (discount.Status == ApprovalStatus.Approved)
                    {
                        <form method="post" asp-page-handler="Apply" asp-route-id="@discount.Id" class="d-inline"><button class="btn btn-sm btn-primary">Apply</button></form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
