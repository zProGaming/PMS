@page
@model Vantage.PMS.Pages.Finance.Refunds.IndexModel
@using Vantage.PMS.Models.Finance
@{
    ViewData["Title"] = "Refunds";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1">Refunds</h1>
        <p class="text-muted mb-0">Controlled refund requests, approvals, and cashier processing.</p>
    </div>
    <a asp-page="./Index" asp-page-handler="CreateNative" class="btn btn-primary" data-vpms-native-dialog data-vpms-native-dialog-title="New Refund Request">New Refund</a>
</div>
@if (TempData["ErrorMessage"] is string error) { <div class="alert alert-danger">@error</div> }

<details class="vpms-refined-card vpms-inline-create-panel mb-4">
    <summary>Manual refund request entry</summary>
<form method="post" asp-page-handler="Create" class="row g-3 mt-3">
    <div class="col-md-2"><label asp-for="Refund.RefundNumber" class="form-label"></label><input asp-for="Refund.RefundNumber" class="form-control" readonly /></div>
    <div class="col-md-2"><label asp-for="Refund.RefundDate" class="form-label"></label><input asp-for="Refund.RefundDate" type="date" class="form-control" /></div>
    <div class="col-md-2"><label asp-for="Refund.Amount" class="form-label"></label><input asp-for="Refund.Amount" class="form-control" /></div>
    <div class="col-md-2"><label asp-for="Refund.RefundMethod" class="form-label"></label><select asp-for="Refund.RefundMethod" asp-items="Html.GetEnumSelectList<FinancePaymentMethod>()" class="form-select"></select></div>
    <div class="col-md-2"><label asp-for="Refund.FolioId" class="form-label">Folio</label><select asp-for="Refund.FolioId" asp-items="Model.FolioOptions" class="form-select"><option value="">None</option></select></div>
    <div class="col-md-2"><label asp-for="Refund.PaymentId" class="form-label">Payment</label><select asp-for="Refund.PaymentId" asp-items="Model.PaymentOptions" class="form-select"><option value="">None</option></select></div>
    <div class="col-md-3"><label asp-for="Refund.RequestedBy" class="form-label"></label><input asp-for="Refund.RequestedBy" class="form-control" /></div>
    <div class="col-md-9"><label asp-for="Refund.Reason" class="form-label"></label><input asp-for="Refund.Reason" class="form-control" /></div>
    <div class="col-12"><button class="btn btn-primary">Create Refund Request</button></div>
</form>
</details>

<table class="table table-striped table-hover align-middle">
    <thead><tr><th>Number</th><th>Date</th><th>Status</th><th>Method</th><th class="text-end">Amount</th><th>Reason</th><th>Approved By</th><th>Processed By</th><th></th></tr></thead>
    <tbody>
        @foreach (var refund in Model.Refunds)
        {
            <tr>
                <td>@refund.RefundNumber</td>
                <td>@refund.RefundDate.ToString("d")</td>
                <td><span class="badge text-bg-secondary">@refund.Status</span></td>
                <td>@refund.RefundMethod</td>
                <td class="text-end">@refund.Amount.ToString("C")</td>
                <td>@refund.Reason</td>
                <td>@refund.ApprovedBy</td>
                <td>@refund.ProcessedBy</td>
                <td class="text-end">
                    @if (refund.Status is RefundStatus.Requested or RefundStatus.ForApproval)
                    {
                        <a asp-page="./Index" asp-page-handler="ApproveNative" asp-route-id="@refund.Id" class="btn btn-sm btn-success" data-vpms-native-dialog data-vpms-native-dialog-title="Approve Refund">Approve</a>
                        <a asp-page="./Index" asp-page-handler="RejectNative" asp-route-id="@refund.Id" class="btn btn-sm btn-outline-danger" data-vpms-native-dialog data-vpms-native-dialog-title="Reject Refund">Reject</a>
                    }
                    @if (refund.Status == RefundStatus.Approved)
                    {
                        <a asp-page="./Index" asp-page-handler="ProcessNative" asp-route-id="@refund.Id" class="btn btn-sm btn-primary" data-vpms-native-dialog data-vpms-native-dialog-title="Process Refund">Process</a>
                    }
                    @if (refund.Status != RefundStatus.Processed)
                    {
                        <a asp-page="./Index" asp-page-handler="CancelNative" asp-route-id="@refund.Id" class="btn btn-sm btn-outline-secondary" data-vpms-native-dialog data-vpms-native-dialog-title="Cancel Refund">Cancel</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
