@model Vantage.PMS.Pages.Finance.CashierShifts.IndexModel

<div class="vpms-native-workflow-card">
    <div class="vpms-native-workflow-kicker">Cashier control</div>
    <h2>Open cashier shift</h2>
    <p>Start a cashier shift for the current business date. Payments and cash movements can be tracked once the shift is open.</p>

    <form method="post" asp-page="./Index" asp-page-handler="Open" class="vpms-native-workflow-form">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <section class="vpms-form-section">
            <div class="vpms-form-section-heading">
                <div>
                    <h2>Opening Control</h2>
                    <p>Enter the starting cash float and any handover notes.</p>
                </div>
            </div>
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="OpeningCashFloat" class="form-label"></label>
                    <input asp-for="OpeningCashFloat" class="form-control" />
                    <span asp-validation-for="OpeningCashFloat" class="text-danger"></span>
                </div>
                <div class="col-md-8">
                    <label asp-for="Notes" class="form-label"></label>
                    <input asp-for="Notes" class="form-control" />
                </div>
            </div>
        </section>
        <div class="vpms-native-workflow-actions">
            <button type="submit" class="btn vpms-btn-primary">Open Shift</button>
            <a href="#" class="btn vpms-btn-secondary" data-vpms-dialog-close>Cancel</a>
        </div>
    </form>
</div>
