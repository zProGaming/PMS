@page
@model Vantage.PMS.Pages.Finance.CashierShifts.IndexModel
@{
    ViewData["Title"] = "Cashier Shifts";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1">Cashier Shifts</h1>
        <p class="text-muted mb-0">Open, monitor, and close cashier accountability shifts.</p>
    </div>
    <a asp-page="./Index" asp-page-handler="OpenNative" class="btn btn-primary" data-vpms-native-dialog data-vpms-native-dialog-title="Open Cashier Shift">Open Shift</a>
</div>

@if (TempData["ErrorMessage"] is string error)
{
    <div class="alert alert-danger">@error</div>
}

<details class="vpms-refined-card vpms-inline-create-panel mb-4">
    <summary>Manual shift opening</summary>
<form method="post" asp-page-handler="Open" class="row g-3 mt-3">
    <div class="col-md-3"><label asp-for="OpeningCashFloat" class="form-label"></label><input asp-for="OpeningCashFloat" class="form-control" /></div>
    <div class="col-md-7"><label asp-for="Notes" class="form-label"></label><input asp-for="Notes" class="form-control" /></div>
    <div class="col-md-2 align-self-end"><button class="btn btn-primary w-100">Open Shift</button></div>
</form>
</details>

<div class="vpms-table-wrapper">
    <table class="table table-striped table-hover align-middle mb-0">
        <thead><tr><th>Shift #</th><th>Business Date</th><th>Opened By</th><th>Opened</th><th>Closed</th><th>Status</th><th class="text-end">Expected Cash</th><th class="text-end">Over/Short</th><th></th></tr></thead>
        <tbody>
            @if (!Model.Shifts.Any())
            {
                <tr class="vpms-empty-row">
                    <td colspan="9">
                        <section class="vpms-empty-state vpms-empty-state-table">
                            <strong>No cashier shifts open or recorded yet.</strong>
                            <span>Open a shift to begin front cash accountability for the current business date.</span>
                        </section>
                    </td>
                </tr>
            }
            else
            {
                @foreach (var shift in Model.Shifts)
                {
                    <tr>
                        <td>@shift.ShiftNumber</td>
                        <td>@shift.BusinessDate.ToString("d")</td>
                        <td>@shift.OpenedBy</td>
                        <td>@shift.OpenedAt.ToString("g")</td>
                        <td>@shift.ClosedAt?.ToString("g")</td>
                        <td><span class="badge text-bg-secondary">@shift.Status</span></td>
                        <td class="text-end">@shift.ExpectedCashAmount?.ToString("C")</td>
                        <td class="text-end">@shift.CashOverShort?.ToString("C")</td>
                        <td class="text-end">
                            <a asp-page="Details"
                               asp-route-id="@shift.Id"
                               class="btn btn-sm btn-outline-primary"
                               data-vpms-dialog
                               data-vpms-dialog-title="Cashier Shift Control">Open</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
