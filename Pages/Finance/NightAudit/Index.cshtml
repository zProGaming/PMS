@page
@model Vantage.PMS.Pages.Finance.NightAudit.IndexModel

@{
    ViewData["Title"] = "Night Audit";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="mb-1">Night Audit</h1>
        <p class="text-muted mb-0">Business date: @Model.BusinessDate.ToString("D")</p>
    </div>
    <form method="post" asp-page-handler="Run">
        <div class="input-group">
            <input asp-for="CompletionNotes" class="form-control" placeholder="Notes" />
            <button type="submit" class="btn btn-primary" disabled="@Model.HasBlockingIssues">Run Night Audit</button>
        </div>
    </form>
</div>

@if (TempData["NightAuditMessage"] is string message)
{
    <div class="alert alert-success">@message</div>
}

@if (Model.HasBlockingIssues)
{
    <div class="alert alert-warning">
        Night audit cannot run until all blocking issues are resolved.
    </div>
}
else if (Model.HasWarnings)
{
    <div class="alert alert-info">
        No blocking issues found. Review the warnings below before running night audit.
    </div>
}
else
{
    <div class="alert alert-success">
        No blocking issues found. Night audit is ready to run.
    </div>
}

<div class="row g-3 mb-4">
    @foreach (var item in Model.Checklist)
    {
        <div class="col-md-6 col-xl-4">
            <div class="border rounded p-3 h-100">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="fw-semibold">@item.Name</div>
                    <span class="badge @(item.Count == 0 ? "bg-success" : "bg-danger")">@item.Count</span>
                </div>
                <div class="text-muted small mt-2">@item.Description</div>
            </div>
        </div>
    }
</div>

<h2 class="h4">Finance Close Controls</h2>
<div class="row g-3 mb-4">
    @foreach (var item in Model.FinanceCloseControls)
    {
        <div class="col-md-6 col-xl-3">
            <div class="border rounded p-3 h-100">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="fw-semibold">@item.Name</div>
                    <span class="badge @(item.Count == 0 ? "bg-success" : "bg-danger")">@item.Count</span>
                </div>
                <div class="text-muted small mt-2">@item.Description</div>
            </div>
        </div>
    }
</div>

<h2 class="h4">Finance Warnings</h2>
<div class="row g-3 mb-4">
    @foreach (var item in Model.FinanceWarnings)
    {
        <div class="col-md-6 col-xl-3">
            <div class="border rounded p-3 h-100">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="fw-semibold">@item.Name</div>
                    <span class="badge @(item.Count == 0 ? "bg-success" : "bg-warning text-dark")">@item.Count</span>
                </div>
                <div class="text-muted small mt-2">@item.Description</div>
            </div>
        </div>
    }
</div>

<h2 class="h4">Blocking Details</h2>

<h3 class="h5 mt-3">Unresolved Arrivals</h3>
<table class="table table-sm table-striped align-middle">
    <thead>
        <tr>
            <th>Confirmation</th>
            <th>Guest</th>
            <th>Arrival</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var reservation in Model.UnresolvedArrivals)
        {
            <tr>
                <td><a asp-page="/FrontOffice/Reservations/Details" asp-route-id="@reservation.Id">@reservation.ConfirmationNumber</a></td>
                <td>@reservation.Guest?.FirstName @reservation.Guest?.LastName</td>
                <td>@reservation.ArrivalDate.ToString("d")</td>
                <td>@reservation.Status</td>
            </tr>
        }
    </tbody>
</table>

<h3 class="h5 mt-3">Unresolved Departures</h3>
<table class="table table-sm table-striped align-middle">
    <thead>
        <tr>
            <th>Confirmation</th>
            <th>Guest</th>
            <th>Departure</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var reservation in Model.UnresolvedDepartures)
        {
            <tr>
                <td><a asp-page="/FrontOffice/Reservations/Details" asp-route-id="@reservation.Id">@reservation.ConfirmationNumber</a></td>
                <td>@reservation.Guest?.FirstName @reservation.Guest?.LastName</td>
                <td>@reservation.DepartureDate.ToString("d")</td>
                <td>@reservation.Status</td>
            </tr>
        }
    </tbody>
</table>

<h2 class="h4 mt-4">Advisory Details</h2>

<h3 class="h5 mt-3">Checked-in Guests With Outstanding Balances</h3>
<p class="text-muted small">These balances are shown for review and collection follow-up. They no longer block normal in-house night audit rollover.</p>
<table class="table table-sm table-striped align-middle">
    <thead>
        <tr>
            <th>Folio</th>
            <th>Guest</th>
            <th>Room</th>
            <th class="text-end">Balance</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var folio in Model.OutstandingFolios)
        {
            <tr>
                <td><a asp-page="/FrontOffice/Folios/Details" asp-route-id="@folio.Id">@folio.FolioNumber</a></td>
                <td>@folio.Guest?.FirstName @folio.Guest?.LastName</td>
                <td>@folio.Reservation?.Room?.RoomNumber</td>
                <td class="text-end">@folio.Balance.ToString("N2")</td>
            </tr>
        }
    </tbody>
</table>

<h3 class="h5 mt-3">Open Payments For Business Date</h3>
<table class="table table-sm table-striped align-middle">
    <thead>
        <tr>
            <th>Folio</th>
            <th>Date</th>
            <th>Method</th>
            <th>Status</th>
            <th class="text-end">Amount</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var payment in Model.OpenPayments)
        {
            <tr>
                <td><a asp-page="/FrontOffice/Folios/Details" asp-route-id="@payment.FolioId">@payment.Folio?.FolioNumber</a></td>
                <td>@payment.PaymentDate.ToString("g")</td>
                <td>@payment.PaymentMethod</td>
                <td>@payment.Status</td>
                <td class="text-end">@payment.Amount.ToString("N2")</td>
            </tr>
        }
    </tbody>
</table>

<h3 class="h5 mt-3">Inconsistent Room Statuses</h3>
<table class="table table-sm table-striped align-middle">
    <thead>
        <tr>
            <th>Room</th>
            <th>Status</th>
            <th>Issue</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var issue in Model.RoomIssues)
        {
            <tr>
                <td>@issue.RoomNumber</td>
                <td>@issue.Status</td>
                <td>@issue.Issue</td>
            </tr>
        }
    </tbody>
</table>

<h2 class="h4 mt-4">Audit History</h2>
<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>Business Date</th>
            <th>Started</th>
            <th>Completed</th>
            <th>Status</th>
            <th>Completed By</th>
            <th>Notes</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var audit in Model.AuditHistory)
        {
            <tr>
                <td>@audit.BusinessDate.ToString("d")</td>
                <td>@audit.StartedAt.ToString("g")</td>
                <td>@(audit.CompletedAt?.ToString("g") ?? "-")</td>
                <td>@audit.Status</td>
                <td>@audit.CompletedBy</td>
                <td class="text-break" style="white-space: pre-wrap">@audit.Notes</td>
            </tr>
        }
    </tbody>
</table>
