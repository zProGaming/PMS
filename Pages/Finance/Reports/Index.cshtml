@page
@model Vantage.PMS.Pages.Finance.Reports.IndexModel
@{
    ViewData["Title"] = "Finance Reports";
}

<h1 class="h3 mb-3">Finance Reports</h1>

<div class="list-group mb-4">
    <a asp-page="/AccountsReceivable/Aging/Index" class="list-group-item list-group-item-action">AR Aging Report</a>
    <a asp-page="/AccountsReceivable/Statements/Index" class="list-group-item list-group-item-action">AR Statement of Account</a>
</div>

<h2 class="h5">Cashier Shift Report</h2>
<table class="table table-sm table-striped">
    <thead><tr><th>Shift</th><th>Business Date</th><th>Opened By</th><th>Status</th><th class="text-end">Expected</th><th class="text-end">Over/Short</th></tr></thead>
    <tbody>
        @foreach (var item in Model.CashierShifts)
        {
            <tr><td>@item.ShiftNumber</td><td>@item.BusinessDate.ToString("d")</td><td>@item.OpenedBy</td><td>@item.Status</td><td class="text-end">@item.ExpectedCashAmount?.ToString("C")</td><td class="text-end">@item.CashOverShort?.ToString("C")</td></tr>
        }
    </tbody>
</table>

<h2 class="h5 mt-4">Cashier Transaction Report</h2>
<table class="table table-sm table-striped">
    <thead><tr><th>Date</th><th>Shift</th><th>Type</th><th>Method</th><th class="text-end">Amount</th><th>Reference</th></tr></thead>
    <tbody>
        @foreach (var item in Model.CashierTransactions)
        {
            <tr><td>@item.TransactionDate.ToString("g")</td><td>@item.CashierShift?.ShiftNumber</td><td>@item.TransactionType</td><td>@item.PaymentMethod</td><td class="text-end">@item.Amount.ToString("C")</td><td>@item.ReferenceNumber</td></tr>
        }
    </tbody>
</table>

<h2 class="h5 mt-4">Payment Summary Report</h2>
<table class="table table-sm table-striped">
    <thead><tr><th>Date</th><th>Folio</th><th>Method</th><th>Status</th><th class="text-end">Amount</th></tr></thead>
    <tbody>
        @foreach (var item in Model.Payments)
        {
            <tr><td>@item.PaymentDate.ToString("g")</td><td>@item.Folio?.FolioNumber</td><td>@item.PaymentMethod</td><td>@item.Status</td><td class="text-end">@item.Amount.ToString("C")</td></tr>
        }
    </tbody>
</table>

<h2 class="h5 mt-4">Refund Report</h2>
<table class="table table-sm table-striped">
    <thead><tr><th>Number</th><th>Date</th><th>Status</th><th>Method</th><th class="text-end">Amount</th><th>Reason</th></tr></thead>
    <tbody>
        @foreach (var item in Model.Refunds)
        {
            <tr><td>@item.RefundNumber</td><td>@item.RefundDate.ToString("d")</td><td>@item.Status</td><td>@item.RefundMethod</td><td class="text-end">@item.Amount.ToString("C")</td><td>@item.Reason</td></tr>
        }
    </tbody>
</table>

<h2 class="h5 mt-4">Void Request Report</h2>
<table class="table table-sm table-striped">
    <thead><tr><th>Date</th><th>Reference</th><th>Status</th><th>Requested By</th><th>Reason</th></tr></thead>
    <tbody>
        @foreach (var item in Model.VoidRequests)
        {
            <tr><td>@item.RequestedAt.ToString("g")</td><td>@item.ReferenceType #@item.ReferenceId</td><td>@item.Status</td><td>@item.RequestedBy</td><td>@item.Reason</td></tr>
        }
    </tbody>
</table>

<h2 class="h5 mt-4">Discount Approval Report</h2>
<table class="table table-sm table-striped">
    <thead><tr><th>Date</th><th>Status</th><th>Type</th><th class="text-end">Amount</th><th>Reason</th></tr></thead>
    <tbody>
        @foreach (var item in Model.DiscountApprovals)
        {
            <tr><td>@item.RequestedAt.ToString("g")</td><td>@item.Status</td><td>@item.DiscountType</td><td class="text-end">@item.DiscountAmount.ToString("C")</td><td>@item.Reason</td></tr>
        }
    </tbody>
</table>

<h2 class="h5 mt-4">Credit Memo Report</h2>
<table class="table table-sm table-striped">
    <thead><tr><th>Number</th><th>Date</th><th>Account</th><th>Status</th><th class="text-end">Amount</th></tr></thead>
    <tbody>
        @foreach (var item in Model.CreditMemos)
        {
            <tr><td>@item.CreditMemoNumber</td><td>@item.CreditMemoDate.ToString("d")</td><td>@item.ARAccount?.AccountName</td><td>@item.Status</td><td class="text-end">@item.Amount.ToString("C")</td></tr>
        }
    </tbody>
</table>

<h2 class="h5 mt-4">Debit Memo Report</h2>
<table class="table table-sm table-striped">
    <thead><tr><th>Number</th><th>Date</th><th>Account</th><th>Status</th><th class="text-end">Amount</th></tr></thead>
    <tbody>
        @foreach (var item in Model.DebitMemos)
        {
            <tr><td>@item.DebitMemoNumber</td><td>@item.DebitMemoDate.ToString("d")</td><td>@item.ARAccount?.AccountName</td><td>@item.Status</td><td class="text-end">@item.Amount.ToString("C")</td></tr>
        }
    </tbody>
</table>
