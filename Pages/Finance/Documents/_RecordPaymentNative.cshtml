@model Vantage.PMS.Pages.Finance.Documents.DetailsModel

<div class="vpms-native-workflow-card">
    <div class="vpms-native-workflow-kicker">Finance collection</div>
    <h2>Record document payment</h2>
    <p>Record a payment against this issued finance document.</p>

    <div class="vpms-native-workflow-summary">
        <span>Document</span>
        <strong>@Model.FinanceDocument.DocumentNumber</strong>
        <span>Billing Name</span>
        <strong>@Model.FinanceDocument.BillingName</strong>
        <span>Balance</span>
        <strong>@Model.FinanceDocument.Balance.ToString("C")</strong>
        <span>Status</span>
        <strong>@Model.FinanceDocument.Status</strong>
    </div>

    <form method="post" asp-page="./Details" asp-page-handler="RecordPayment" asp-route-id="@Model.FinanceDocument.Id" class="vpms-native-workflow-form">
        <section class="vpms-form-section">
            <div class="row g-3">
                <div class="col-md-5">
                    <label asp-for="DocumentPaymentAmount" class="form-label">Payment Amount</label>
                    <input asp-for="DocumentPaymentAmount" class="form-control" />
                    <span asp-validation-for="DocumentPaymentAmount" class="text-danger"></span>
                </div>
            </div>
        </section>
        <div class="vpms-native-workflow-actions">
            <button class="btn vpms-btn-primary">Record Payment</button>
            <a href="#" class="btn vpms-btn-secondary" data-vpms-dialog-close>Cancel</a>
        </div>
    </form>
</div>
