@model Vantage.PMS.Pages.Finance.Documents.DetailsModel

<div class="vpms-native-workflow-card">
    <div class="vpms-native-workflow-kicker">Finance document control</div>
    <h2>Void finance document</h2>
    <p>Void this document while preserving its history and reason for review.</p>

    <div class="vpms-native-workflow-summary">
        <span>Document</span>
        <strong>@Model.FinanceDocument.DocumentNumber</strong>
        <span>Billing Name</span>
        <strong>@Model.FinanceDocument.BillingName</strong>
        <span>Status</span>
        <strong>@Model.FinanceDocument.Status</strong>
        <span>Balance</span>
        <strong>@Model.FinanceDocument.Balance.ToString("C")</strong>
    </div>

    <form method="post" asp-page="./Details" asp-page-handler="Void" asp-route-id="@Model.FinanceDocument.Id" class="vpms-native-workflow-form">
        <section class="vpms-form-section">
            <div class="row g-3">
                <div class="col-12">
                    <label asp-for="VoidReason" class="form-label">Void Reason</label>
                    <input asp-for="VoidReason" class="form-control" />
                </div>
            </div>
        </section>
        <div class="vpms-native-workflow-actions">
            <button class="btn vpms-btn-danger">Void Document</button>
            <a href="#" class="btn vpms-btn-secondary" data-vpms-dialog-close>Keep Document</a>
        </div>
    </form>
</div>
