@model Vantage.PMS.ViewModels.Reports.ReportHeaderViewModel

<header class="vpms-report-header">
    <div>
        <div class="vpms-report-brand">Vantage PMS</div>
        <h1 class="vpms-report-title">@Model.ReportTitle</h1>
        <div class="vpms-report-meta">
            <span>@Model.HotelName</span>
            <span>@Model.ReportCategory</span>
            @if (Model.DateRangeStart is not null || Model.DateRangeEnd is not null)
            {
                <span>@(Model.DateRangeStart?.ToString("MMM d, yyyy") ?? "Start") to @(Model.DateRangeEnd?.ToString("MMM d, yyyy") ?? "End")</span>
            }
        </div>
    </div>
    <div class="vpms-report-meta text-end">
        <div>Generated @Model.GeneratedAt.ToString("MMM d, yyyy h:mm tt")</div>
        @if (!string.IsNullOrWhiteSpace(Model.GeneratedBy))
        {
            <div>Generated by @Model.GeneratedBy</div>
        }
        @if (!string.IsNullOrWhiteSpace(Model.PreparedBy))
        {
            <div>Prepared by @Model.PreparedBy</div>
        }
        @if (!string.IsNullOrWhiteSpace(Model.ReviewedBy))
        {
            <div>Reviewed by @Model.ReviewedBy</div>
        }
    </div>
</header>

@if (!string.IsNullOrWhiteSpace(Model.Disclaimer))
{
    <div class="vpms-report-disclaimer">@Model.Disclaimer</div>
}
