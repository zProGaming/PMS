@model Vantage.PMS.ViewModels.Reports.ReportFooterViewModel

<footer class="vpms-report-footer">
    <span>@(string.IsNullOrWhiteSpace(Model.FooterText) ? "Generated by Vantage PMS." : Model.FooterText)</span>
    <span>Printed @Model.PrintedAt.ToString("MMM d, yyyy h:mm tt")</span>
    @if (Model.ShowComplianceNote)
    {
        <span class="vpms-report-footer-note">Reports are configurable and should be reviewed by authorized finance personnel before official filing or submission.</span>
    }
</footer>
