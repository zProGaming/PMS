@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager

@if (SignInManager.IsSignedIn(User))
{
    var displayName = User.Identity?.Name ?? "Signed in user";
    var nameParts = displayName.Split('@')[0].Split(new[] { '.', '_', '-', ' ' }, StringSplitOptions.RemoveEmptyEntries);
    var initials = string.Join("", nameParts.Take(2).Select(part => part[0])).ToUpperInvariant();
    if (string.IsNullOrWhiteSpace(initials))
    {
        initials = "VP";
    }
    var roles = User.Claims
        .Where(claim => claim.Type == global::System.Security.Claims.ClaimTypes.Role)
        .Select(claim => claim.Value)
        .Where(role => !string.IsNullOrWhiteSpace(role))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .ToList();
    var primaryRole = roles.FirstOrDefault() ?? "Authorized User";
    var roleDisplayNames = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
    {
        ["SystemAdmin"] = "Global Admin",
        ["GeneralManager"] = "General Manager",
        ["FrontOfficeManager"] = "Front Office Manager",
        ["FrontDesk"] = "Front Desk",
        ["HousekeepingSupervisor"] = "Housekeeping Supervisor",
        ["Housekeeper"] = "Housekeeper",
        ["FinanceManager"] = "Finance Manager",
        ["Cashier"] = "Cashier",
        ["FBManager"] = "F&B Manager",
        ["FBServer"] = "F&B Server",
        ["FBCashier"] = "F&B Cashier",
        ["KitchenStaff"] = "Kitchen Staff",
        ["Chef"] = "Chef",
        ["SalesManager"] = "Sales Manager",
        ["BanquetManager"] = "Banquet Manager",
        ["RevenueManager"] = "Revenue Manager",
        ["PurchasingManager"] = "Purchasing Manager",
        ["InventoryManager"] = "Inventory Manager",
        ["HRManager"] = "HR Manager",
        ["Authorized User"] = "Authorized User"
    };
    var primaryRoleLabel = roleDisplayNames.TryGetValue(primaryRole, out var friendlyRole) ? friendlyRole : primaryRole;
    var roleLabel = roles.Count > 1 ? $"{primaryRoleLabel} +{roles.Count - 1}" : primaryRoleLabel;
    var companyName = User.FindFirst("Vantage.CompanyName")?.Value;
    var companyCode = User.FindFirst("Vantage.CompanyCode")?.Value;
    var accountContext = string.IsNullOrWhiteSpace(companyName)
        ? roleLabel
        : string.IsNullOrWhiteSpace(companyCode)
            ? $"{roleLabel} | {companyName}"
            : $"{roleLabel} | {companyCode}";

    <div class="vpms-user-area">
        <a class="vpms-notification-link" asp-area="" asp-page="/System/Notifications/Index" aria-label="System notifications">
            <span class="vpms-notification-dot"></span>
        </a>
        <a class="vpms-user-summary" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage account">
            <span class="vpms-user-avatar">@initials</span>
            <span class="vpms-user-copy">
                <strong>@displayName</strong>
                <small>@accountContext</small>
                @if (!string.IsNullOrWhiteSpace(companyName))
                {
                    <em>@companyName</em>
                }
            </span>
        </a>
        <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/Index", new { area = "" })">
            <button type="submit" class="vpms-logout-button">Logout</button>
        </form>
    </div>
}
else
{
    <div class="vpms-user-area">
        <a class="vpms-auth-link" asp-area="Identity" asp-page="/Account/Login">Login</a>
        <a class="vpms-auth-link primary" asp-area="Identity" asp-page="/Account/Register">Register</a>
    </div>
}
