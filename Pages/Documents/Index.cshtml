@page
@model Vantage.PMS.Pages.Documents.IndexModel
@{
    ViewData["Title"] = "Printable Documents";
    var totalDocuments = Model.Sections.Sum(section => section.Links.Count);
    var availableDocuments = Model.Sections.Sum(section => section.Links.Count(link => link.IsAvailable));
    var canManageTemplates = Vantage.PMS.Authorization.PmsRoles.SystemManagement.Any(User.IsInRole)
        || Vantage.PMS.Authorization.PmsRoles.ReportAdministration.Any(User.IsInRole);
}

<section class="vpms-document-hero">
    <div>
        <div class="page-kicker">Document Studio</div>
        <h1 class="vpms-page-title">Printable Documents</h1>
        <p class="vpms-page-subtitle">Guest, finance, F&amp;B, banquet, purchasing, and management print packages.</p>
        <div class="vpms-hero-chip-row">
            <span class="vpms-mini-chip">@totalDocuments templates</span>
            <span class="vpms-mini-chip">@availableDocuments available</span>
            <span class="vpms-mini-chip">Browser print / Save as PDF</span>
        </div>
    </div>
    <div class="vpms-hero-actions">
        <a class="btn vpms-btn-secondary" asp-page="/Reports/Center">Report Center</a>
        @if (canManageTemplates)
        {
            <a class="btn vpms-btn-primary" asp-page="/System/DocumentTemplateSettings/Index">Template Settings</a>
        }
    </div>
</section>

<div class="vpms-document-grid">
    @foreach (var documentSection in Model.Sections)
    {
        var availableInSection = documentSection.Links.Count(link => link.IsAvailable);
        <section class="vpms-document-section">
            <div class="vpms-document-section-header">
                <div>
                    <h2>@documentSection.Title</h2>
                    <p>@availableInSection of @documentSection.Links.Count available.</p>
                </div>
                <span>@availableInSection/@documentSection.Links.Count</span>
            </div>
            <div class="vpms-document-list">
                @foreach (var link in documentSection.Links)
                {
                    <article class="vpms-document-item @(link.IsAvailable ? "is-ready" : "is-pending")">
                        <div>
                            <strong>@link.Title</strong>
                            @if (link.IsAvailable)
                            {
                                <p>Available for review and print.</p>
                            }
                            else
                            {
                                <p>Source record required.</p>
                            }
                        </div>
                        @if (link.IsAvailable)
                        {
                            if (link.Page is not null)
                            {
                                <a class="btn btn-sm vpms-btn-secondary" href="@link.Page">Open</a>
                            }
                            else
                            {
                                <a class="btn btn-sm vpms-btn-secondary" asp-page="/Documents/Print" asp-route-template="@link.Template" asp-route-id="@link.SampleId">Open</a>
                            }
                        }
                        else
                        {
                            <span class="vpms-status-badge status-draft">Source needed</span>
                        }
                    </article>
                }
            </div>
        </section>
    }
</div>
