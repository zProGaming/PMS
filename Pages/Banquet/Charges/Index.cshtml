@page "{eventId:int?}"
@model Vantage.PMS.Pages.Banquet.Charges.IndexModel

@{
    ViewData["Title"] = "Banquet Charges";
    var charges = Model.BanquetEvent?.Charges ?? Model.AllCharges;
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="mb-1">Banquet Charges</h1>
        <p class="text-muted mb-0">
            @if (Model.BanquetEvent is null)
            {
                <span>All banquet event charges.</span>
            }
            else
            {
                <span>@Model.BanquetEvent.EventName - @Model.BanquetEvent.EventDate.ToString("d")</span>
            }
        </p>
    </div>
    @if (Model.BanquetEvent is not null)
    {
        <a class="btn btn-outline-secondary" asp-page="/Banquet/Events/Details" asp-route-id="@Model.BanquetEvent.Id">Back to Event</a>
    }
</div>

@if (Model.BanquetEvent is not null)
{
<form method="post" asp-page-handler="Add" asp-route-eventId="@Model.BanquetEvent.Id" class="border rounded p-3 mb-4">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <h2 class="h5">Add Charge</h2>
    <div class="row align-items-end">
        <div class="col-md-2 mb-3">
            <label asp-for="NewCharge.ChargeDate" class="form-label">Charge Date</label>
            <input asp-for="NewCharge.ChargeDate" type="date" class="form-control" />
            <span asp-validation-for="NewCharge.ChargeDate" class="text-danger"></span>
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="NewCharge.Description" class="form-label"></label>
            <input asp-for="NewCharge.Description" class="form-control" />
            <span asp-validation-for="NewCharge.Description" class="text-danger"></span>
        </div>
        <div class="col-md-2 mb-3">
            <label asp-for="NewCharge.Quantity" class="form-label"></label>
            <input asp-for="NewCharge.Quantity" class="form-control" />
            <span asp-validation-for="NewCharge.Quantity" class="text-danger"></span>
        </div>
        <div class="col-md-3 mb-3">
            <label asp-for="NewCharge.UnitPrice" class="form-label">Unit Price</label>
            <input asp-for="NewCharge.UnitPrice" class="form-control" />
            <span asp-validation-for="NewCharge.UnitPrice" class="text-danger"></span>
        </div>
        <div class="col-md-2 mb-3">
            <button type="submit" class="btn btn-primary w-100">Add</button>
        </div>
    </div>
</form>
}

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            @if (Model.BanquetEvent is null)
            {
                <th>Event</th>
            }
            <th>Description</th>
            <th>Date</th>
            <th class="text-end">Quantity</th>
            <th class="text-end">Unit Price</th>
            <th class="text-end">Amount</th>
            <th>Voided</th>
            <th class="text-end">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var charge in charges.OrderBy(charge => charge.ChargeDate).ThenBy(charge => charge.Id))
        {
            <tr class="@(charge.IsVoided ? "table-secondary text-muted" : "")">
                @if (Model.BanquetEvent is null)
                {
                    <td><a asp-page="/Banquet/Events/Details" asp-route-id="@charge.BanquetEventId">@charge.BanquetEvent?.EventName</a></td>
                }
                <td>@charge.Description</td>
                <td>@charge.ChargeDate.ToString("d")</td>
                <td class="text-end">@charge.Quantity.ToString("N2")</td>
                <td class="text-end">@charge.UnitPrice.ToString("N2")</td>
                <td class="text-end">@charge.Amount.ToString("N2")</td>
                <td>@(charge.IsVoided ? "Yes" : "No")</td>
                <td class="text-end">
                    @if (!charge.IsVoided && Model.BanquetEvent is not null)
                    {
                        <form method="post" asp-page-handler="Void" asp-route-eventId="@Model.BanquetEvent.Id" asp-route-chargeId="@charge.Id" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-danger">Void</button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
    <tfoot>
        <tr>
            <th colspan="@(Model.BanquetEvent is null ? 5 : 4)">Total Active Charges</th>
            <th class="text-end">@Model.TotalCharges.ToString("N2")</th>
            <th colspan="2"></th>
        </tr>
    </tfoot>
</table>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
