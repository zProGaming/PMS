@page "{id:int}"
@model Vantage.PMS.Pages.Banquet.Events.DeleteModel

@{
    ViewData["Title"] = "Delete Banquet Event";
}

<h1>Delete Banquet Event</h1>

<div class="alert alert-warning">
    Delete event <strong>@Model.BanquetEvent.EventName</strong>?
</div>

<dl class="row">
    <dt class="col-sm-2">Client</dt>
    <dd class="col-sm-10">@Model.BanquetEvent.ClientName</dd>
    <dt class="col-sm-2">Date</dt>
    <dd class="col-sm-10">@Model.BanquetEvent.EventDate.ToString("d")</dd>
    <dt class="col-sm-2">Room</dt>
    <dd class="col-sm-10">@Model.BanquetEvent.FunctionRoom?.Name</dd>
</dl>

<form method="post">
    <button type="submit" class="btn btn-danger">Delete</button>
    <a class="btn btn-outline-secondary" asp-page="./Index">Cancel</a>
</form>
