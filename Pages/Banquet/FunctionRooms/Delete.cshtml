@page "{id:int}"
@model Vantage.PMS.Pages.Banquet.FunctionRooms.DeleteModel

@{
    ViewData["Title"] = "Delete Function Room";
}

<h1>Delete Function Room</h1>

<div class="alert alert-warning">
    Delete function room <strong>@Model.FunctionRoom.Name</strong>?
</div>

<dl class="row">
    <dt class="col-sm-2">Location</dt>
    <dd class="col-sm-10">@Model.FunctionRoom.Location</dd>
    <dt class="col-sm-2">Capacity</dt>
    <dd class="col-sm-10">@Model.FunctionRoom.Capacity</dd>
    <dt class="col-sm-2">Rate</dt>
    <dd class="col-sm-10">@Model.FunctionRoom.Rate.ToString("N2")</dd>
    <dt class="col-sm-2">Notes</dt>
    <dd class="col-sm-10">@Model.FunctionRoom.Notes</dd>
</dl>

<form method="post">
    <button type="submit" class="btn btn-danger">Delete</button>
    <a class="btn btn-outline-secondary" asp-page="./Index">Cancel</a>
</form>
