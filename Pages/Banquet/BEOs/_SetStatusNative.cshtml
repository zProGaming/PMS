@model Vantage.PMS.Pages.Banquet.BEOs.DetailsModel

<div class="vpms-native-workflow-card">
    <div class="vpms-native-workflow-kicker">Banquet control</div>
    <h2>@Model.NativeActionTitle</h2>
    <p>@Model.NativeActionMessage</p>

    <div class="vpms-native-workflow-summary">
        <span>Event</span>
        <strong>@Model.BanquetEvent.EventName</strong>
        <span>Current BEO Status</span>
        <strong>@Model.BanquetEventOrder.Status</strong>
        <span>Target Status</span>
        <strong>@Model.NativeStatus</strong>
        <span>Event Date</span>
        <strong>@Model.BanquetEvent.EventDate.ToString("d")</strong>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.NativeActionSupport))
    {
        <div class="vpms-native-workflow-note">@Model.NativeActionSupport</div>
    }

    <form method="post" asp-page="./Details" asp-page-handler="SetStatus" asp-route-eventId="@Model.BanquetEvent.Id" asp-route-status="@Model.NativeStatus" class="vpms-native-workflow-actions">
        <button type="submit" class="btn @Model.NativeActionButtonClass">@Model.NativeActionButtonText</button>
        <a href="#" class="btn vpms-btn-secondary" data-vpms-dialog-close>Keep Reviewing</a>
    </form>
</div>
