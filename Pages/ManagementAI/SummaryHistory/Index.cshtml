@page
@model Vantage.PMS.Pages.ManagementAI.SummaryHistory.IndexModel
@{
    ViewData["Title"] = "Management Summary History";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">Summary History</h1>
    <a class="btn btn-outline-secondary" asp-page="/ManagementAI/Index">Dashboard</a>
</div>

<div class="table-responsive">
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Business Date</th>
                <th>Occupancy</th>
                <th>Total Revenue</th>
                <th>Payments</th>
                <th>Guest Balances</th>
                <th>AR Balance</th>
                <th>Generated By</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var summary in Model.Summaries)
            {
                <tr>
                    <td>@summary.BusinessDate.ToString("d")</td>
                    <td>@summary.OccupancyPercentage.ToString("0.#")%</td>
                    <td>@summary.TotalRevenue.ToString("C")</td>
                    <td>@summary.TotalPayments.ToString("C")</td>
                    <td>@summary.OutstandingGuestBalances.ToString("C")</td>
                    <td>@summary.ARBalance.ToString("C")</td>
                    <td>@summary.GeneratedBy</td>
                    <td class="text-end"><a class="btn btn-sm btn-outline-primary" asp-page="./Details" asp-route-id="@summary.Id">Details</a></td>
                </tr>
            }
        </tbody>
    </table>
</div>
