@page
@model Vantage.PMS.Pages.Booking.GuestDetailsModel
@{
    ViewData["Title"] = "Guest Details";
    var quote = Model.QuoteResult.Quote;
}

<section class="vpms-booking-flow-header">
    <div>
        <div class="vpms-booking-kicker">Guest Details</div>
        <h1>Complete your booking request</h1>
        <p>Share guest details and arrival preferences for a secure hotel-reviewed confirmation.</p>
    </div>
    <a asp-page="Rooms"
       asp-route-checkInDate="@Model.BookingInput.CheckInDate.ToString("yyyy-MM-dd")"
       asp-route-checkOutDate="@Model.BookingInput.CheckOutDate.ToString("yyyy-MM-dd")"
       asp-route-adultCount="@Model.BookingInput.AdultCount"
       asp-route-childCount="@Model.BookingInput.ChildCount"
       asp-route-promoCode="@Model.BookingInput.PromoCode"
       class="btn vpms-booking-secondary">Back to Rooms</a>
</section>

<section class="vpms-booking-confidence-strip" aria-label="Booking request confidence">
    <article>
        <span>Privacy</span>
        <strong>Guest details stay within the hotel review workflow.</strong>
    </article>
    <article>
        <span>Payment</span>
        <strong>No payment is collected before final hotel confirmation.</strong>
    </article>
    <article>
        <span>Review</span>
        <strong>Reservations team validates availability and preferences.</strong>
    </article>
</section>

@if (Model.QuoteResult.Errors.Count > 0)
{
    <div class="vpms-booking-unavailable">
        @foreach (var error in Model.QuoteResult.Errors)
        {
            <div>@error</div>
        }
    </div>
}

@if (quote is not null)
{
    <div class="vpms-booking-checkout">
        <main>
            <form method="post" asp-page="Summary" class="vpms-guest-details-card">
                <input type="hidden" asp-for="BookingInput.CheckInDate" />
                <input type="hidden" asp-for="BookingInput.CheckOutDate" />
                <input type="hidden" asp-for="BookingInput.AdultCount" />
                <input type="hidden" asp-for="BookingInput.ChildCount" />
                <input type="hidden" asp-for="BookingInput.PromoCode" />
                <input type="hidden" asp-for="BookingInput.RoomTypeId" />
                <input type="hidden" asp-for="BookingInput.RatePlanId" />

                <section class="vpms-booking-form-section">
                    <div class="vpms-booking-section-heading">
                        <span>01</span>
                        <div>
                            <h2>Primary Guest</h2>
                            <p>Use the name and contact details the reservations team should use for confirmation.</p>
                        </div>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="GuestInput.FirstName" class="form-label">First Name</label>
                            <input asp-for="GuestInput.FirstName" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="GuestInput.LastName" class="form-label">Last Name</label>
                            <input asp-for="GuestInput.LastName" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="GuestInput.Email" class="form-label">Email Address</label>
                            <input asp-for="GuestInput.Email" type="email" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="GuestInput.Phone" class="form-label">Mobile Number</label>
                            <input asp-for="GuestInput.Phone" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label asp-for="GuestInput.Address" class="form-label">Address</label>
                            <textarea asp-for="GuestInput.Address" class="form-control" rows="2"></textarea>
                        </div>
                    </div>
                </section>

                @if (quote.Setting.AllowSpecialRequests)
                {
                    <section class="vpms-booking-form-section">
                        <div class="vpms-booking-section-heading">
                            <span>02</span>
                            <div>
                                <h2>Arrival Preferences</h2>
                                <p>Optional requests are shared with the hotel team for review.</p>
                            </div>
                        </div>
                        <label asp-for="GuestInput.SpecialRequests" class="form-label">Special Requests</label>
                        <textarea asp-for="GuestInput.SpecialRequests" class="form-control" rows="4" placeholder="Arrival time, bed preference, accessibility notes, celebration details, or other requests"></textarea>
                    </section>
                }

                @if (Model.AvailableAddOns.Count > 0)
                {
                    <section class="vpms-booking-form-section">
                        <div class="vpms-booking-section-heading">
                            <span>03</span>
                            <div>
                                <h2>Enhance Your Stay</h2>
                                <p>Select optional add-ons available for this booking request.</p>
                            </div>
                        </div>
                        <div class="vpms-addon-list">
                            @for (var i = 0; i < Model.AvailableAddOns.Count; i++)
                            {
                                <input type="hidden" asp-for="AddOnSelections[i].BookingAddOnId" />
                                <article class="vpms-addon-card">
                                    <div>
                                        <strong>@Model.AvailableAddOns[i].Name</strong>
                                        <p>
                                            @Model.AvailableAddOns[i].Description
                                            @if (Model.AvailableAddOns[i].IsPerNight)
                                            {
                                                <span> Per night.</span>
                                            }
                                            @if (Model.AvailableAddOns[i].IsPerPerson)
                                            {
                                                <span> Per person.</span>
                                            }
                                        </p>
                                    </div>
                                    <div class="vpms-addon-price">@Model.AvailableAddOns[i].Price.ToString("C")</div>
                                    <div>
                                        <label asp-for="AddOnSelections[i].Quantity" class="form-label visually-hidden">Quantity</label>
                                        <input asp-for="AddOnSelections[i].Quantity" class="form-control" type="number" min="0" />
                                    </div>
                                </article>
                            }
                        </div>
                    </section>
                }

                <section class="vpms-booking-form-section compact">
                    <div class="form-check">
                        <input asp-for="GuestAcceptedTerms" class="form-check-input" />
                        <label asp-for="GuestAcceptedTerms" class="form-check-label">I accept the booking terms and privacy policy.</label>
                    </div>
                </section>

                <button type="submit" class="btn vpms-booking-primary w-100">Review Booking</button>
            </form>
        </main>

        <aside class="vpms-booking-summary-card">
            @if (!string.IsNullOrWhiteSpace(quote.ImageUrl))
            {
                <img src="@quote.ImageUrl" alt="@quote.RoomTypeName" />
            }
            <div class="vpms-booking-summary-body">
                <div class="vpms-booking-kicker">Selected Room</div>
                <h2>@quote.RoomTypeName</h2>
                <p>@(string.IsNullOrWhiteSpace(quote.ShortDescription) ? "Selected room type for your stay." : quote.ShortDescription)</p>
                <div class="vpms-rate-breakdown">
                    <div><span>Stay dates</span><strong>@quote.CheckInDate.ToString("MMM d") - @quote.CheckOutDate.ToString("MMM d, yyyy")</strong></div>
                    <div><span>Nights</span><strong>@quote.Nights</strong></div>
                    <div><span>Guests</span><strong>@quote.AdultCount adult@(quote.AdultCount == 1 ? "" : "s")@if (quote.ChildCount > 0) { <text>, @quote.ChildCount child@(quote.ChildCount == 1 ? "" : "ren")</text> }</strong></div>
                    <div><span>Rate</span><strong>@quote.RoomRate.ToString("C")</strong></div>
                    @if (quote.DiscountAmount > 0)
                    {
                        <div><span>Promo discount</span><strong>-@quote.DiscountAmount.ToString("C")</strong></div>
                    }
                    <div class="total"><span>Estimated total</span><strong>@quote.FinalEstimatedTotal.ToString("C")</strong></div>
                    @if (quote.DepositRequired)
                    {
                        <div><span>Deposit guidance</span><strong>@quote.DepositAmount.ToString("C")</strong></div>
                    }
                </div>
            </div>
        </aside>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
