@page
@model Vantage.PMS.Pages.Booking.ConfirmationModel
@{
    ViewData["Title"] = "Booking Confirmation";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-body">
                <h1 class="h3">Booking Request Received</h1>
                @if (Model.BookingRequest is null)
                {
                    <div class="alert alert-warning">Booking request was not found.</div>
                }
                else
                {
                    <p>Your booking request has been received. Our team will contact you to confirm your reservation.</p>
                    <dl class="row">
                        <dt class="col-sm-4">Booking reference</dt>
                        <dd class="col-sm-8 fw-semibold">@Model.BookingRequest.BookingReference</dd>
                        <dt class="col-sm-4">Guest</dt>
                        <dd class="col-sm-8">@Model.BookingRequest.GuestFirstName @Model.BookingRequest.GuestLastName</dd>
                        <dt class="col-sm-4">Stay dates</dt>
                        <dd class="col-sm-8">@Model.BookingRequest.CheckInDate.ToString("yyyy-MM-dd") - @Model.BookingRequest.CheckOutDate.ToString("yyyy-MM-dd")</dd>
                        <dt class="col-sm-4">Status</dt>
                        <dd class="col-sm-8">@Model.BookingRequest.BookingStatus</dd>
                    </dl>
                }
                <a asp-page="Index" class="btn btn-primary">Start New Search</a>
            </div>
        </div>
    </div>
</div>
