@page
@model Vantage.PMS.Pages.Purchasing.PurchaseRequests.IndexModel
@{
    ViewData["Title"] = "Purchase Requests";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">Purchase Requests</h1>
    <a asp-page="Create" class="btn btn-primary" data-vpms-native-dialog data-vpms-native-handler="Native" data-vpms-native-dialog-title="New Purchase Request">New Request</a>
</div>

<div class="vpms-table-wrapper">
    <table class="table table-striped table-hover align-middle mb-0">
        <thead><tr><th>Request #</th><th>Department</th><th>Requested By</th><th>Date</th><th>Needed</th><th>Status</th><th class="text-end">Estimated Total</th><th></th></tr></thead>
        <tbody>
            @if (!Model.PurchaseRequests.Any())
            {
                <tr class="vpms-empty-row">
                    <td colspan="8">
                        <section class="vpms-empty-state vpms-empty-state-table">
                            <strong>No purchase requests found.</strong>
                            <span>Create a request from the purchasing queue when departments need approval for replenishment or operating supplies.</span>
                        </section>
                    </td>
                </tr>
            }
            else
            {
                @foreach (var request in Model.PurchaseRequests)
                {
                    <tr>
                        <td>@request.RequestNumber</td>
                        <td>@request.Department?.Name</td>
                        <td>@request.RequestedBy</td>
                        <td>@request.RequestDate.ToString("d")</td>
                        <td>@request.NeededDate?.ToString("d")</td>
                        <td><span class="badge text-bg-secondary">@request.Status</span></td>
                        <td class="text-end">@request.Items.Sum(item => item.EstimatedAmount).ToString("C")</td>
                        <td class="text-end">
                            <a asp-page="Details"
                               asp-route-id="@request.Id"
                               class="btn btn-sm btn-outline-primary"
                               data-vpms-dialog
                               data-vpms-dialog-title="Purchase Request Control">Open</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
