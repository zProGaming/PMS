@page
@model Vantage.PMS.Pages.Purchasing.PurchaseOrders.IndexModel
@{
    ViewData["Title"] = "Purchase Orders";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">Purchase Orders</h1>
    <a asp-page="Create" class="btn btn-primary" data-vpms-native-dialog data-vpms-native-handler="Native" data-vpms-native-dialog-title="New Purchase Order">New PO</a>
</div>

<div class="vpms-table-wrapper">
    <table class="table table-striped table-hover align-middle mb-0">
        <thead><tr><th>PO #</th><th>Supplier</th><th>Request</th><th>Order Date</th><th>Expected</th><th>Status</th><th class="text-end">Total</th><th></th></tr></thead>
        <tbody>
            @if (!Model.PurchaseOrders.Any())
            {
                <tr class="vpms-empty-row">
                    <td colspan="8">
                        <section class="vpms-empty-state vpms-empty-state-table">
                            <strong>No purchase orders found.</strong>
                            <span>Create a purchase order when an approved request is ready for supplier commitment and receiving control.</span>
                        </section>
                    </td>
                </tr>
            }
            else
            {
                @foreach (var order in Model.PurchaseOrders)
                {
                    <tr>
                        <td>@order.PONumber</td>
                        <td>@order.Supplier?.SupplierName</td>
                        <td>@order.PurchaseRequest?.RequestNumber</td>
                        <td>@order.OrderDate.ToString("d")</td>
                        <td>@order.ExpectedDeliveryDate?.ToString("d")</td>
                        <td><span class="badge text-bg-secondary">@order.Status</span></td>
                        <td class="text-end">@order.TotalAmount.ToString("C")</td>
                        <td class="text-end">
                            <a asp-page="Details"
                               asp-route-id="@order.Id"
                               class="btn btn-sm btn-outline-primary"
                               data-vpms-dialog
                               data-vpms-dialog-title="Purchase Order Control">Open</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
