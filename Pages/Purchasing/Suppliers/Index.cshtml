@page
@model Vantage.PMS.Pages.Purchasing.Suppliers.IndexModel
@{
    ViewData["Title"] = "Suppliers";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">Suppliers</h1>
    <a asp-page="Create" class="btn btn-primary">New Supplier</a>
</div>

<table class="table table-striped table-hover">
    <thead><tr><th>Supplier</th><th>Contact</th><th>Phone</th><th>Email</th><th>Terms</th><th>Active</th><th></th></tr></thead>
    <tbody>
        @foreach (var supplier in Model.Suppliers)
        {
            <tr>
                <td>@supplier.SupplierName</td>
                <td>@supplier.ContactPerson</td>
                <td>@supplier.Phone</td>
                <td>@supplier.Email</td>
                <td>@supplier.Terms</td>
                <td>@(supplier.IsActive ? "Yes" : "No")</td>
                <td class="text-end">
                    <a asp-page="Edit" asp-route-id="@supplier.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                    <a asp-page="Delete" asp-route-id="@supplier.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
