@page
@model Vantage.PMS.Pages.Purchasing.Suppliers.IndexModel
@{
    ViewData["Title"] = "Suppliers";
}

<div class="page-header">
    <div>
        <div class="page-kicker">Purchasing Setup</div>
        <h1 class="page-title">Suppliers</h1>
        <p class="page-subtitle">Supplier master records used for purchase requests, purchase orders, receiving, and AP controls.</p>
    </div>
    <a asp-page="Create" class="btn btn-primary" data-vpms-dialog data-vpms-dialog-title="New Supplier">New Supplier</a>
</div>

<div class="vpms-table-wrapper">
    <table class="table table-striped table-hover mb-0">
        <thead><tr><th>Supplier</th><th>Contact</th><th>Phone</th><th>Email</th><th>Terms</th><th>Active</th><th></th></tr></thead>
        <tbody>
            @if (!Model.Suppliers.Any())
            {
                <tr class="vpms-empty-row">
                    <td colspan="7">
                        <section class="vpms-empty-state vpms-empty-state-table">
                            <strong>No suppliers configured.</strong>
                            <span>No suppliers match the current view.</span>
                        </section>
                    </td>
                </tr>
            }
            else
            {
                @foreach (var supplier in Model.Suppliers)
                {
                    <tr>
                        <td>@supplier.SupplierName</td>
                        <td>@supplier.ContactPerson</td>
                        <td>@supplier.Phone</td>
                        <td>@supplier.Email</td>
                        <td>@supplier.Terms</td>
                        <td>@(supplier.IsActive ? "Yes" : "No")</td>
                        <td class="text-end">
                            <div class="vpms-row-actions">
                                <a asp-page="Edit" asp-route-id="@supplier.Id" class="btn btn-sm btn-outline-secondary" data-vpms-dialog data-vpms-dialog-title="Edit Supplier">Edit</a>
                                <a asp-page="Delete" asp-route-id="@supplier.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
