@page "{id:int}"
@model Vantage.PMS.Pages.Purchasing.Suppliers.EditModel
@{
    ViewData["Title"] = "Edit Supplier";
}

<h1 class="h3 mb-3">Edit Supplier</h1>

<form method="post" class="row g-3">
    <input type="hidden" asp-for="Supplier.Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="col-md-6"><label asp-for="Supplier.SupplierName" class="form-label"></label><input asp-for="Supplier.SupplierName" class="form-control" /></div>
    <div class="col-md-6"><label asp-for="Supplier.ContactPerson" class="form-label"></label><input asp-for="Supplier.ContactPerson" class="form-control" /></div>
    <div class="col-md-4"><label asp-for="Supplier.Phone" class="form-label"></label><input asp-for="Supplier.Phone" class="form-control" /></div>
    <div class="col-md-4"><label asp-for="Supplier.Email" class="form-label"></label><input asp-for="Supplier.Email" class="form-control" /></div>
    <div class="col-md-4"><label asp-for="Supplier.Terms" class="form-label"></label><input asp-for="Supplier.Terms" class="form-control" /></div>
    <div class="col-12"><label asp-for="Supplier.Address" class="form-label"></label><textarea asp-for="Supplier.Address" class="form-control"></textarea></div>
    <div class="col-12"><label asp-for="Supplier.Notes" class="form-label"></label><textarea asp-for="Supplier.Notes" class="form-control"></textarea></div>
    <div class="col-12"><div class="form-check"><input asp-for="Supplier.IsActive" class="form-check-input" /><label asp-for="Supplier.IsActive" class="form-check-label"></label></div></div>
    <div class="col-12"><button class="btn btn-primary">Save</button> <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a></div>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
