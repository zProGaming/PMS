@page
@model Vantage.PMS.Pages.System.DemoWorkflowLauncher.IndexModel
@{
    ViewData["Title"] = "Demo Workflow Launcher";
}

<div class="vpms-page-header">
    <div>
        <div class="page-kicker">Client Demo</div>
        <h1 class="vpms-page-title">Demo Workflow Launcher</h1>
        <p class="vpms-page-subtitle">Launch the major Vantage PMS demo flows from one polished control page.</p>
    </div>
    <div class="vpms-actions">
        <a class="btn vpms-btn-secondary" asp-page="/System/ClientDemoPackage/Index">Client Demo Package</a>
        <a class="btn vpms-btn-primary" asp-page="/Documents/Index">Printable Documents</a>
    </div>
</div>

<div class="row g-4">
    @foreach (var item in Model.Items)
    {
        <div class="col-md-6 col-xl-4">
            <a class="vpms-module-card text-decoration-none h-100" href="@item.Url">
                <div class="vpms-module-card-icon" aria-hidden="true"></div>
                <div>
                    <h2>@item.Title</h2>
                    <p>@item.Description</p>
                </div>
            </a>
        </div>
    }
</div>
