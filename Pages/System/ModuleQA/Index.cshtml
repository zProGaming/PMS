@page
@using Vantage.PMS.Models.SystemAdministration
@model Vantage.PMS.Pages.System.ModuleQA.IndexModel
@{
    ViewData["Title"] = "Module QA Stabilization";
    ViewData["BodyClass"] = "vpms-enterprise-control-page";
}

<div class="page-header vpms-enterprise-hero vpms-qa-hero">
    <div>
        <div class="page-kicker">System</div>
        <h1 class="page-title">Module QA Stabilization</h1>
        <p class="page-subtitle">Track end-to-end hotel workflow checks across front office, finance, operations, reports, and executive modules.</p>
    </div>
    <div class="page-actions">
        <a class="btn vpms-btn-secondary" asp-page="/System/HealthCheck/Index">System Health</a>
        <a class="btn vpms-btn-secondary" asp-page="/System/RouteReadiness/Index">Route Smoke Console</a>
        <a class="btn vpms-btn-secondary" asp-page="/System/QAChecklist/Index">Classic QA Checklist</a>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-info">@Model.StatusMessage</div>
}

@if (!Model.Items.Any())
{
    <div class="vpms-empty-state">
        <h2 class="h5">No QA checklist items are configured yet.</h2>
        <p class="mb-0">Run system seed data or add QA checklist items before the stabilization review.</p>
    </div>
}
else
{
    <div class="vpms-qa-summary-grid mb-4">
        @foreach (var summary in Model.ModuleSummaries)
        {
            <article class="vpms-card vpms-qa-summary-card">
                <div class="vpms-qa-summary-head">
                    <div>
                        <span>Module</span>
                        <h2>@summary.Module</h2>
                    </div>
                    <strong>@summary.ProgressPercent%</strong>
                </div>
                <div class="vpms-qa-progress" aria-label="@summary.ProgressPercent percent passed">
                    <span style="width: @summary.ProgressPercent%"></span>
                </div>
                <div class="vpms-qa-metrics">
                    <span><strong>@summary.Passed</strong> passed</span>
                    <span><strong>@summary.NeedsFix</strong> needs fix</span>
                    <span><strong>@summary.Failed</strong> failed</span>
                    <span><strong>@summary.NotTested</strong> not tested</span>
                </div>
            </article>
        }
    </div>

    @foreach (var group in Model.Items.GroupBy(item => item.Module))
    {
        <section class="vpms-card vpms-qa-workflow-section mb-3">
            <div class="vpms-qa-section-header">
                <div>
                    <div class="page-kicker">@group.Key</div>
                    <h2 class="h5 mb-0">Workflow Checks</h2>
                </div>
                <span class="status-badge">@group.Count() checks</span>
            </div>
            <div class="vpms-table-wrapper">
                <table class="table vpms-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Workflow</th>
                            <th>Expected Result</th>
                            <th>Status</th>
                            <th>Notes</th>
                            <th>Last Tested</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in group)
                    {
                        <tr>
                            <td class="fw-semibold">@item.TestName</td>
                            <td>@item.Description</td>
                            <td>
                                <form id="qa-form-@item.Id" method="post" asp-page-handler="Update" asp-route-id="@item.Id">
                                    <select class="form-select form-select-sm" name="status">
                                        @foreach (var status in Enum.GetValues<QATestChecklistStatus>())
                                        {
                                            <option value="@status" selected="@(status == item.Status)">@status</option>
                                        }
                                    </select>
                                </form>
                            </td>
                            <td>
                                <input form="qa-form-@item.Id" class="form-control form-control-sm" name="notes" value="@item.Notes" placeholder="Issue, evidence, or next fix" />
                            </td>
                            <td>
                                <div>@(item.TestedBy ?? "Not tested")</div>
                                <div class="small text-muted">@item.TestedAt?.ToString("g")</div>
                            </td>
                            <td class="text-end">
                                <button form="qa-form-@item.Id" class="btn btn-sm vpms-btn-primary" type="submit">Save</button>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </section>
    }
}
