@page
@model Vantage.PMS.Pages.System.ErrorLogs.IndexModel
@{
    ViewData["Title"] = "System Error Logs";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">System Error Logs</h1>
    <span class="text-muted">Page @Model.CurrentPage of @Model.TotalPages</span>
</div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-info">@Model.StatusMessage</div>
}

<form method="get" class="card card-body mb-3">
    <div class="row g-3 align-items-end">
        <div class="col-md-3">
            <label class="form-label" asp-for="Resolved">Status</label>
            <select class="form-select" asp-for="Resolved">
                <option value="">All</option>
                <option value="false">Unresolved</option>
                <option value="true">Resolved</option>
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">Filter</button>
        </div>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Date</th>
                <th>User</th>
                <th>Path</th>
                <th>Message</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var error in Model.ErrorLogs)
            {
                <tr>
                    <td>@error.ErrorDate.ToString("g")</td>
                    <td>@error.UserName</td>
                    <td>@error.Path</td>
                    <td>@error.ErrorMessage</td>
                    <td>
                        @if (error.IsResolved)
                        {
                            <span class="badge bg-success">Resolved</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Open</span>
                        }
                    </td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary" asp-page="./Details" asp-route-id="@error.Id">Details</a>
                        @if (!error.IsResolved)
                        {
                            <form method="post" asp-page-handler="Resolve" asp-route-id="@error.Id" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-outline-success">Resolve</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="d-flex justify-content-between">
    <a class="btn btn-outline-secondary @(Model.CurrentPage <= 1 ? "disabled" : "")" asp-route-currentPage="@(Model.CurrentPage - 1)" asp-route-resolved="@Model.Resolved">Previous</a>
    <a class="btn btn-outline-secondary @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")" asp-route-currentPage="@(Model.CurrentPage + 1)" asp-route-resolved="@Model.Resolved">Next</a>
</div>
