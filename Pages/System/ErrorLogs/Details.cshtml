@page "{id:int}"
@model Vantage.PMS.Pages.System.ErrorLogs.DetailsModel
@{
    ViewData["Title"] = "System Error Details";
    var error = Model.ErrorLog!;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">System Error Details</h1>
    <a class="btn btn-outline-secondary" asp-page="./Index">Back to Error Logs</a>
</div>

<dl class="row">
    <dt class="col-sm-2">Date</dt>
    <dd class="col-sm-10">@error.ErrorDate.ToString("F")</dd>
    <dt class="col-sm-2">User</dt>
    <dd class="col-sm-10">@error.UserName (@error.UserId)</dd>
    <dt class="col-sm-2">Path</dt>
    <dd class="col-sm-10">@error.Path</dd>
    <dt class="col-sm-2">Message</dt>
    <dd class="col-sm-10">@error.ErrorMessage</dd>
    <dt class="col-sm-2">Source</dt>
    <dd class="col-sm-10">@error.Source</dd>
    <dt class="col-sm-2">Status</dt>
    <dd class="col-sm-10">@(error.IsResolved ? "Resolved" : "Open")</dd>
    <dt class="col-sm-2">Resolved By</dt>
    <dd class="col-sm-10">@error.ResolvedBy</dd>
</dl>

@if (!error.IsResolved)
{
    <form method="post" asp-page-handler="Resolve" asp-route-id="@error.Id" class="card card-body mb-3">
        <label class="form-label" asp-for="Notes">Resolution notes</label>
        <textarea class="form-control" asp-for="Notes" rows="3"></textarea>
        <div class="mt-3">
            <button type="submit" class="btn btn-success">Mark Resolved</button>
        </div>
    </form>
}

<div class="card">
    <div class="card-header">Stack Trace</div>
    <pre class="card-body mb-0 small">@error.StackTrace</pre>
</div>
