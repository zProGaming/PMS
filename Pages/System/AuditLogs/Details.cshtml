@page "{id:int}"
@model Vantage.PMS.Pages.System.AuditLogs.DetailsModel
@{
    ViewData["Title"] = "Audit Log Details";
    var log = Model.AuditLog!;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">Audit Log Details</h1>
    <a class="btn btn-outline-secondary" asp-page="./Index">Back to Audit Logs</a>
</div>

<dl class="row">
    <dt class="col-sm-2">Date</dt>
    <dd class="col-sm-10">@log.CreatedAt.ToString("F")</dd>
    <dt class="col-sm-2">User</dt>
    <dd class="col-sm-10">@log.UserName (@log.UserId)</dd>
    <dt class="col-sm-2">Action</dt>
    <dd class="col-sm-10">@log.Action</dd>
    <dt class="col-sm-2">Module</dt>
    <dd class="col-sm-10">@log.Module</dd>
    <dt class="col-sm-2">Entity</dt>
    <dd class="col-sm-10">@log.EntityName #@log.EntityId</dd>
    <dt class="col-sm-2">IP Address</dt>
    <dd class="col-sm-10">@log.IpAddress</dd>
    <dt class="col-sm-2">User Agent</dt>
    <dd class="col-sm-10">@log.UserAgent</dd>
</dl>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">Old Values</div>
            <pre class="card-body mb-0 small">@log.OldValues</pre>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">New Values</div>
            <pre class="card-body mb-0 small">@log.NewValues</pre>
        </div>
    </div>
</div>
