@page
@using Vantage.PMS.Models.SystemAdministration
@model Vantage.PMS.Pages.System.AuditLogs.IndexModel
@{
    ViewData["Title"] = "Audit Logs";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">Audit Logs</h1>
    <span class="text-muted">Page @Model.CurrentPage of @Model.TotalPages</span>
</div>

<form method="get" class="card card-body mb-3">
    <div class="row g-3 align-items-end">
        <div class="col-md-2">
            <label class="form-label" asp-for="DateFrom">From</label>
            <input class="form-control" asp-for="DateFrom" type="date" />
        </div>
        <div class="col-md-2">
            <label class="form-label" asp-for="DateTo">To</label>
            <input class="form-control" asp-for="DateTo" type="date" />
        </div>
        <div class="col-md-2">
            <label class="form-label" asp-for="UserName">User</label>
            <input class="form-control" asp-for="UserName" />
        </div>
        <div class="col-md-2">
            <label class="form-label" asp-for="Module">Module</label>
            <select class="form-select" asp-for="Module">
                <option value="">All</option>
                @foreach (var module in Model.Modules)
                {
                    <option value="@module">@module</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label" asp-for="Action">Action</label>
            <select class="form-select" asp-for="Action" asp-items="Html.GetEnumSelectList<AuditActionType>()">
                <option value="">All</option>
            </select>
        </div>
        <div class="col-md-1">
            <label class="form-label" asp-for="EntityName">Entity</label>
            <input class="form-control" asp-for="EntityName" />
        </div>
        <div class="col-md-1">
            <button class="btn btn-primary w-100" type="submit">Filter</button>
        </div>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Date</th>
                <th>User</th>
                <th>Action</th>
                <th>Module</th>
                <th>Entity</th>
                <th>Entity ID</th>
                <th>IP</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var log in Model.AuditLogs)
            {
                <tr>
                    <td>@log.CreatedAt.ToString("g")</td>
                    <td>@log.UserName</td>
                    <td><span class="badge bg-secondary">@log.Action</span></td>
                    <td>@log.Module</td>
                    <td>@log.EntityName</td>
                    <td>@log.EntityId</td>
                    <td>@log.IpAddress</td>
                    <td class="text-end"><a class="btn btn-sm btn-outline-primary" asp-page="./Details" asp-route-id="@log.Id">Details</a></td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="d-flex justify-content-between">
    <a class="btn btn-outline-secondary @(Model.CurrentPage <= 1 ? "disabled" : "")" asp-route-currentPage="@(Model.CurrentPage - 1)" asp-route-dateFrom="@Model.DateFrom?.ToString("yyyy-MM-dd")" asp-route-dateTo="@Model.DateTo?.ToString("yyyy-MM-dd")" asp-route-userName="@Model.UserName" asp-route-module="@Model.Module" asp-route-action="@Model.Action" asp-route-entityName="@Model.EntityName">Previous</a>
    <a class="btn btn-outline-secondary @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")" asp-route-currentPage="@(Model.CurrentPage + 1)" asp-route-dateFrom="@Model.DateFrom?.ToString("yyyy-MM-dd")" asp-route-dateTo="@Model.DateTo?.ToString("yyyy-MM-dd")" asp-route-userName="@Model.UserName" asp-route-module="@Model.Module" asp-route-action="@Model.Action" asp-route-entityName="@Model.EntityName">Next</a>
</div>
