@page
@model Vantage.PMS.Pages.Reports.PlaceholderModel

@{
    ViewData["Title"] = Model.ReportName;
}

<section class="vpms-placeholder-command">
    <div>
        <div class="page-kicker">@Model.Category</div>
        <h1 class="vpms-page-title">@Model.ReportName</h1>
        <p class="vpms-page-subtitle">Report unavailable for the current configuration.</p>
    </div>
    <a class="btn vpms-btn-secondary" asp-page="/Reports/Center">Back to Report Center</a>
</section>

<section class="vpms-placeholder-panel">
    <div class="vpms-placeholder-mark">R</div>
    <div>
        <span>Unavailable</span>
        <h2>@Model.Message</h2>
        <div class="vpms-placeholder-actions">
            <a class="btn vpms-btn-primary" asp-page="/Reports/Center">Open Report Center</a>
            <a class="btn vpms-btn-secondary" asp-page="/Documents/Index">Printable Documents</a>
        </div>
    </div>
</section>
