@page
@using Vantage.PMS.Models.Reports
@using Vantage.PMS.Services
@model Vantage.PMS.Pages.Reports.CenterModel

@{
    ViewData["Title"] = "Report Center";
    var categories = Model.Reports
        .GroupBy(report => report.ReportCategory)
        .OrderBy(group => group.Key)
        .ToList();
    var canManageReports = Vantage.PMS.Authorization.PmsRoles.ReportAdministration.Any(User.IsInRole);
    var availableCount = Model.Reports.Count(report => report.IsAvailable);
    var printCount = Model.Reports.Count(report => report.SupportsPrint);
    var csvCount = Model.Reports.Count(report => report.SupportsCsvExport);
}

@functions {
    private static string CategoryStory(ReportCategory category) => category switch
    {
        ReportCategory.FrontOffice => "Arrival, departure, occupancy, and guest movement reporting.",
        ReportCategory.Finance => "Revenue control, cashiering, payment, and financial operations reports.",
        ReportCategory.Accounting => "GL, statements, close review, and finance leadership reporting.",
        ReportCategory.USALI => "USALI-style management reporting for department performance review.",
        ReportCategory.PhilippineFinance => "Internal Philippine tax-support registers for finance and CPA review.",
        ReportCategory.AccountsReceivable => "Aging, collections, statements, and credit-control visibility.",
        ReportCategory.AccountsPayable => "Supplier liability, voucher, payment, and disbursement reporting.",
        ReportCategory.Executive => "Owner, GM, and management committee reporting surfaces.",
        ReportCategory.FoodBeverage => "F&B sales and outlet performance reporting.",
        ReportCategory.Banquet => "Event, BEO, function room, and banquet revenue visibility.",
        ReportCategory.Inventory => "Stock, risk, movement, adjustment, and valuation reporting.",
        _ => "Operational reports curated for review, print, and export."
    };
}

<section class="vpms-report-command">
    <div>
        <div class="page-kicker">Reporting Command</div>
        <h1 class="vpms-page-title">Report Center</h1>
        <p class="vpms-page-subtitle">A curated reporting library for hotel operations, ownership review, finance control, browser print, and safe CSV export.</p>
        <div class="vpms-hero-chip-row">
            <span class="vpms-mini-chip">@Model.Reports.Count report@(Model.Reports.Count == 1 ? "" : "s") visible</span>
            <span class="vpms-mini-chip">@availableCount available now</span>
            <span class="vpms-mini-chip">@printCount print-ready</span>
            <span class="vpms-mini-chip">@csvCount CSV export@(csvCount == 1 ? "" : "s")</span>
        </div>
    </div>
    <div class="vpms-hero-actions">
        <a class="btn vpms-btn-secondary" asp-page="/Documents/Index">Printable Documents</a>
        @if (canManageReports)
        {
            <a class="btn vpms-btn-secondary" asp-page="/Reports/ExportLogs/Index">Export Logs</a>
            <a class="btn vpms-btn-secondary" asp-page="/Reports/TemplateSettings/Index">Template Settings</a>
        }
    </div>
</section>

<section class="vpms-report-proof-strip" aria-label="Report center readiness">
    <article>
        <span>Curated Library</span>
        <strong>@availableCount live report@(availableCount == 1 ? "" : "s")</strong>
        <p>Unavailable reports route to controlled status pages instead of broken links.</p>
    </article>
    <article>
        <span>Print Discipline</span>
        <strong>@printCount print-ready surface@(printCount == 1 ? "" : "s")</strong>
        <p>Browser print and Save as PDF remain the standard export path.</p>
    </article>
    <article>
        <span>Data Export</span>
        <strong>@csvCount CSV export@(csvCount == 1 ? "" : "s")</strong>
        <p>CSV is surfaced only where simple table exports are supported safely.</p>
    </article>
</section>

<section class="vpms-filter-bar vpms-report-filter-premium">
    <form method="get">
        <div>
            <label class="form-label" for="search">Search</label>
            <input class="form-control" id="search" name="search" value="@Model.Search" placeholder="Search reports, categories, or descriptions" />
        </div>
        <div>
            <label class="form-label" for="category">Category</label>
            <select class="form-select" id="category" asp-for="Category" asp-items="Html.GetEnumSelectList<ReportCategory>()">
                <option value="">All categories</option>
            </select>
        </div>
        <div class="vpms-filter-actions">
            <button class="btn vpms-btn-primary" type="submit">Filter</button>
            <a class="btn vpms-btn-secondary" asp-page="/Reports/Center">Reset</a>
        </div>
    </form>
</section>

@if (Model.Reports.Count == 0)
{
    <section class="vpms-empty-state">
        <strong>No reports found.</strong>
        <span>Adjust the filters or confirm your role has report access.</span>
    </section>
}
else
{
    <div class="vpms-report-center vpms-report-center-premium">
        @foreach (var category in categories)
        {
            var availableInCategory = category.Count(report => report.IsAvailable);
            <section class="vpms-section-card vpms-report-category">
                <div class="vpms-report-category-header">
                    <div>
                        <div class="vpms-report-card-kicker">@ReportCatalogService.FormatCategory(category.Key)</div>
                        <h2>@ReportCatalogService.FormatCategory(category.Key)</h2>
                        <p>@CategoryStory(category.Key)</p>
                    </div>
                    <div class="vpms-report-category-meter">
                        <strong>@availableInCategory / @category.Count()</strong>
                        <span>available now</span>
                    </div>
                </div>
                <div class="vpms-report-card-grid">
                    @foreach (var report in category)
                    {
                        var placeholderUrl = Url.Page("/Reports/Placeholder", new { reportName = report.ReportName, category = ReportCatalogService.FormatCategory(report.ReportCategory) });
                        var openUrl = report.IsAvailable ? report.RoutePath : placeholderUrl;
                        var csvUrl = report.SupportsCsvExport
                            ? Url.Page("/Reports/Export", "Csv", new { reportKey = report.ReportKey })
                            : null;
                        <article class="vpms-report-card @(report.IsAvailable ? "is-available" : "is-planned")">
                            <div class="vpms-report-card-body">
                                <div class="vpms-report-card-kicker">@(report.IsAvailable ? "Ready for review" : "Controlled status")</div>
                                <h3>@report.ReportName</h3>
                                <p>@report.Description</p>
                            </div>
                            <div class="vpms-report-capabilities" aria-label="Report capabilities">
                                <span class="@(report.SupportsPrint ? "is-on" : "is-muted")">Print</span>
                                <span class="@(report.SupportsPdfViaBrowserPrint ? "is-on" : "is-muted")">Browser PDF</span>
                                <span class="@(report.SupportsCsvExport ? "is-on" : "is-muted")">CSV</span>
                                <span class="@(report.SupportsHtmlExport ? "is-on" : "is-muted")">HTML</span>
                            </div>
                            <div class="vpms-report-card-actions">
                                <a class="btn vpms-btn-primary btn-sm" href="@openUrl">@(report.IsAvailable ? "Open Report" : "View Status")</a>
                                @if (!string.IsNullOrWhiteSpace(csvUrl))
                                {
                                    <a class="btn vpms-btn-secondary btn-sm" href="@csvUrl">CSV</a>
                                }
                                else
                                {
                                    <span class="btn vpms-btn-secondary btn-sm disabled">CSV unavailable</span>
                                }
                            </div>
                            @if (!report.IsAvailable)
                            {
                                <div class="vpms-report-unavailable">Capability is visible for planning, with no broken route exposed.</div>
                            }
                        </article>
                    }
                </div>
            </section>
        }
    </div>
}
