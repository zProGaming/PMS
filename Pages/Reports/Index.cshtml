@page
@model Vantage.PMS.Pages.Reports.IndexModel

@{
    ViewData["Title"] = "Reports";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="mb-1">Reports</h1>
        <p class="text-muted mb-0">Business date: @Model.BusinessDate.ToString("D")</p>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-6 col-xl-4">
        <a class="text-decoration-none text-dark" asp-page="./Occupancy">
            <div class="border rounded p-3 h-100">
                <div class="fw-semibold">Occupancy Report</div>
                <div class="text-muted small mt-2">Room inventory and occupancy percentage.</div>
            </div>
        </a>
    </div>
    <div class="col-md-6 col-xl-4">
        <a class="text-decoration-none text-dark" asp-page="./Arrivals">
            <div class="border rounded p-3 h-100">
                <div class="fw-semibold">Arrivals Report</div>
                <div class="text-muted small mt-2">Reservations arriving on the business date.</div>
            </div>
        </a>
    </div>
    <div class="col-md-6 col-xl-4">
        <a class="text-decoration-none text-dark" asp-page="./Departures">
            <div class="border rounded p-3 h-100">
                <div class="fw-semibold">Departures Report</div>
                <div class="text-muted small mt-2">Reservations departing on the business date.</div>
            </div>
        </a>
    </div>
    <div class="col-md-6 col-xl-4">
        <a class="text-decoration-none text-dark" asp-page="./InHouse">
            <div class="border rounded p-3 h-100">
                <div class="fw-semibold">In-House Guest Report</div>
                <div class="text-muted small mt-2">Checked-in guests and current balances.</div>
            </div>
        </a>
    </div>
    <div class="col-md-6 col-xl-4">
        <a class="text-decoration-none text-dark" asp-page="./DailyRevenue">
            <div class="border rounded p-3 h-100">
                <div class="fw-semibold">Daily Revenue Report</div>
                <div class="text-muted small mt-2">Charges, payments, and outstanding balances.</div>
            </div>
        </a>
    </div>
</div>
