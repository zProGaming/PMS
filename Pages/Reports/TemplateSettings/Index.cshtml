@page
@using Vantage.PMS.Models.Reports
@model Vantage.PMS.Pages.Reports.TemplateSettings.IndexModel

@{
    ViewData["Title"] = "Report Template Settings";
}

<div class="vpms-page-header">
    <div>
        <div class="page-kicker">Reports</div>
        <h1 class="vpms-page-title">Report Template Settings</h1>
        <p class="vpms-page-subtitle">Configure reusable report headers, footers, date range display, orientation, and disclaimers.</p>
    </div>
    <a class="btn vpms-btn-secondary" asp-page="/Reports/Center">Report Center</a>
</div>

<section class="vpms-form-card mb-4">
    <form method="post" asp-page-handler="Save">
        <input type="hidden" asp-for="Input.Id" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="vpms-form-grid">
            <div>
                <label class="form-label" asp-for="Input.ReportKey">Report key</label>
                <input class="form-control" asp-for="Input.ReportKey" placeholder="default" />
                <span class="text-danger" asp-validation-for="Input.ReportKey"></span>
            </div>
            <div>
                <label class="form-label" asp-for="Input.ReportName">Report name</label>
                <input class="form-control" asp-for="Input.ReportName" placeholder="Default Vantage Report" />
                <span class="text-danger" asp-validation-for="Input.ReportName"></span>
            </div>
            <div>
                <label class="form-label" asp-for="Input.ReportCategory">Category</label>
                <select class="form-select" asp-for="Input.ReportCategory" asp-items="Html.GetEnumSelectList<ReportCategory>()"></select>
            </div>
            <div>
                <label class="form-label" asp-for="Input.HeaderTitle">Header title</label>
                <input class="form-control" asp-for="Input.HeaderTitle" placeholder="Vantage PMS Report" />
                <span class="text-danger" asp-validation-for="Input.HeaderTitle"></span>
            </div>
            <div class="vpms-form-grid-span">
                <label class="form-label" asp-for="Input.FooterText">Footer text</label>
                <input class="form-control" asp-for="Input.FooterText" placeholder="Generated by Vantage PMS." />
            </div>
            <div class="vpms-form-grid-span">
                <label class="form-label" asp-for="Input.DisclaimerText">Disclaimer</label>
                <textarea class="form-control" asp-for="Input.DisclaimerText" rows="2"></textarea>
            </div>
        </div>

        <div class="vpms-toggle-grid mt-3">
            <label><input class="form-check-input" asp-for="Input.ShowLogo" /> Show logo</label>
            <label><input class="form-check-input" asp-for="Input.ShowHotelName" /> Show hotel name</label>
            <label><input class="form-check-input" asp-for="Input.ShowPreparedBy" /> Show prepared by</label>
            <label><input class="form-check-input" asp-for="Input.ShowReviewedBy" /> Show reviewed by</label>
            <label><input class="form-check-input" asp-for="Input.ShowGeneratedDate" /> Show generated date</label>
            <label><input class="form-check-input" asp-for="Input.ShowDateRange" /> Show date range</label>
            <label><input class="form-check-input" asp-for="Input.ShowDisclaimer" /> Show disclaimer</label>
            <label><input class="form-check-input" asp-for="Input.IsLandscape" /> Landscape print</label>
            <label><input class="form-check-input" asp-for="Input.IsActive" /> Active</label>
        </div>

        <div class="vpms-actions mt-4">
            <button class="btn vpms-btn-primary" type="submit">Save Setting</button>
            <a class="btn vpms-btn-secondary" asp-page="/Reports/TemplateSettings/Index">New</a>
        </div>
    </form>
</section>

<section class="vpms-card">
    <div class="vpms-table-wrapper">
        <table class="table vpms-table align-middle">
            <thead>
            <tr>
                <th>Report</th>
                <th>Category</th>
                <th>Header</th>
                <th>Options</th>
                <th>Status</th>
                <th class="text-end">Actions</th>
            </tr>
            </thead>
            <tbody>
            @if (Model.Settings.Count == 0)
            {
                <tr><td colspan="6"><div class="vpms-empty-state">No report template settings have been configured.</div></td></tr>
            }
            else
            {
                @foreach (var setting in Model.Settings)
                {
                    <tr>
                        <td>
                            <strong>@setting.ReportName</strong>
                            <div class="text-muted small">@setting.ReportKey</div>
                        </td>
                        <td>@setting.ReportCategory</td>
                        <td>@setting.HeaderTitle</td>
                        <td>
                            <span class="vpms-badge">@(setting.IsLandscape ? "Landscape" : "Portrait")</span>
                            @if (setting.ShowDisclaimer)
                            {
                                <span class="vpms-badge">Disclaimer</span>
                            }
                        </td>
                        <td><span class="vpms-status-badge @(setting.IsActive ? "status-approved" : "status-draft")">@(setting.IsActive ? "Active" : "Inactive")</span></td>
                        <td class="text-end">
                            <a class="btn btn-sm vpms-btn-secondary" asp-page-handler="Edit" asp-route-id="@setting.Id">Edit</a>
                            <form method="post" asp-page-handler="Toggle" asp-route-id="@setting.Id" class="d-inline">
                                <button class="btn btn-sm vpms-btn-secondary" type="submit">@(setting.IsActive ? "Deactivate" : "Activate")</button>
                            </form>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
