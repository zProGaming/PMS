@page
@model Vantage.PMS.Pages.Reports.InHouseModel

@{
    ViewData["Title"] = "In-House Guest Report";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="mb-1">In-House Guest Report</h1>
        <p class="text-muted mb-0">Business date: @Model.BusinessDate.ToString("D")</p>
    </div>
    <a class="btn btn-outline-secondary" asp-page="./Index">Reports</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>Guest</th>
            <th>Room</th>
            <th>Arrival Date</th>
            <th>Departure Date</th>
            <th class="text-end">Balance</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.InHouseGuests.Count == 0)
        {
            <tr>
                <td colspan="5" class="text-muted">No in-house guests found.</td>
            </tr>
        }
        @foreach (var guest in Model.InHouseGuests)
        {
            <tr>
                <td>@guest.GuestName</td>
                <td>@guest.RoomNumber</td>
                <td>@guest.ArrivalDate.ToString("d")</td>
                <td>@guest.DepartureDate.ToString("d")</td>
                <td class="text-end">@guest.Balance.ToString("N2")</td>
            </tr>
        }
    </tbody>
</table>
