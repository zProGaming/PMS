@page
@model Vantage.PMS.Pages.Reports.DeparturesModel

@{
    ViewData["Title"] = "Departures Report";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="mb-1">Departures Report</h1>
        <p class="text-muted mb-0">Business date: @Model.BusinessDate.ToString("D")</p>
    </div>
    <a class="btn btn-outline-secondary" asp-page="./Index">Reports</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>Business Date</th>
            <th>Guest</th>
            <th>Room</th>
            <th>Check-out Date</th>
            <th class="text-end">Balance</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Departures.Count == 0)
        {
            <tr>
                <td colspan="6" class="text-muted">No departures found for this business date.</td>
            </tr>
        }
        @foreach (var departure in Model.Departures)
        {
            <tr>
                <td>@departure.BusinessDate.ToString("d")</td>
                <td>@departure.GuestName</td>
                <td>@departure.RoomNumber</td>
                <td>@departure.CheckOutDate.ToString("d")</td>
                <td class="text-end">@departure.Balance.ToString("N2")</td>
                <td>@departure.Status</td>
            </tr>
        }
    </tbody>
</table>
