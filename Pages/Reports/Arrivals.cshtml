@page
@model Vantage.PMS.Pages.Reports.ArrivalsModel

@{
    ViewData["Title"] = "Arrivals Report";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="mb-1">Arrivals Report</h1>
        <p class="text-muted mb-0">Business date: @Model.BusinessDate.ToString("D")</p>
    </div>
    <a class="btn btn-outline-secondary" asp-page="./Index">Reports</a>
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>Business Date</th>
            <th>Guest</th>
            <th>Room</th>
            <th>Check-in Date</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Arrivals.Count == 0)
        {
            <tr>
                <td colspan="5" class="text-muted">No arrivals found for this business date.</td>
            </tr>
        }
        @foreach (var arrival in Model.Arrivals)
        {
            <tr>
                <td>@arrival.BusinessDate.ToString("d")</td>
                <td>@arrival.GuestName</td>
                <td>@arrival.RoomNumber</td>
                <td>@arrival.CheckInDate.ToString("d")</td>
                <td>@arrival.Status</td>
            </tr>
        }
    </tbody>
</table>
