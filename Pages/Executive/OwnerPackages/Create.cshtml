@page
@model Vantage.PMS.Pages.Executive.OwnerPackages.CreateModel
@{
    ViewData["Title"] = "Create Owner Report Package";
}
<div class="page-header"><div><div class="page-kicker">Executive Reports</div><h1 class="page-title">Create Owner Report Package</h1><p class="page-subtitle">Build a curated package with executive summary, KPI scorecard, department performance, financial summary, and action items.</p></div><a class="btn vpms-btn-secondary" asp-page="/Executive/OwnerPackages/Index">Back</a></div>
<section class="vpms-form-card">
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="row g-3">
            <div class="col-md-6"><label class="form-label">Package Name</label><input asp-for="Input.PackageName" class="form-control" required /></div>
            <div class="col-md-6"><label class="form-label">Prepared For</label><input asp-for="Input.PreparedFor" class="form-control" required /></div>
            <div class="col-md-6"><label class="form-label">Period Start</label><input asp-for="Input.PeriodStart" type="date" class="form-control" /></div>
            <div class="col-md-6"><label class="form-label">Period End</label><input asp-for="Input.PeriodEnd" type="date" class="form-control" /></div>
        </div>
        <div class="vpms-actions mt-3"><button class="btn vpms-btn-primary">Create Package</button><a class="btn vpms-btn-secondary" asp-page="/Executive/OwnerPackages/Index">Cancel</a></div>
    </form>
</section>
