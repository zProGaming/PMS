@page "{id:int}"
@model Vantage.PMS.Pages.Executive.OwnerPackages.DetailsModel
@{
    ViewData["Title"] = "Owner Report Package Details";
}
<div class="page-header"><div><div class="page-kicker">Executive Reports</div><h1 class="page-title">Owner Report Package Details</h1><p class="page-subtitle">Included report sections and package metadata.</p></div><div class="page-actions"><a class="btn vpms-btn-secondary" asp-page="/Executive/OwnerPackages/Index">Back</a>@if(Model.Package is not null){<a class="btn vpms-btn-primary" asp-page="/Executive/OwnerPackages/Print" asp-route-id="@Model.Package.Id">Print Package</a>}</div></div>
@if(Model.Package is not null){<section class="vpms-card mb-4"><dl class="row"><dt class="col-md-3">Package</dt><dd class="col-md-9">@Model.Package.PackageName</dd><dt class="col-md-3">Prepared For</dt><dd class="col-md-9">@Model.Package.PreparedFor</dd><dt class="col-md-3">Period</dt><dd class="col-md-9">@Model.Package.PeriodStart.ToString("MMM d, yyyy") - @Model.Package.PeriodEnd.ToString("MMM d, yyyy")</dd><dt class="col-md-3">Prepared By</dt><dd class="col-md-9">@Model.Package.PreparedBy</dd><dt class="col-md-3">Status</dt><dd class="col-md-9"><span class="status-badge">@Model.Package.Status</span></dd></dl></section><section class="vpms-card"><h2 class="h5">Package Items</h2><div class="vpms-table-wrapper"><table class="table vpms-table"><thead><tr><th>Sort</th><th>Report</th><th>Type</th><th>Included</th><th>Notes</th></tr></thead><tbody>@foreach(var item in Model.Package.Items.OrderBy(item => item.SortOrder)){<tr><td>@item.SortOrder</td><td>@item.ReportName</td><td>@item.ReportType</td><td>@(item.IsIncluded ? "Yes" : "No")</td><td>@item.Notes</td></tr>}</tbody></table></div></section>}
