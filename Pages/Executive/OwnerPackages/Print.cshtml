@page "{id:int}"
@model Vantage.PMS.Pages.Executive.OwnerPackages.PrintModel
@using Vantage.PMS.Services
@{
    Layout = "_PrintLayout";
    ViewData["Title"] = "Print Owner Report Package";
    var view = Model.View;
}
@if (view is not null)
{
    <div class="vpms-report-actions vpms-no-print mb-3"><button class="btn vpms-btn-primary" onclick="window.print()">Print / Save as PDF</button><a class="btn vpms-btn-secondary" asp-page="/Executive/OwnerPackages/Details" asp-route-id="@view.Package.Id">Back</a></div>
    <article class="vpms-print-document">
        <section class="vpms-print-section text-center" style="padding: 3rem 0;">
            <h1>Vantage PMS</h1>
            <h2>@view.Package.PackageName</h2>
            <p>Prepared for @view.Package.PreparedFor</p>
            <p>@view.Package.PeriodStart.ToString("MMMM d, yyyy") - @view.Package.PeriodEnd.ToString("MMMM d, yyyy")</p>
            <p>Prepared by @view.Package.PreparedBy on @view.Package.PreparedAt.ToString("MMMM d, yyyy")</p>
        </section>
        <section class="vpms-print-section"><h2>Executive Summary</h2><p>@ExecutiveReportingService.BuildExecutiveSummaryText(view.Summary)</p></section>
        <section class="vpms-print-section"><h2>KPI Scorecard</h2><table class="vpms-print-table"><thead><tr><th>KPI</th><th>Actual</th><th>Target</th><th>Status</th></tr></thead><tbody>@foreach(var kpi in view.Kpis.Take(20)){<tr><td>@kpi.KPIName</td><td>@kpi.ActualValue.ToString("N2")</td><td>@(kpi.TargetValue?.ToString("N2") ?? "-")</td><td>@kpi.Status</td></tr>}</tbody></table></section>
        <section class="vpms-print-section"><h2>Department Performance</h2><table class="vpms-print-table"><thead><tr><th>Department</th><th>Revenue</th><th>Labor</th><th>Profit</th><th>Margin</th></tr></thead><tbody>@foreach(var row in view.Departments){<tr><td>@row.DepartmentName</td><td>@row.Revenue.ToString("C")</td><td>@row.PayrollCost.ToString("C")</td><td>@row.DepartmentProfit.ToString("C")</td><td>@row.DepartmentProfitMargin.ToString("N1")%</td></tr>}</tbody></table></section>
        <section class="vpms-print-section"><h2>Financial Results</h2><table class="vpms-print-table"><tbody><tr><th>Total Revenue</th><td>@view.Summary.TotalRevenue.ToString("C")</td><th>GOP</th><td>@view.Summary.GrossOperatingProfit.ToString("C")</td></tr><tr><th>AR Balance</th><td>@view.Summary.ARBalance.ToString("C")</td><th>AP Balance</th><td>@view.Summary.APBalance.ToString("C")</td></tr><tr><th>Labor Cost</th><td>@view.Summary.LaborCost.ToString("C")</td><th>Labor Cost %</th><td>@view.Summary.LaborCostPercentage.ToString("N1")%</td></tr></tbody></table></section>
        <section class="vpms-print-section"><h2>Review</h2><div class="vpms-print-signatures"><div>Prepared By</div><div>Reviewed By</div><div>Approved By</div></div></section>
        <footer class="vpms-print-footer">Generated by Vantage PMS. Management reports are configurable and should be reviewed by authorized finance personnel before official filing or submission.</footer>
    </article>
}
