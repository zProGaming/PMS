@page
@model Vantage.PMS.Pages.Executive.IndexModel
@{
    ViewData["Title"] = "Executive Dashboard";
    var summary = Model.Dashboard.Summary;
    var performancePosture = summary.OpenCriticalIssues > 0 ? "Risk review required" : summary.TotalRevenue > 0 ? "Performance review ready" : "Awaiting posted activity";
    var cashPosture = summary.ARBalance > summary.CashPaymentsToday ? "Monitor collections" : "Cash position steady";
    var laborPosture = summary.LaborCostPercentage > 35 ? "Labor pressure watch" : "Labor ratio controlled";
}

@functions {
    private static decimal Share(decimal value, decimal total) => total <= 0 ? 0 : Math.Round(value / total * 100, 1);
}

<section class="vpms-ops-hero vpms-executive-hero">
    <div>
        <div class="page-kicker">Owner / GM Intelligence</div>
        <h1 class="page-title">Executive Command View</h1>
        <p class="page-subtitle">Performance, cash exposure, labor discipline, and management attention.</p>
        <div class="vpms-hero-chip-row">
            <span class="vpms-mini-chip">@summary.HotelName</span>
            <span class="vpms-mini-chip">@Model.StartDate.ToString("MMM d") - @Model.EndDate.ToString("MMM d, yyyy")</span>
            <span class="vpms-mini-chip">Business date @summary.BusinessDate.ToString("MMM d, yyyy")</span>
        </div>
    </div>
    <div class="vpms-hero-intelligence vpms-no-print">
        <span>Ownership posture</span>
        <strong>@performancePosture</strong>
        <small>@summary.TotalRevenue.ToString("C0") selected-period revenue with @summary.OpenCriticalIssues critical alert@(summary.OpenCriticalIssues == 1 ? "" : "s").</small>
        <div class="vpms-hero-actions">
            <a class="btn vpms-btn-secondary" asp-page="/Executive/Snapshots/Index">Generate Snapshot</a>
            <a class="btn vpms-btn-secondary" asp-page="/Executive/MonthlyOwnerReport">Monthly Owner Report</a>
            <button type="button" class="btn vpms-btn-primary" onclick="window.print()">Print</button>
        </div>
    </div>
</section>

<form method="get" class="vpms-filter-bar vpms-no-print">
    <div>
        <label class="form-label">From</label>
        <input class="form-control" type="date" name="StartDate" value="@Model.StartDate.ToString("yyyy-MM-dd")" />
    </div>
    <div>
        <label class="form-label">To</label>
        <input class="form-control" type="date" name="EndDate" value="@Model.EndDate.ToString("yyyy-MM-dd")" />
    </div>
    <div class="vpms-filter-actions">
        <button class="btn vpms-btn-primary">Refresh View</button>
    </div>
</form>

<section class="vpms-print-document vpms-executive-board">
    <section class="vpms-board-brief" aria-label="Executive briefing">
        <article class="@(summary.OpenCriticalIssues > 0 ? "danger" : "positive")">
            <span>Ownership Posture</span>
            <strong>@performancePosture</strong>
            <p>@summary.OpenCriticalIssues critical alert@(summary.OpenCriticalIssues == 1 ? "" : "s") and @summary.PendingApprovals pending approval@(summary.PendingApprovals == 1 ? "" : "s").</p>
        </article>
        <article>
            <span>Cash Discipline</span>
            <strong>@cashPosture</strong>
            <p>@summary.CashPaymentsToday.ToString("C0") cash payments today against @summary.ARBalance.ToString("C0") AR exposure.</p>
        </article>
        <article class="@(summary.LaborCostPercentage > 35 ? "warning" : "positive")">
            <span>Labor Discipline</span>
            <strong>@laborPosture</strong>
            <p>@summary.LaborCostPercentage.ToString("N1")% labor cost against selected-period revenue.</p>
        </article>
    </section>

    <section class="vpms-control-strip vpms-executive-strip">
        <article>
            <span>Occupancy</span>
            <strong>@summary.OccupancyPercentage.ToString("N1")%</strong>
            <small>@summary.OccupiedRooms of @summary.TotalRooms rooms</small>
        </article>
        <article>
            <span>ADR</span>
            <strong>@summary.ADR.ToString("C0")</strong>
            <small>Average daily rate</small>
        </article>
        <article>
            <span>RevPAR</span>
            <strong>@summary.RevPAR.ToString("C0")</strong>
            <small>Revenue per available room</small>
        </article>
        <article class="@(summary.OpenCriticalIssues > 0 ? "danger" : "positive")">
            <span>Critical Alerts</span>
            <strong>@summary.OpenCriticalIssues</strong>
            <small>Unresolved executive risks</small>
        </article>
    </section>

    <div class="vpms-two-column vpms-executive-layout">
        <main class="vpms-stack">
            <section class="vpms-card vpms-operational-panel">
                <div class="vpms-section-titlebar">
                    <div>
                        <h2>Financial Position</h2>
                        <p>Revenue, collections, receivables, payables, and labor exposure.</p>
                    </div>
                </div>
                <div class="vpms-finance-grid">
                    <div><span>Total Revenue</span><strong>@summary.TotalRevenue.ToString("C")</strong><small>Selected period</small></div>
                    <div><span>Revenue MTD</span><strong>@summary.TotalRevenueMonthToDate.ToString("C")</strong><small>Month-to-date</small></div>
                    <div><span>Cash Payments Today</span><strong>@summary.CashPaymentsToday.ToString("C")</strong><small>Completed folio payments</small></div>
                    <div><span>Net Income</span><strong>@summary.NetIncome.ToString("C")</strong><small>Where mapped</small></div>
                    <div><span>AR Balance</span><strong>@summary.ARBalance.ToString("C")</strong><small>Open city ledger</small></div>
                    <div><span>AP Balance</span><strong>@summary.APBalance.ToString("C")</strong><small>Supplier liability</small></div>
                    <div><span>Labor MTD</span><strong>@summary.LaborCostMonthToDate.ToString("C")</strong><small>@summary.LaborCostPercentage.ToString("N1")% of revenue</small></div>
                    <div><span>Guest Rating</span><strong>@(summary.GuestSatisfactionScore?.ToString("N1") ?? "0.0")</strong><small>Average feedback score</small></div>
                </div>
            </section>

            <section class="vpms-card vpms-operational-panel">
                <div class="vpms-section-titlebar">
                    <div>
                        <h2>Revenue Architecture</h2>
                        <p>Revenue share by operating stream.</p>
                    </div>
                </div>
                <div class="vpms-revenue-mix">
                    <div><span>Rooms</span><strong>@summary.TotalRoomRevenue.ToString("C")</strong><small>@Share(summary.TotalRoomRevenue, summary.TotalRevenue).ToString("N1")%</small></div>
                    <div><span>F&amp;B</span><strong>@summary.TotalFBRevenue.ToString("C")</strong><small>@Share(summary.TotalFBRevenue, summary.TotalRevenue).ToString("N1")%</small></div>
                    <div><span>Banquet</span><strong>@summary.TotalBanquetRevenue.ToString("C")</strong><small>@Share(summary.TotalBanquetRevenue, summary.TotalRevenue).ToString("N1")%</small></div>
                    <div><span>Other</span><strong>@summary.TotalOtherRevenue.ToString("C")</strong><small>@Share(summary.TotalOtherRevenue, summary.TotalRevenue).ToString("N1")%</small></div>
                </div>
            </section>

            <section class="vpms-card vpms-operational-panel">
                <div class="vpms-section-titlebar">
                    <div>
                        <h2>Department Performance</h2>
                        <p>Revenue, labor, profit, and margin by department.</p>
                    </div>
                    <a class="btn vpms-btn-secondary vpms-no-print" asp-page="/Executive/DepartmentPerformance">Open Department View</a>
                </div>
                @if (Model.Dashboard.Departments.Count == 0)
                {
                    <div class="vpms-empty-state">No department performance data found for the selected period.</div>
                }
                else
                {
                    <div class="vpms-table-wrapper">
                        <table class="table vpms-table align-middle">
                            <thead><tr><th>Department</th><th class="text-end">Revenue</th><th class="text-end">Labor</th><th class="text-end">Profit</th><th class="text-end">Margin</th></tr></thead>
                            <tbody>
                            @foreach (var row in Model.Dashboard.Departments)
                            {
                                <tr>
                                    <td class="fw-semibold">@row.DepartmentName</td>
                                    <td class="text-end">@row.Revenue.ToString("C")</td>
                                    <td class="text-end">@row.PayrollCost.ToString("C")</td>
                                    <td class="text-end">@row.DepartmentProfit.ToString("C")</td>
                                    <td class="text-end">@row.DepartmentProfitMargin.ToString("N1")%</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            </section>
        </main>

        <aside class="vpms-stack">
            <section class="vpms-card vpms-operational-panel">
                <div class="vpms-section-titlebar">
                    <div>
                        <h2>Operational Attention</h2>
                        <p>Open management signals.</p>
                    </div>
                </div>
                <div class="vpms-risk-list">
                    <div><span>Pending approvals</span><strong>@summary.PendingApprovals</strong></div>
                    <div><span>Low stock risk</span><strong>@summary.LowStockRisk</strong></div>
                    <div><span>High balance folios</span><strong>@summary.HighBalanceFolios</strong></div>
                    <div><span>Open service requests</span><strong>@summary.OpenServiceRequests</strong></div>
                </div>
            </section>

            <section class="vpms-card vpms-operational-panel">
                <div class="vpms-section-titlebar">
                    <div>
                        <h2>Executive Alerts</h2>
                        <p>Unresolved alerts by severity and area.</p>
                    </div>
                </div>
                @if (Model.Dashboard.Alerts.Count == 0)
                {
                    <div class="vpms-empty-state">No unresolved executive alerts.</div>
                }
                else
                {
                    <div class="vpms-alert-list">
                        @foreach (var alert in Model.Dashboard.Alerts)
                        {
                            <div>
                                <strong>@alert.Title</strong>
                                <span>@alert.Module</span>
                                <small>@alert.Severity</small>
                            </div>
                        }
                    </div>
                    <a class="btn vpms-btn-secondary w-100 mt-3 vpms-no-print" asp-page="/Executive/Alerts/Index">View Alerts</a>
                }
            </section>

            <section class="vpms-card vpms-operational-panel">
                <div class="vpms-section-titlebar">
                    <div>
                        <h2>KPI Watchlist</h2>
                        <p>Key indicators and benchmark posture.</p>
                    </div>
                </div>
                @if (Model.Dashboard.Kpis.Count == 0)
                {
                    <div class="vpms-empty-state">No KPI results are available for the selected period.</div>
                }
                else
                {
                    <div class="vpms-kpi-watchlist">
                        @foreach (var kpi in Model.Dashboard.Kpis.Take(8))
                        {
                            <div>
                                <span>@kpi.KPIName</span>
                                <strong>@kpi.ActualValue.ToString("N1")</strong>
                                <small class="vpms-status-badge status-@kpi.Status.ToString().ToLowerInvariant()">@kpi.Status</small>
                            </div>
                        }
                    </div>
                    <a class="btn vpms-btn-secondary w-100 mt-3 vpms-no-print" asp-page="/Executive/KPIScorecard">Open KPI Scorecard</a>
                }
            </section>

            <section class="vpms-card vpms-operational-panel">
                <div class="vpms-section-titlebar">
                    <div>
                        <h2>Seven-Day Movement</h2>
                        <p>Occupancy and revenue direction.</p>
                    </div>
                </div>
                <div class="vpms-table-wrapper">
                    <table class="table vpms-table align-middle">
                        <thead><tr><th>Date</th><th class="text-end">Occ.</th><th class="text-end">Revenue</th></tr></thead>
                        <tbody>
                        @foreach (var trend in Model.Dashboard.Trend)
                        {
                            <tr><td>@trend.Date.ToString("MMM d")</td><td class="text-end">@trend.OccupancyPercentage.ToString("N1")%</td><td class="text-end">@trend.Revenue.ToString("C")</td></tr>
                        }
                        </tbody>
                    </table>
                </div>
            </section>
        </aside>
    </div>
</section>
