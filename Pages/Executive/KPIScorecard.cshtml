@page
@model Vantage.PMS.Pages.Executive.KPIScorecardModel
@using Vantage.PMS.Models.Executive
@{
    ViewData["Title"] = "KPI Scorecard";
}

<div class="page-header">
    <div>
        <div class="page-kicker">Executive Reports</div>
        <h1 class="page-title">KPI Scorecard</h1>
        <p class="page-subtitle">Targets, actuals, variance, and executive status by KPI category.</p>
    </div>
    <div class="page-actions vpms-no-print">
        <a class="btn vpms-btn-secondary" asp-page="/Executive/KPIBenchmarks/Index">KPI Benchmarks</a>
        <button class="btn vpms-btn-primary" onclick="window.print()">Print</button>
        <a class="btn vpms-btn-secondary" asp-page="/Reports/Export" asp-page-handler="Csv" asp-route-reportKey="kpi-scorecard" asp-route-dateRangeStart="@Model.StartDate.ToString("yyyy-MM-dd")" asp-route-dateRangeEnd="@Model.EndDate.ToString("yyyy-MM-dd")">Export CSV</a>
    </div>
</div>

<form method="get" class="vpms-card report-filter vpms-no-print mb-3">
    <div class="row g-3 align-items-end">
        <div class="col-md-3"><label class="form-label">From</label><input class="form-control" type="date" name="StartDate" value="@Model.StartDate.ToString("yyyy-MM-dd")" /></div>
        <div class="col-md-3"><label class="form-label">To</label><input class="form-control" type="date" name="EndDate" value="@Model.EndDate.ToString("yyyy-MM-dd")" /></div>
        <div class="col-md-2"><label class="form-label">Category</label><select class="form-select" name="Category"><option value="">All</option>@foreach (var value in Enum.GetValues<ExecutiveKPICategory>()) { <option value="@value" selected="@(Model.Category == value)">@value</option> }</select></div>
        <div class="col-md-2"><label class="form-label">Status</label><select class="form-select" name="Status"><option value="">All</option>@foreach (var value in Enum.GetValues<KPIStatus>()) { <option value="@value" selected="@(Model.Status == value)">@value</option> }</select></div>
        <div class="col-md-2"><button class="btn vpms-btn-primary w-100">Run</button></div>
    </div>
</form>

<section class="vpms-card vpms-print-document">
    @if (Model.Rows.Count == 0)
    {
        <div class="vpms-empty-state">No KPI results found for the selected filters.</div>
    }
    else
    {
        <div class="vpms-table-wrapper">
            <table class="table vpms-table align-middle">
                <thead><tr><th>KPI</th><th>Category</th><th class="text-end">Actual</th><th class="text-end">Target</th><th class="text-end">Variance</th><th class="text-end">Variance %</th><th>Status</th></tr></thead>
                <tbody>
                @foreach (var row in Model.Rows)
                {
                    <tr>
                        <td><div class="fw-semibold">@row.KPIName</div><div class="small text-muted">@row.FormulaDescription</div></td>
                        <td>@row.Category</td>
                        <td class="text-end">@row.ActualValue.ToString("N2")</td>
                        <td class="text-end">@(row.TargetValue?.ToString("N2") ?? "-")</td>
                        <td class="text-end">@(row.Variance?.ToString("N2") ?? "-")</td>
                        <td class="text-end">@(row.VariancePercentage?.ToString("N1") ?? "-")</td>
                        <td><span class="status-badge">@row.Status</span></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>
