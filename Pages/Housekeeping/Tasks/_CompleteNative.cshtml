@model Vantage.PMS.Pages.Housekeeping.Tasks.IndexModel

@{
    var task = Model.SelectedTask!;
}

<section class="vpms-native-modal-intro vpms-native-hk-intro">
    <div>
        <span class="page-kicker">Housekeeping Task</span>
        <h1>Complete Task</h1>
        <p>Confirm completion so room readiness and supervisory queues stay aligned.</p>
    </div>
    <div class="vpms-native-balance-pill positive">
        <span>Room</span>
        <strong>@(task.Room?.RoomNumber ?? "Unassigned")</strong>
    </div>
</section>

<dl class="row mt-3 vpms-native-definition-strip">
    <dt class="col-sm-4">Assigned To</dt>
    <dd class="col-sm-8">@task.AssignedTo</dd>
    <dt class="col-sm-4">Priority</dt>
    <dd class="col-sm-8">@task.Priority</dd>
    <dt class="col-sm-4">Current Status</dt>
    <dd class="col-sm-8">@task.TaskStatus</dd>
    <dt class="col-sm-4">Notes</dt>
    <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(task.Notes) ? "No notes recorded." : task.Notes)</dd>
</dl>

<form method="post" asp-page-handler="Complete" asp-route-id="@task.Id" class="vpms-native-workflow-form">
    <div class="vpms-native-action-row">
        <a class="btn btn-outline-secondary" href="#" data-vpms-dialog-close>Cancel</a>
        <button class="btn vpms-btn-primary" type="submit">Mark Completed</button>
    </div>
</form>
