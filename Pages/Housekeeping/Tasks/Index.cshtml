@page
@model Vantage.PMS.Pages.Housekeeping.Tasks.IndexModel

@{
    ViewData["Title"] = "Housekeeping Tasks";
}

<div class="page-header">
    <div>
        <div class="page-kicker">Rooms Operations</div>
        <h1 class="page-title">Housekeeping Tasks</h1>
        <p class="page-subtitle">Supervisor task queue for room readiness, priority cleaning, and operational follow-through.</p>
    </div>
    <div class="page-actions">
        <a class="btn vpms-btn-primary" asp-page="./Create" data-vpms-native-dialog data-vpms-native-handler="Native" data-vpms-native-dialog-title="Create Housekeeping Task">Create Task</a>
        <a class="btn vpms-btn-secondary" asp-page="/Housekeeping/Index">Room Board</a>
    </div>
</div>

<section class="vpms-card">
    @if (Model.Tasks.Count == 0)
    {
        <div class="vpms-empty-state">
            <strong>No housekeeping tasks are open.</strong>
            <span>Create a task from this queue or from the room board when rooms need cleaning, inspection, or maintenance follow-up.</span>
        </div>
    }
    else
    {
        <div class="vpms-table-wrapper">
            <table class="table vpms-table align-middle">
                <thead>
                    <tr>
                        <th>Room</th>
                        <th>Assigned To</th>
                        <th>Status</th>
                        <th>Priority</th>
                        <th>Started</th>
                        <th>Completed</th>
                        <th>Notes</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var task in Model.Tasks)
                    {
                        <tr>
                            <td class="fw-semibold">@task.Room?.RoomNumber</td>
                            <td>@task.AssignedTo</td>
                            <td><span class="status-badge">@task.TaskStatus</span></td>
                            <td><span class="status-badge @(task.Priority.ToString().Contains("Urgent") ? "status-warning" : "")">@task.Priority</span></td>
                            <td>@(task.StartedAt?.ToString("g") ?? "-")</td>
                            <td>@(task.CompletedAt?.ToString("g") ?? "-")</td>
                            <td class="text-muted">@task.Notes</td>
                            <td class="text-end">
                                @if (task.TaskStatus != Vantage.PMS.Models.Housekeeping.HousekeepingTaskStatus.Completed)
                                {
                                    <a class="btn btn-sm vpms-btn-secondary"
                                       asp-page-handler="CompleteNative"
                                       asp-route-id="@task.Id"
                                       data-vpms-native-dialog
                                       data-vpms-native-handler="CompleteNative"
                                       data-vpms-native-dialog-title="Complete Housekeeping Task">Complete</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
