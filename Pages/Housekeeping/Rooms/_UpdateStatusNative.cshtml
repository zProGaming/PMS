@model Vantage.PMS.Pages.Housekeeping.Rooms.UpdateStatusModel

<section class="vpms-native-modal-intro vpms-native-hk-intro">
    <div>
        <div class="page-kicker">Room Readiness</div>
        <h1>Room @Model.Room.RoomNumber</h1>
        <p>@Model.Room.Property?.Name | Current status: @Model.Room.Status</p>
    </div>
    <div class="vpms-native-balance-pill">
        <span>Next Action</span>
        <strong>Update</strong>
    </div>
</section>

<dl class="row mt-3 vpms-native-definition-strip">
    <dt class="col-sm-3">Property</dt>
    <dd class="col-sm-9">@Model.Room.Property?.Name</dd>

    <dt class="col-sm-3">Room</dt>
    <dd class="col-sm-9">@Model.Room.RoomNumber</dd>

    <dt class="col-sm-3">Current Status</dt>
    <dd class="col-sm-9">@Model.Room.Status</dd>
</dl>

<form method="post"
      asp-page="./UpdateStatus"
      asp-route-id="@Model.Room.Id"
      class="vpms-native-workflow-form vpms-native-housekeeping-form">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="Room.Id" />

    <div class="vpms-native-step-grid compact" aria-label="Room status path">
        <span><strong>Dirty</strong><small>Clean next</small></span>
        <span><strong>Clean</strong><small>Inspect next</small></span>
        <span><strong>Inspected</strong><small>Release next</small></span>
    </div>

    <div class="mb-3">
        <label asp-for="TargetStatus" class="form-label">New Status</label>
        <select asp-for="TargetStatus" class="form-select" asp-items="Model.StatusOptions"></select>
        <span asp-validation-for="TargetStatus" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Notes" class="form-label"></label>
        <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Notes" class="text-danger"></span>
    </div>

    <div class="vpms-native-action-row">
        <a class="btn btn-outline-secondary" asp-page="/Housekeeping/Index" data-vpms-dialog-close>Cancel</a>
        <button type="submit" class="btn btn-primary">Update Status</button>
    </div>
</form>
