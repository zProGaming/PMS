@model Vantage.PMS.Pages.Groups.DetailsModel

<section class="vpms-native-modal-intro">
    <div>
        <span class="page-kicker">Group Allocation</span>
        <h1>Allocate Payment / Deposit</h1>
        <p>Apply an available group deposit to a target folio or member reservation while keeping the group collection summary in context.</p>
    </div>
    <div class="vpms-native-balance-pill @(Model.CollectionSummary.OutstandingBalance > 0 ? "warning" : "positive")">
        <span>Outstanding</span>
        <strong>@Model.CollectionSummary.OutstandingBalance.ToString("C")</strong>
    </div>
</section>

<div class="row g-3 mb-3 vpms-native-summary-row">
    <div class="col-md-4">
        <div class="border rounded p-3">
            <div class="text-muted small">Deposits</div>
            <strong>@Model.CollectionSummary.TotalDeposits.ToString("C")</strong>
        </div>
    </div>
    <div class="col-md-4">
        <div class="border rounded p-3">
            <div class="text-muted small">Allocated</div>
            <strong>@Model.CollectionSummary.TotalAllocated.ToString("C")</strong>
        </div>
    </div>
    <div class="col-md-4">
        <div class="border rounded p-3">
            <div class="text-muted small">Posted Charges</div>
            <strong>@Model.CollectionSummary.TotalPostedCharges.ToString("C")</strong>
        </div>
    </div>
</div>

<form method="post" asp-page-handler="Allocate" asp-route-id="@Model.GroupBooking.Id" class="vpms-native-workflow-form">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <section class="vpms-form-section">
        <div class="vpms-form-section-heading">
            <h2>Allocation Target</h2>
            <p>Select one deposit/payment source and one receiving folio or reservation.</p>
        </div>
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="AllocationInput.GroupDepositId" class="form-label">Deposit</label>
                <select asp-for="AllocationInput.GroupDepositId" asp-items="Model.DepositOptions" class="form-select">
                    <option value="">None</option>
                </select>
            </div>
            <div class="col-md-6">
                <label asp-for="AllocationInput.TargetFolioId" class="form-label">Target Folio</label>
                <select asp-for="AllocationInput.TargetFolioId" asp-items="Model.FolioOptions" class="form-select">
                    <option value="">None</option>
                </select>
            </div>
            <div class="col-md-6">
                <label asp-for="AllocationInput.TargetReservationId" class="form-label">Target Reservation</label>
                <select asp-for="AllocationInput.TargetReservationId" asp-items="Model.MemberReservationOptions" class="form-select">
                    <option value="">None</option>
                </select>
                <span asp-validation-for="AllocationInput.TargetReservationId" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="AllocationInput.AllocatedAmount" class="form-label">Amount</label>
                <input asp-for="AllocationInput.AllocatedAmount" type="number" min="0.01" step="0.01" class="form-control" />
                <span asp-validation-for="AllocationInput.AllocatedAmount" class="text-danger"></span>
            </div>
            <div class="col-12">
                <label asp-for="AllocationInput.Notes" class="form-label">Notes</label>
                <input asp-for="AllocationInput.Notes" class="form-control" />
            </div>
        </div>
    </section>
    <div class="vpms-native-action-row">
        <a class="btn btn-outline-secondary" href="#" data-vpms-dialog-close>Cancel</a>
        <button class="btn vpms-btn-primary" type="submit">Allocate</button>
    </div>
</form>
