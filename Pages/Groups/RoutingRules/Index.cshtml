@page
@model Vantage.PMS.Pages.Groups.RoutingRules.IndexModel
@using Vantage.PMS.Models.Finance
@using Vantage.PMS.Models.Groups
@{
    ViewData["Title"] = "Charge Routing Rules";
}

<div class="page-header">
    <div>
        <div class="page-kicker">Group Billing Setup</div>
        <h1 class="page-title">Charge Routing Rules</h1>
        <p class="page-subtitle">Route room, tax, F&B, banquet, and incidental charges to guest folios, group master folios, or pseudo room accounts.</p>
    </div>
    <div class="page-actions">
        <a class="btn vpms-btn-primary"
           asp-page="./Index"
           data-vpms-native-dialog
           data-vpms-native-handler="Native"
           data-vpms-native-dialog-title="Create Routing Rule">Create Rule</a>
        <a class="btn vpms-btn-secondary" asp-page="/Groups/Index">Group Bookings</a>
        <a class="btn vpms-btn-secondary" asp-page="/Groups/PseudoRooms/Index">Pseudo Rooms</a>
    </div>
</div>

<section class="vpms-card">
    @if (Model.Rules.Count == 0)
    {
        <div class="vpms-empty-state">No charge routing rules have been configured.</div>
    }
    else
    {
        <div class="vpms-table-wrapper">
            <table class="table vpms-table align-middle">
                <thead>
                <tr>
                    <th>Source</th>
                    <th>Category</th>
                    <th>Route To</th>
                    <th>Target</th>
                    <th>Status</th>
                    <th>Notes</th>
                    <th class="text-end">Actions</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var rule in Model.Rules)
                {
                    var source = rule.GroupBooking?.GroupName
                        ?? rule.Reservation?.ConfirmationNumber
                        ?? rule.Folio?.FolioNumber
                        ?? "Unscoped";
                    var target = rule.TargetGroupFolio?.FolioName
                        ?? rule.TargetFolio?.FolioNumber
                        ?? rule.TargetPseudoRoom?.PseudoRoomCode
                        ?? "Not configured";
                    <tr>
                        <td>@source</td>
                        <td>@rule.SourceChargeCategory</td>
                        <td>@rule.RouteToType</td>
                        <td>@target</td>
                        <td><span class="status-badge @(rule.IsActive ? "status-paid" : "status-cancelled")">@(rule.IsActive ? "Active" : "Inactive")</span></td>
                        <td class="text-muted">@rule.Notes</td>
                        <td class="text-end">
                            <form method="post" asp-page-handler="Toggle" asp-route-id="@rule.Id" class="d-inline">
                                <button class="btn btn-sm vpms-btn-secondary">@(rule.IsActive ? "Deactivate" : "Activate")</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
