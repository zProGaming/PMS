@page
@model Vantage.PMS.Areas.Identity.Pages.Account.LoginModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "Sign in";
    ViewData["BodyClass"] = "vpms-login-screen";
}

<section class="vpms-login-stage" aria-labelledby="login-title">
    <div class="vpms-login-card">
        <div class="vpms-login-brand">
            <div class="vpms-login-logo-wrap">
                <img src="~/images/vantage-pms-logo.png" asp-append-version="true" alt="Vantage PMS" />
            </div>
        </div>

        <div class="vpms-login-copy">
            <h1 id="login-title">Secure Log In</h1>
        </div>

        <form id="account" method="post" class="vpms-login-form" novalidate>
            <div asp-validation-summary="ModelOnly" class="text-danger vpms-login-validation" role="alert"></div>
            <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />

            <div class="vpms-floating-field">
                <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                <label asp-for="Input.Email">Email Address</label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="vpms-floating-field">
                <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="Password" />
                <label asp-for="Input.Password">Password</label>
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="vpms-login-options">
                <label class="vpms-login-check">
                    <input asp-for="Input.RememberMe" />
                    <span>@Html.DisplayNameFor(model => model.Input.RememberMe)</span>
                </label>
                <a asp-page="./ForgotPassword">Forgot password?</a>
            </div>

            <button id="login-submit" type="submit" class="vpms-login-submit">
                <span class="vpms-login-submit-text">Sign In</span>
                <span class="vpms-login-submit-loader" aria-hidden="true"></span>
            </button>
        </form>

        <div class="vpms-login-footer">
            <span>Copyright © 2026 Vantage Innovations PH. All rights reserved.</span>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const form = document.getElementById("account");
            const button = document.getElementById("login-submit");
            if (!form || !button) {
                return;
            }

            form.addEventListener("submit", () => {
                if (form.checkValidity()) {
                    button.classList.add("is-loading");
                    button.setAttribute("aria-busy", "true");
                }
            });
        })();
    </script>
}
