@page
@model Vantage.PMS.Areas.Identity.Pages.Account.AccessDeniedModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "Access denied";
}

<div class="alert alert-warning" role="alert">
    <h1 class="h4">Access denied</h1>
    <p class="mb-0">Your account does not have permission to open this Vantage PMS module.</p>
</div>

<div class="d-flex gap-2">
    <a class="btn btn-primary" asp-area="" asp-page="/Index">Go to Home</a>
    <a class="btn btn-outline-secondary" asp-area="Identity" asp-page="/Account/Manage/Index">View Account</a>
</div>
